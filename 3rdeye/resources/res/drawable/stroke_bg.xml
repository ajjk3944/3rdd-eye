<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android" android:color="#79ddff">
    <item android:id="@android:id/mask">
        <shape android:shape="rectangle">
            <solid android:color="#79ddff"/>
            <corners android:radius="@dimen/_25sdp"/>
        </shape>
    </item>
    <item android:id="@android:id/background">
        <shape>
            <stroke
                android:width="1dp"
                android:color="#b2a8a8"/>
            <corners android:radius="@dimen/_30sdp"/>
        </shape>
    </item>
</ripple>
