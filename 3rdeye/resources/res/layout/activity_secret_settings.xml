<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rootView"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/containerToto"
        android:paddingLeft="16dp"
        android:paddingTop="10dp"
        android:paddingRight="16dp"
        android:paddingBottom="10dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="90dp"
        android:paddingHorizontal="16dp"
        android:paddingVertical="10dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        <TextView
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/ph_black"
            android:id="@+id/tvTotoStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <Button
            android:textSize="18sp"
            android:textStyle="bold"
            android:id="@+id/btnFetchRemote"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:minHeight="30dp"
            android:text="Fetch Remote"
            android:textAllCaps="false"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tvTotoStatus"/>
        <Button
            android:textSize="18sp"
            android:textStyle="bold"
            android:id="@+id/btnViewHideConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="30dp"
            android:textAllCaps="false"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/btnFetchRemote"
            app:layout_goneMarginTop="10dp"/>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/paramsList"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            app:layout_constraintHeight_max="300dp"
            app:layout_constraintTop_toBottomOf="@+id/btnViewHideConfig"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <View
        android:id="@+id/dividerToto"
        android:background="@color/medium_grey"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        app:layout_constraintTop_toBottomOf="@+id/containerToto"/>
    <TextView
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/ph_black"
        android:id="@+id/tvItemPurchase"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:text="Purchase:"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/dividerToto"/>
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/offeringLayout"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:weightSum="2"
        android:layout_marginStart="16dp"
        android:layout_marginEnd="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tvItemPurchase">
        <Button
            android:id="@+id/btn_relaunch"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="Relaunch"
            android:layout_weight="1"
            android:textAllCaps="false"
            android:layout_marginEnd="4dp"/>
        <Button
            android:id="@+id/btn_onboarding"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="StartLikePro"
            android:layout_weight="1"
            android:textAllCaps="false"
            android:layout_marginStart="4dp"/>
    </LinearLayout>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/itemsRV"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/offeringLayout"/>
    <FrameLayout
        android:id="@+id/fragmentContainer"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
