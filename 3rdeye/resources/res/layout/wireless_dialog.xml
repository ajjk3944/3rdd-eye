<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/root"
    android:background="@color/white"
    android:padding="@dimen/_10sdp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.AppCompatImageView
        android:layout_gravity="end"
        android:id="@+id/close"
        android:padding="@dimen/_5sdp"
        android:layout_width="@dimen/_30sdp"
        android:layout_height="@dimen/_30sdp"
        app:srcCompat="@drawable/ic_cross"
        app:tint="@color/colorTextSecond"/>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@color/colorPrimaryDark"
        android:id="@+id/head"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/detect_wired_camera"
        android:layout_marginStart="@dimen/_10sdp"
        android:letterSpacing="0.03"/>
    <View
        android:id="@+id/view"
        android:background="@color/dimColor"
        android:layout_width="match_parent"
        android:layout_height="2dp"
        android:layout_marginTop="@dimen/_10sdp"
        android:alpha="0.2"/>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_10sdp"
        android:layout_marginBottom="@dimen/_10sdp"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_marginEnd="@dimen/_10sdp">
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/device"
            android:layout_width="90dp"
            android:layout_height="wrap_content"
            app:srcCompat="@drawable/ic_device"
            app:tint="@color/colorPrimaryDark"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:layout_gravity="center_vertical"
            android:layout_width="@dimen/_25sdp"
            android:layout_height="@dimen/_25sdp"
            android:layout_marginStart="150dp"
            app:srcCompat="@drawable/ic_find_device"
            app:tint="@color/colorPrimaryDark"/>
    </LinearLayout>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="15sp"
        android:textColor="@color/colorTextSecond"
        android:id="@+id/body"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/_5sdp"
        android:layout_marginBottom="@dimen/_15sdp"
        android:text="@string/detect_wired_info"
        android:lineSpacingExtra="@dimen/_3sdp"
        android:layout_marginStart="@dimen/_10sdp"
        android:layout_marginEnd="@dimen/_10sdp"/>
    <androidx.appcompat.widget.AppCompatButton
        android:textColor="@color/white"
        android:layout_gravity="end"
        android:id="@+id/ok"
        android:background="@drawable/button_click"
        android:paddingLeft="@dimen/_15sdp"
        android:paddingRight="@dimen/_15sdp"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/_40sdp"
        android:layout_marginTop="@dimen/_15sdp"
        android:layout_marginBottom="@dimen/_10sdp"
        android:text="@string/find_camera"
        android:textAllCaps="false"
        android:drawableEnd="@drawable/ic_arrow_right"
        android:layout_marginEnd="@dimen/_10sdp"
        android:backgroundTint="@color/colorPrimaryDark"
        android:letterSpacing="0.04"
        android:drawableTint="@color/white"
        android:paddingHorizontal="@dimen/_15sdp"
        style="@style/Widget.AppCompat.Button.Borderless"/>
</LinearLayout>
