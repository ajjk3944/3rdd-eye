<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:background="@color/colorPrimary"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:paddingStart="@dimen/_35sdp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="@string/settings"
        app:titleTextColor="@color/white"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/back"
        android:layout_width="@dimen/_35sdp"
        android:layout_height="@dimen/_30sdp"
        android:rotation="180"
        app:layout_constraintBottom_toBottomOf="@+id/toolbar"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_arrow_right"/>
    <FrameLayout
        android:id="@+id/container_fragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/view2"
        app:layout_constraintTop_toBottomOf="@+id/toolbar"/>
    <View
        android:id="@+id/view2"
        android:background="@color/colorPrimaryDark"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_2sdp"
        android:alpha="0.2"
        app:layout_constraintBottom_toTopOf="@+id/view"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <View
        android:id="@+id/view"
        android:background="@color/colorPrimaryDark"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_4sdp"
        android:alpha="0.2"
        app:layout_constraintBottom_toTopOf="@+id/linearLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <LinearLayout
        android:id="@+id/linearLayout"
        android:background="@color/colorPrimary"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_60sdp"
        app:layout_constraintBottom_toTopOf="@+id/banner"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <androidx.appcompat.widget.AppCompatButton
            android:textColor="@color/white"
            android:id="@+id/photos"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/photo_log"
            android:singleLine="true"
            android:drawableTop="@drawable/ic_gallery_fill"
            android:layout_weight="1"
            android:textAllCaps="false"
            android:letterSpacing="0.02"
            android:drawableTint="@color/white"
            style="@style/Widget.AppCompat.Button.Borderless"/>
        <androidx.appcompat.widget.AppCompatButton
            android:textColor="@color/colorTextSecond"
            android:id="@+id/settings"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/settings"
            android:singleLine="true"
            android:drawableTop="@drawable/ic_setting"
            android:layout_weight="1"
            android:textAllCaps="false"
            android:letterSpacing="0.02"
            android:drawableTint="@color/colorTextSecond"
            style="@style/Widget.AppCompat.Button.Borderless"/>
        <androidx.appcompat.widget.AppCompatButton
            android:textColor="@color/colorTextSecond"
            android:id="@+id/history"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/history"
            android:singleLine="true"
            android:drawableTop="@drawable/ic_clock"
            android:layout_weight="1"
            android:textAllCaps="false"
            android:letterSpacing="0.02"
            android:drawableTint="@color/colorTextSecond"
            style="@style/Widget.AppCompat.Button.Borderless"/>
    </LinearLayout>
    <com.zipoapps.ads.banner.PhShimmerBannerAdView
        android:id="@+id/banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:banner_size="adaptive_anchored"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
