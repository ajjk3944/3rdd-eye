<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/toolbar_view"
        android:background="@color/colorPrimary"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:background="@color/colorPrimary"
            android:layout_width="0dp"
            android:layout_height="?attr/actionBarSize"
            android:layout_marginEnd="@dimen/_5sdp"
            app:layout_constraintEnd_toStartOf="@+id/detect"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:title="@string/tips_and_tricks"
            app:titleTextColor="@color/white"/>
        <androidx.appcompat.widget.AppCompatButton
            android:textColor="@color/white"
            android:id="@+id/detect"
            android:background="@drawable/button_click"
            android:paddingLeft="@dimen/_10sdp"
            android:paddingRight="@dimen/_10sdp"
            android:layout_width="wrap_content"
            android:layout_height="@dimen/_30sdp"
            android:text="@string/detect"
            android:drawablePadding="@dimen/_5sdp"
            android:textAllCaps="false"
            android:drawableStart="@drawable/ic_camera_find"
            android:layout_marginEnd="@dimen/_3sdp"
            android:backgroundTint="@color/colorOrange"
            android:letterSpacing="0.02"
            android:drawableTint="@color/white"
            android:paddingHorizontal="@dimen/_10sdp"
            app:layout_constraintBottom_toBottomOf="@+id/toolbar"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            style="@style/Widget.AppCompat.Button.Borderless"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <FrameLayout
        android:id="@+id/container_fragment"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/view"
        app:layout_constraintTop_toBottomOf="@+id/toolbar_view"/>
    <View
        android:id="@+id/view"
        android:background="@color/colorTextSecond"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_2sdp"
        android:alpha="0.2"
        app:layout_constraintBottom_toTopOf="@+id/linearLayout"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
    <LinearLayout
        android:id="@+id/linearLayout"
        android:background="@color/colorPrimaryDark"
        android:layout_width="match_parent"
        android:layout_height="@dimen/_60sdp"
        app:layout_constraintBottom_toTopOf="@+id/banner"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <androidx.appcompat.widget.AppCompatButton
            android:textSize="14sp"
            android:textColor="@color/white"
            android:id="@+id/bedroom"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/bedroom"
            android:singleLine="true"
            android:drawableTop="@drawable/ic_bedroom"
            android:layout_weight="1"
            android:textAllCaps="false"
            android:drawableTint="@color/white"
            style="@style/Widget.AppCompat.Button.Borderless"/>
        <androidx.appcompat.widget.AppCompatButton
            android:textSize="14sp"
            android:textColor="@color/colorTextSecond"
            android:id="@+id/bathroom"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/bathroom"
            android:singleLine="true"
            android:drawableTop="@drawable/ic_bathroom"
            android:layout_weight="1"
            android:textAllCaps="false"
            android:drawableTint="@color/colorTextSecond"
            style="@style/Widget.AppCompat.Button.Borderless"/>
        <androidx.appcompat.widget.AppCompatButton
            android:textSize="14sp"
            android:textColor="@color/colorTextSecond"
            android:id="@+id/changing"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/changing"
            android:singleLine="true"
            android:drawableTop="@drawable/ic_changing"
            android:layout_weight="1"
            android:textAllCaps="false"
            android:drawableTint="@color/colorTextSecond"
            style="@style/Widget.AppCompat.Button.Borderless"/>
        <androidx.appcompat.widget.AppCompatButton
            android:textSize="14sp"
            android:textColor="@color/colorTextSecond"
            android:id="@+id/outside"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:text="@string/outside"
            android:singleLine="true"
            android:drawableTop="@drawable/ic_outside"
            android:layout_weight="1"
            android:textAllCaps="false"
            android:drawableTint="@color/colorTextSecond"
            style="@style/Widget.AppCompat.Button.Borderless"/>
    </LinearLayout>
    <com.zipoapps.ads.banner.PhShimmerBannerAdView
        android:id="@+id/banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:banner_size="adaptive_anchored"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
