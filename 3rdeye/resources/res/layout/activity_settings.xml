<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:background="@drawable/setting_bar"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        app:layout_constraintBottom_toTopOf="@+id/uninstall"
        app:layout_constraintTop_toTopOf="parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <androidx.cardview.widget.CardView
                android:id="@+id/pro_lay"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/_20sdp"
                android:layout_marginStart="@dimen/_20sdp"
                android:layout_marginEnd="@dimen/_20sdp"
                app:cardCornerRadius="@dimen/_13sdp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/pro"
                    android:background="@drawable/button_click"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:backgroundTint="@color/white"
                    app:layout_constraintTop_toTopOf="parent">
                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/crown"
                        android:layout_width="@dimen/_50sdp"
                        android:layout_height="@dimen/_50sdp"
                        android:layout_marginTop="@dimen/_10sdp"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:srcCompat="@drawable/ic_crown_new"/>
                    <androidx.appcompat.widget.AppCompatTextView
                        android:textSize="20sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorOrange"
                        android:id="@+id/go_premium"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/_5sdp"
                        android:text="@string/remove_ads"
                        android:letterSpacing="0.07"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/crown"/>
                    <com.airbnb.lottie.LottieAnimationView
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/_40sdp"
                        android:layout_marginTop="@dimen/_15sdp"
                        android:layout_marginBottom="@dimen/_15sdp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/go_premium"
                        app:lottie_autoPlay="true"
                        app:lottie_loop="true"
                        app:lottie_rawRes="@raw/premium"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/ll_buttons"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/_10sdp"
                android:layout_marginEnd="@dimen/_10sdp"
                app:layout_constraintTop_toBottomOf="@+id/pro_lay">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/help"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_45sdp"
                    android:layout_marginTop="@dimen/_10sdp"
                    android:foreground="?attr/selectableItemBackground"
                    android:layout_marginEnd="@dimen/_10sdp">
                    <androidx.appcompat.widget.AppCompatTextView
                        android:textSize="15sp"
                        android:textColor="@color/colorPrimaryDark"
                        android:gravity="center_vertical"
                        android:background="@color/transparent"
                        android:paddingLeft="@dimen/_10sdp"
                        android:paddingRight="@dimen/_10sdp"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="@string/how_to_use"
                        android:maxLines="1"
                        android:drawablePadding="@dimen/_20sdp"
                        android:textAllCaps="false"
                        android:drawableEnd="@drawable/ic_arrow_right_large"
                        android:letterSpacing="0.06"
                        android:paddingHorizontal="@dimen/_10sdp"
                        app:drawableStartCompat="@drawable/ic_help"
                        app:drawableTint="@color/colorPrimaryDark"/>
                    <androidx.appcompat.widget.AppCompatTextView
                        android:textSize="12sp"
                        android:textColor="@color/colorTextSecond"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/how_to_get_intruder_image"
                        android:singleLine="true"
                        android:paddingStart="@dimen/_17sdp"
                        android:layout_marginStart="@dimen/_32sdp"
                        android:letterSpacing="0.05"/>
                </LinearLayout>
                <View
                    android:background="@color/colorTextSecond"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:alpha="0.1"
                    android:layout_marginStart="@dimen/_10sdp"
                    android:layout_marginEnd="@dimen/_10sdp"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/language"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_45sdp"
                    android:foreground="?attr/selectableItemBackground"
                    android:layout_marginEnd="@dimen/_10sdp">
                    <androidx.appcompat.widget.AppCompatTextView
                        android:textSize="15sp"
                        android:textColor="@color/colorPrimaryDark"
                        android:gravity="center_vertical"
                        android:background="@color/transparent"
                        android:paddingLeft="@dimen/_10sdp"
                        android:paddingRight="@dimen/_10sdp"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="@string/choose_lang"
                        android:maxLines="1"
                        android:drawablePadding="@dimen/_20sdp"
                        android:textAllCaps="false"
                        android:drawableEnd="@drawable/ic_arrow_right_large"
                        android:letterSpacing="0.06"
                        android:paddingHorizontal="@dimen/_10sdp"
                        app:drawableStartCompat="@drawable/ic_language"
                        app:drawableTint="@color/colorPrimaryDark"/>
                    <androidx.appcompat.widget.AppCompatTextView
                        android:textSize="12sp"
                        android:textColor="@color/colorTextSecond"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/change_app_language"
                        android:singleLine="true"
                        android:paddingStart="@dimen/_17sdp"
                        android:layout_marginStart="@dimen/_32sdp"
                        android:letterSpacing="0.05"/>
                </LinearLayout>
                <View
                    android:background="@color/colorTextSecond"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:alpha="0.1"
                    android:layout_marginStart="@dimen/_10sdp"
                    android:layout_marginEnd="@dimen/_10sdp"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/privacy"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_45sdp"
                    android:foreground="?attr/selectableItemBackground"
                    android:layout_marginEnd="@dimen/_10sdp">
                    <androidx.appcompat.widget.AppCompatTextView
                        android:textSize="15sp"
                        android:textColor="@color/colorPrimaryDark"
                        android:gravity="center_vertical"
                        android:background="@color/transparent"
                        android:paddingLeft="@dimen/_10sdp"
                        android:paddingRight="@dimen/_10sdp"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="@string/ph_privacy_policy"
                        android:maxLines="1"
                        android:drawablePadding="@dimen/_20sdp"
                        android:textAllCaps="false"
                        android:drawableEnd="@drawable/ic_arrow_right_large"
                        android:letterSpacing="0.06"
                        android:paddingHorizontal="@dimen/_10sdp"
                        app:drawableStartCompat="@drawable/ic_privacy"
                        app:drawableTint="@color/colorPrimaryDark"/>
                    <androidx.appcompat.widget.AppCompatTextView
                        android:textSize="12sp"
                        android:textColor="@color/colorTextSecond"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/terms_and_conditions"
                        android:singleLine="true"
                        android:paddingStart="@dimen/_17sdp"
                        android:layout_marginStart="@dimen/_32sdp"
                        android:letterSpacing="0.05"/>
                </LinearLayout>
                <View
                    android:background="@color/colorTextSecond"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:alpha="0.1"
                    android:layout_marginStart="@dimen/_10sdp"
                    android:layout_marginEnd="@dimen/_10sdp"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/terms"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_45sdp"
                    android:foreground="?attr/selectableItemBackground"
                    android:layout_marginEnd="@dimen/_10sdp">
                    <androidx.appcompat.widget.AppCompatTextView
                        android:textSize="15sp"
                        android:textColor="@color/colorPrimaryDark"
                        android:gravity="center_vertical"
                        android:background="@color/transparent"
                        android:paddingLeft="@dimen/_10sdp"
                        android:paddingRight="@dimen/_10sdp"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="@string/terms_and_conditions"
                        android:maxLines="1"
                        android:drawablePadding="@dimen/_20sdp"
                        android:textAllCaps="false"
                        android:drawableEnd="@drawable/ic_arrow_right_large"
                        android:letterSpacing="0.06"
                        android:paddingHorizontal="@dimen/_10sdp"
                        app:drawableStartCompat="@drawable/ph_ic_terms"
                        app:drawableTint="@color/colorPrimaryDark"/>
                    <androidx.appcompat.widget.AppCompatTextView
                        android:textSize="12sp"
                        android:textColor="@color/colorTextSecond"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/terms_and_conditions"
                        android:singleLine="true"
                        android:paddingStart="@dimen/_17sdp"
                        android:layout_marginStart="@dimen/_32sdp"
                        android:letterSpacing="0.05"/>
                </LinearLayout>
                <View
                    android:background="@color/colorTextSecond"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:alpha="0.1"
                    android:layout_marginStart="@dimen/_10sdp"
                    android:layout_marginEnd="@dimen/_10sdp"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/feedback"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_45sdp"
                    android:foreground="?attr/selectableItemBackground"
                    android:layout_marginEnd="@dimen/_10sdp">
                    <TextView
                        android:textSize="15sp"
                        android:textColor="@color/colorPrimaryDark"
                        android:gravity="center_vertical"
                        android:id="@+id/tv_customer_support"
                        android:background="@color/transparent"
                        android:paddingLeft="@dimen/_10sdp"
                        android:paddingRight="@dimen/_10sdp"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="@string/ph_customer_support"
                        android:maxLines="1"
                        android:drawablePadding="@dimen/_20sdp"
                        android:textAllCaps="false"
                        android:letterSpacing="0.06"
                        android:paddingHorizontal="@dimen/_10sdp"
                        app:drawableEndCompat="@drawable/ic_arrow_right_large"
                        app:drawableStartCompat="@drawable/ic_feedback"
                        app:drawableTint="@color/colorPrimaryDark"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@color/colorTextSecond"
                        android:id="@+id/resolution_text"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/your_feedback"
                        android:paddingStart="@dimen/_17sdp"
                        android:layout_marginStart="@dimen/_32sdp"
                        android:letterSpacing="0.05"/>
                </LinearLayout>
                <View
                    android:background="@color/colorTextSecond"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:alpha="0.1"
                    android:layout_marginStart="@dimen/_10sdp"
                    android:layout_marginEnd="@dimen/_10sdp"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/share"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_45sdp"
                    android:foreground="?attr/selectableItemBackground"
                    android:layout_marginEnd="@dimen/_10sdp">
                    <TextView
                        android:textSize="15sp"
                        android:textColor="@color/colorPrimaryDark"
                        android:gravity="center_vertical"
                        android:background="@color/transparent"
                        android:paddingLeft="@dimen/_10sdp"
                        android:paddingRight="@dimen/_10sdp"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="@string/share"
                        android:maxLines="1"
                        android:drawablePadding="@dimen/_20sdp"
                        android:textAllCaps="false"
                        android:letterSpacing="0.06"
                        android:paddingHorizontal="@dimen/_10sdp"
                        app:drawableEndCompat="@drawable/ic_arrow_right_large"
                        app:drawableStartCompat="@drawable/ic_share"
                        app:drawableTint="@color/colorPrimaryDark"/>
                </LinearLayout>
                <View
                    android:background="@color/colorTextSecond"
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:alpha="0.1"
                    android:layout_marginStart="@dimen/_10sdp"
                    android:layout_marginEnd="@dimen/_10sdp"/>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/rate"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_45sdp"
                    android:foreground="?attr/selectableItemBackground"
                    android:maxLines="1"
                    android:layout_marginEnd="@dimen/_10sdp">
                    <TextView
                        android:textSize="15sp"
                        android:textColor="@color/colorPrimaryDark"
                        android:gravity="center_vertical"
                        android:layout_gravity="center_vertical"
                        android:background="@color/transparent"
                        android:paddingLeft="@dimen/_10sdp"
                        android:paddingRight="@dimen/_10sdp"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="@string/rate"
                        android:drawablePadding="@dimen/_20sdp"
                        android:textAllCaps="false"
                        android:letterSpacing="0.06"
                        android:paddingHorizontal="@dimen/_10sdp"
                        app:drawableEndCompat="@drawable/ic_arrow_right_large"
                        app:drawableStartCompat="@drawable/ic_rate"
                        app:drawableTint="@color/colorPrimaryDark"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@color/colorTextSecond"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/please_share"
                        android:paddingStart="@dimen/_17sdp"
                        android:layout_marginStart="@dimen/_32sdp"
                        android:letterSpacing="0.05"/>
                </LinearLayout>
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/personalized_ads"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/_45sdp"
                    android:layout_marginBottom="@dimen/_10sdp"
                    android:foreground="?attr/selectableItemBackground"
                    android:maxLines="1"
                    android:layout_marginEnd="@dimen/_10sdp">
                    <TextView
                        android:textSize="15sp"
                        android:textColor="@color/colorPrimaryDark"
                        android:gravity="center_vertical"
                        android:layout_gravity="center_vertical"
                        android:background="@color/transparent"
                        android:paddingLeft="@dimen/_10sdp"
                        android:paddingRight="@dimen/_10sdp"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:text="@string/personalized_ads"
                        android:drawablePadding="@dimen/_20sdp"
                        android:textAllCaps="false"
                        android:letterSpacing="0.06"
                        android:paddingHorizontal="@dimen/_10sdp"
                        app:drawableEndCompat="@drawable/ic_arrow_right_large"
                        app:drawableStartCompat="@drawable/ic_personalized_ads"
                        app:drawableTint="@color/colorPrimaryDark"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@color/colorTextSecond"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/please_share"
                        android:paddingStart="@dimen/_17sdp"
                        android:layout_marginStart="@dimen/_32sdp"
                        android:letterSpacing="0.05"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/uninstall"
        android:background="@drawable/button_click"
        android:layout_width="wrap_content"
        android:layout_height="@dimen/_40sdp"
        android:layout_marginTop="@dimen/_10sdp"
        android:layout_marginBottom="@dimen/_10sdp"
        android:backgroundTint="@color/colorOrange"
        app:layout_constraintBottom_toTopOf="@+id/banner"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="15sp"
            android:textColor="@color/white"
            android:gravity="center_vertical"
            android:layout_gravity="center_horizontal"
            android:background="@color/transparent"
            android:paddingLeft="@dimen/_10sdp"
            android:paddingRight="@dimen/_10sdp"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:text="@string/uninstall"
            android:maxLines="1"
            android:singleLine="true"
            android:drawablePadding="@dimen/_10sdp"
            android:textAllCaps="false"
            android:letterSpacing="0.06"
            android:paddingHorizontal="@dimen/_10sdp"
            app:drawableStartCompat="@drawable/ic_delete_2"
            app:drawableTint="@color/white"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/deactivate_admin"
            android:singleLine="true"
            android:paddingStart="@dimen/_17sdp"
            android:layout_marginStart="@dimen/_32sdp"
            android:letterSpacing="0.05"/>
    </LinearLayout>
    <com.zipoapps.ads.banner.PhShimmerBannerAdView
        android:id="@+id/banner"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:banner_size="adaptive_anchored"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
