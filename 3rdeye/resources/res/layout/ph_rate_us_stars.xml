<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:animateLayoutChanges="true"
    app:cardCornerRadius="8dp"
    app:cardPreventCornerOverlap="true">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/main_container"
        android:background="@color/ph_rate_dialog_background"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintWidth_percent="0.95">
            <ImageView
                android:id="@+id/rate_dialog_dismiss_button"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="8dp"
                android:layout_width="42dp"
                android:layout_height="42dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="8dp"
                android:layout_marginEnd="8dp"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ph_ic_close"
                app:tint="@color/rate_us_description_text_color"/>
            <TextView
                android:textSize="22sp"
                android:textColor="@color/ph_text_dark"
                android:gravity="center"
                android:id="@+id/tvTitle"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="28dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                style="@style/TextAppearance.AppCompat.Widget.ActionBar.Title"/>
            <TextView
                android:textSize="18sp"
                android:textColor="@color/rate_us_description_text_color"
                android:gravity="center"
                android:id="@+id/tvDescription"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:text="@string/rate_us_description"
                android:lineSpacingExtra="4dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvTitle"/>
            <androidx.recyclerview.widget.RecyclerView
                android:orientation="horizontal"
                android:id="@+id/rvReactions"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/rate_dialog_stars_margin"
                android:overScrollMode="never"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                app:layout_constraintDimensionRatio="38:6"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvDescription"/>
            <androidx.constraintlayout.widget.Guideline
                android:orientation="vertical"
                android:id="@+id/star5guideline"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_percent="0.9"/>
            <TextView
                android:textSize="18sp"
                android:textColor="@color/rate_us_description_text_color"
                android:gravity="center"
                android:id="@+id/tvHint"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp"
                android:text="@string/rate_us_hint"
                android:layout_marginEnd="8dp"
                app:layout_constrainedWidth="true"
                app:layout_constraintEnd_toStartOf="@+id/ivArrowHint"
                app:layout_constraintHorizontal_bias="1"
                app:layout_constraintStart_toStartOf="@+id/tvDescription"
                app:layout_constraintTop_toBottomOf="@+id/rvReactions"/>
            <ImageView
                android:id="@+id/ivArrowHint"
                android:layout_width="50dp"
                android:layout_height="50dp"
                android:src="@drawable/rateus_hint_arrow"
                android:layout_marginEnd="-5dp"
                app:layout_constraintEnd_toStartOf="@+id/star5guideline"
                app:layout_constraintTop_toBottomOf="@+id/rvReactions"
                app:tint="@color/rate_us_description_text_color"/>
            <TextView
                android:textColor="@android:color/white"
                android:id="@+id/btnSendFeedback"
                android:visibility="gone"
                android:layout_width="0dp"
                android:layout_marginTop="40dp"
                android:layout_marginBottom="24dp"
                android:text="@string/send_us_a_feedback"
                android:elevation="6dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvHint"
                style="@style/PhRateUsButton"/>
            <TextView
                android:enabled="false"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/rate_button_text_color"
                android:gravity="center"
                android:id="@+id/rate_dialog_positive_button"
                android:layout_width="0dp"
                android:layout_marginTop="@dimen/rate_dialog_btn_margin"
                android:layout_marginBottom="24dp"
                android:text="@string/rate"
                android:textAllCaps="false"
                android:fontFamily="sans-serif"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:translationZ="6dp"
                android:elevation="6dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/tvHint"
                style="@style/PhRateUsButton"/>
            <View
                android:id="@+id/rate_dialog_negative_button"
                android:visibility="gone"
                android:layout_width="1dp"
                android:layout_height="1dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
