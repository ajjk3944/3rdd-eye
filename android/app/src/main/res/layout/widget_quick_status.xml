<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <ImageView
        android:id="@+id/widget_wifi_icon"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@android:drawable/ic_menu_manage"
        android:layout_marginEnd="8dp"
        android:contentDescription="WiFi" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <TextView
            android:id="@+id/widget_ssid"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Not Connected"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/widget_signal_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-- dBm"
            android:textColor="#9CA3AF"
            android:textSize="11sp"
            android:maxLines="1" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/widget_signal_bars"
        android:layout_width="wrap_content"
        android:layout_height="24dp"
        android:orientation="horizontal"
        android:gravity="bottom"
        android:layout_marginStart="4dp">

        <View
            android:id="@+id/signal_bar_1"
            android:layout_width="4dp"
            android:layout_height="6dp"
            android:layout_marginEnd="2dp"
            android:background="#22D3EE" />

        <View
            android:id="@+id/signal_bar_2"
            android:layout_width="4dp"
            android:layout_height="10dp"
            android:layout_marginEnd="2dp"
            android:background="#22D3EE" />

        <View
            android:id="@+id/signal_bar_3"
            android:layout_width="4dp"
            android:layout_height="16dp"
            android:layout_marginEnd="2dp"
            android:background="#22D3EE" />

        <View
            android:id="@+id/signal_bar_4"
            android:layout_width="4dp"
            android:layout_height="22dp"
            android:background="#22D3EE" />
    </LinearLayout>

    <ImageView
        android:id="@+id/widget_refresh"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:src="@android:drawable/ic_menu_rotate"
        android:layout_marginStart="8dp"
        android:clickable="true"
        android:contentDescription="Refresh" />
</LinearLayout>
