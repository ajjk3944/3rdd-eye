<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="ThirdEye"
        android:textColor="#22D3EE"
        android:textSize="14sp"
        android:textStyle="bold"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <!-- Top row buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal"
        android:layout_marginBottom="8dp">

        <!-- WiFi Scan -->
        <LinearLayout
            android:id="@+id/widget_btn_wifi"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/widget_action_button_bg"
            android:clickable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📶"
                android:textSize="24sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="WiFi\nScan"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:gravity="center"
                android:maxLines="2" />
        </LinearLayout>

        <!-- Speed Test -->
        <LinearLayout
            android:id="@+id/widget_btn_speed"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/widget_action_button_bg"
            android:clickable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="⚡"
                android:textSize="24sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Speed\nTest"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:gravity="center"
                android:maxLines="2" />
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom row buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="horizontal">

        <!-- Network Scan -->
        <LinearLayout
            android:id="@+id/widget_btn_network"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/widget_action_button_bg"
            android:clickable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="🔍"
                android:textSize="24sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Network\nScan"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:gravity="center"
                android:maxLines="2" />
        </LinearLayout>

        <!-- Camera Detect -->
        <LinearLayout
            android:id="@+id/widget_btn_camera"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/widget_action_button_bg"
            android:clickable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="📷"
                android:textSize="24sp"
                android:layout_marginBottom="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Camera\nDetect"
                android:textColor="#FFFFFF"
                android:textSize="10sp"
                android:gravity="center"
                android:maxLines="2" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
