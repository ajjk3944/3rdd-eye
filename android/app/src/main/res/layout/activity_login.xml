<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#1a1a1a">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp"
        android:gravity="center">

        <!-- Logo/Title -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="3rd Eye"
            android:textSize="36sp"
            android:textColor="#ffffff"
            android:textStyle="bold"
            android:layout_marginTop="48dp"
            android:layout_marginBottom="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Network Security Scanner"
            android:textSize="14sp"
            android:textColor="#888888"
            android:layout_marginBottom="48dp" />

        <!-- Offline Indicator -->
        <TextView
            android:id="@+id/tv_offline_indicator"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚠ Offline Mode"
            android:textSize="14sp"
            android:textColor="#ff9800"
            android:background="#33ff9800"
            android:padding="12dp"
            android:gravity="center"
            android:layout_marginBottom="16dp"
            android:visibility="gone" />

        <!-- Username Input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Username"
            android:textSize="14sp"
            android:textColor="#cccccc"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/input_username"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Enter username"
            android:textColorHint="#666666"
            android:textColor="#ffffff"
            android:background="@drawable/input_background"
            android:padding="16dp"
            android:inputType="text"
            android:maxLines="1"
            android:layout_marginBottom="16dp" />

        <!-- Password Input -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Password"
            android:textSize="14sp"
            android:textColor="#cccccc"
            android:layout_marginBottom="8dp" />

        <EditText
            android:id="@+id/input_password"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:hint="Enter password"
            android:textColorHint="#666666"
            android:textColor="#ffffff"
            android:background="@drawable/input_background"
            android:padding="16dp"
            android:inputType="textPassword"
            android:maxLines="1"
            android:layout_marginBottom="24dp" />

        <!-- Status Text -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Sign in to access all features"
            android:textSize="14sp"
            android:textColor="#888888"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

        <!-- Sign In Button -->
        <Button
            android:id="@+id/btn_sign_in"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Sign In"
            android:textSize="16sp"
            android:textColor="#ffffff"
            android:background="@drawable/button_primary"
            android:layout_marginBottom="12dp" />

        <!-- Sign Up Button -->
        <Button
            android:id="@+id/btn_sign_up"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Sign Up"
            android:textSize="16sp"
            android:textColor="#ffffff"
            android:background="@drawable/button_secondary"
            android:layout_marginBottom="24dp" />

        <!-- Divider -->
        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#333333"
            android:layout_marginVertical="16dp" />

        <!-- Guest Button -->
        <Button
            android:id="@+id/btn_guest"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:text="Continue as Guest"
            android:textSize="16sp"
            android:textColor="#888888"
            android:background="@drawable/button_guest"
            android:layout_marginBottom="16dp" />

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Guest mode provides access to offline features only"
            android:textSize="12sp"
            android:textColor="#666666"
            android:gravity="center"
            android:layout_marginBottom="24dp" />

    </LinearLayout>

</ScrollView>
