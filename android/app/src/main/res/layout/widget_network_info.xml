<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <!-- Top row: Title + Refresh -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="8dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="ThirdEye"
            android:textColor="#22D3EE"
            android:textSize="16sp"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/widget_refresh"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_rotate"
            android:clickable="true"
            android:contentDescription="Refresh" />
    </LinearLayout>

    <!-- WiFi row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <ImageView
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@android:drawable/ic_menu_manage"
            android:layout_marginEnd="8dp"
            android:contentDescription="WiFi" />

        <TextView
            android:id="@+id/widget_ssid"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Not Connected"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:textStyle="bold"
            android:maxLines="1"
            android:ellipsize="end" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="20dp"
            android:orientation="horizontal"
            android:gravity="bottom"
            android:layout_marginStart="8dp"
            android:layout_marginEnd="8dp">

            <View
                android:id="@+id/signal_bar_1"
                android:layout_width="3dp"
                android:layout_height="5dp"
                android:layout_marginEnd="2dp"
                android:background="#22D3EE" />

            <View
                android:id="@+id/signal_bar_2"
                android:layout_width="3dp"
                android:layout_height="9dp"
                android:layout_marginEnd="2dp"
                android:background="#22D3EE" />

            <View
                android:id="@+id/signal_bar_3"
                android:layout_width="3dp"
                android:layout_height="14dp"
                android:layout_marginEnd="2dp"
                android:background="#22D3EE" />

            <View
                android:id="@+id/signal_bar_4"
                android:layout_width="3dp"
                android:layout_height="18dp"
                android:background="#22D3EE" />
        </LinearLayout>

        <TextView
            android:id="@+id/widget_signal_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="-- dBm"
            android:textColor="#9CA3AF"
            android:textSize="11sp" />
    </LinearLayout>

    <!-- Info cards row -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">

        <!-- IP Card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/widget_card_background">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="IP"
                android:textColor="#9CA3AF"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_ip_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="N/A"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:gravity="center"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Speed Card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:layout_marginStart="4dp"
            android:layout_marginEnd="4dp"
            android:background="@drawable/widget_card_background">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Speed"
                android:textColor="#9CA3AF"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_speed_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="N/A"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:gravity="center"
                android:ellipsize="end" />
        </LinearLayout>

        <!-- Devices Card -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="8dp"
            android:layout_marginStart="4dp"
            android:background="@drawable/widget_card_background">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Devices"
                android:textColor="#9CA3AF"
                android:textSize="10sp" />

            <TextView
                android:id="@+id/widget_devices_value"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="N/A"
                android:textColor="#FFFFFF"
                android:textSize="11sp"
                android:textStyle="bold"
                android:maxLines="2"
                android:gravity="center"
                android:ellipsize="end" />
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
