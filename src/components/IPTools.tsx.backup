                      </Button>
                    </div>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500">IPv6 (Full)</p>
                    <div className="flex items-center justify-between mt-1">
                      <p className="text-purple-400 font-mono text-xs break-all">{result.ipv6Full}</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.ipv6Full)}
                        className="h-6 px-2"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                      </Button>
                    </div>
                  </div>
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // IPv6 Compression View
  if (currentView === 'ipv6-compression') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Network className="w-5 h-5 text-green-400" />
            IPv6 Compression
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Compress IPv6 address to shortest form
          </p>
        </div>

        <Input
          placeholder="Enter IPv6 address"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-green-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && compressIpv6()}
        />

        <Button 
          onClick={compressIpv6} 
          disabled={!inputValue.trim()}
          className="bg-green-600 hover:bg-green-700 w-full"
        >
          Compress IPv6
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-green-900/30">
            <CardContent className="p-4 space-y-3">
              {result.error ? (
                <p className="text-red-400 text-sm">{result.error}</p>
              ) : (
                <>
                  <div>
                    <p className="text-xs text-gray-500">Original</p>
                    <p className="text-white font-mono text-sm mt-1 break-all">{result.original}</p>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500">Compressed</p>
                    <div className="flex items-center justify-between mt-1">
                      <p className="text-green-400 font-mono text-sm break-all">{result.compressed}</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.compressed)}
                        className="h-6 px-2"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                      </Button>
                    </div>
                  </div>
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // IPv6 Compatibility Test View
  if (currentView === 'ipv6-compatibility') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Check className="w-5 h-5 text-yellow-400" />
            IPv6 Compatibility Test
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Test your device's IPv6 compatibility
          </p>
        </div>

        <Button 
          onClick={testIpv6Compatibility} 
          className="bg-yellow-600 hover:bg-yellow-700 w-full"
        >
          Run Compatibility Test
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-yellow-900/30">
            <CardContent className="p-4 space-y-3">
              <div className="flex items-center justify-between p-3 rounded bg-yellow-900/10">
                <span className="text-sm text-gray-300">Overall Status</span>
                <Badge className={result.compatible ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400'}>
                  {result.compatible ? 'Compatible' : 'Limited'}
                </Badge>
              </div>
              {Object.entries(result.tests).map(([key, value]: [string, any]) => (
                <div key={key} className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                  <span className="text-sm text-gray-300">{key}</span>
                  <span className={value ? 'text-green-400' : 'text-red-400'}>
                    {value ? '✓' : '✗'}
                  </span>
                </div>
              ))}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // IPv6 CIDR Calculator View
  if (currentView === 'ipv6-cidr') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Network className="w-5 h-5 text-indigo-400" />
            IPv6 CIDR Calculator
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Calculate IPv6 network information from CIDR notation
          </p>
          <div className="mt-2 p-3 rounded bg-indigo-900/10 border border-indigo-900/30">
            <p className="text-xs text-indigo-300 font-medium mb-1">How to use:</p>
            <p className="text-xs text-gray-400">Enter an IPv6 address with CIDR prefix (e.g., 2001:db8::/32). The calculator will show network bits, host bits, and total addresses in the range.</p>
          </div>
        </div>

        <Input
          placeholder="Enter IPv6 CIDR (e.g., 2001:db8::/32)"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-indigo-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && calculateIpv6Cidr()}
        />

        <Button 
          onClick={calculateIpv6Cidr} 
          disabled={!inputValue.trim()}
          className="bg-indigo-600 hover:bg-indigo-700 w-full"
        >
          Calculate
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-indigo-900/30">
            <CardContent className="p-4 space-y-3">
              {result.error ? (
                <p className="text-red-400 text-sm">{result.error}</p>
              ) : (
                <>
                  <div className="grid grid-cols-2 gap-3">
                    <div className="p-3 rounded bg-indigo-900/10">
                      <p className="text-xs text-gray-500">Network Bits</p>
                      <p className="text-white font-mono text-lg">{result.networkBits}</p>
                    </div>
                    <div className="p-3 rounded bg-indigo-900/10">
                      <p className="text-xs text-gray-500">Host Bits</p>
                      <p className="text-white font-mono text-lg">{result.hostBits}</p>
                    </div>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500">Total Addresses</p>
                    <p className="text-indigo-400 font-mono mt-1">{result.totalAddresses}</p>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500">Usable Addresses</p>
                    <p className="text-indigo-400 font-mono mt-1">{result.usableAddresses}</p>
                  </div>
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // MAC Vendor Lookup View
  if (currentView === 'mac-vendor') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Network className="w-5 h-5 text-pink-400" />
            MAC Vendor Lookup
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Identify the manufacturer of a network device by its MAC address
          </p>
        </div>

        <Input
          placeholder="Enter MAC address (e.g., 00:1A:2B:3C:4D:5E)"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-pink-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && lookupMacVendor()}
        />

        <Button 
          onClick={lookupMacVendor} 
          disabled={loading || !inputValue.trim()}
          className="bg-pink-600 hover:bg-pink-700 w-full"
        >
          {loading ? 'Looking up...' : 'Lookup Vendor'}
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-pink-900/30">
            <CardContent className="p-4 space-y-3">
              {result.error ? (
                <p className="text-red-400 text-sm">{result.error}</p>
              ) : (
                <>
                  <div>
                    <p className="text-xs text-gray-500">MAC Address</p>
                    <div className="flex items-center justify-between mt-1">
                      <p className="text-white font-mono">{result.mac}</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.mac)}
                        className="h-6 px-2"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                      </Button>
                    </div>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500">Vendor / Manufacturer</p>
                    <div className="flex items-center justify-between mt-1">
                      <p className="text-pink-400 font-medium">{result.vendor}</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.vendor)}
                        className="h-6 px-2"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                      </Button>
                    </div>
                    {result.apiUsed && (
                      <p className="text-xs text-gray-600 mt-1">Source: {result.apiUsed}</p>
                    )}
                  </div>
                  {result.note && (
                    <div className="p-3 rounded bg-yellow-900/10 border border-yellow-900/30">
                      <p className="text-xs text-yellow-400">{result.note}</p>
                    </div>
                  )}
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // IP Range Expander View
  if (currentView === 'ip-range-expander') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Network className="w-5 h-5 text-orange-400" />
            IP Range Expander
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Expand CIDR notation or IP range into individual addresses
          </p>
        </div>

        <Input
          placeholder="192.168.1.0/24 or 192.168.1.1-192.168.1.10"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-orange-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && expandIpRange()}
        />

        <Button 
          onClick={expandIpRange} 
          disabled={!inputValue.trim()}
          className="bg-orange-600 hover:bg-orange-700 w-full"
        >
          Expand Range
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-orange-900/30">
            <CardContent className="p-4 space-y-3">
              {result.error ? (
                <p className="text-red-400 text-sm">{result.error}</p>
              ) : (
                <>
                  <div className="flex items-center justify-between p-3 rounded bg-orange-900/10">
                    <span className="text-sm text-gray-300">Total Addresses</span>
                    <span className="text-orange-400 font-mono text-lg">{result.count}</span>
                  </div>
                  {result.networkAddress && (
                    <div className="grid grid-cols-2 gap-3">
                      <div>
                        <p className="text-xs text-gray-500">Network</p>
                        <p className="text-white font-mono text-sm">{result.networkAddress}</p>
                      </div>
                      <div>
                        <p className="text-xs text-gray-500">Broadcast</p>
                        <p className="text-white font-mono text-sm">{result.broadcastAddress}</p>
                      </div>
                    </div>
                  )}
                  <div>
                    <div className="flex items-center justify-between mb-2">
                      <p className="text-xs text-gray-500">IP Addresses</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.ips.join('\n'))}
                        className="h-6 px-2 text-xs"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />} Copy All
                      </Button>
                    </div>
                    <ScrollArea className="h-[300px] rounded border border-orange-900/30 p-2">
                      <div className="space-y-1">
                        {result.ips.map((ip: string, i: number) => (
                          <div key={i} className="text-orange-400 font-mono text-xs p-1 hover:bg-orange-900/10 rounded">
                            {ip}
                          </div>
                        ))}
                      </div>
                    </ScrollArea>
                  </div>
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // IP Address Converter View
  if (currentView === 'ip-address-converter') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <RefreshCw className="w-5 h-5 text-teal-400" />
            IP Address Converter
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Convert IP address to binary, hexadecimal, and decimal formats
          </p>
        </div>

        <Input
          placeholder="Enter IPv4 address (e.g., 192.168.1.1)"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-teal-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && convertIpAddress()}
        />

        <Button 
          onClick={convertIpAddress} 
          disabled={!inputValue.trim()}
          className="bg-teal-600 hover:bg-teal-700 w-full"
        >
          Convert
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-teal-900/30">
            <CardContent className="p-4 space-y-3">
              {result.error ? (
                <p className="text-red-400 text-sm">{result.error}</p>
              ) : (
                <>
                  <div>
                    <p className="text-xs text-gray-500">IP Address</p>
                    <p className="text-white font-mono mt-1">{result.ip}</p>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500">Decimal</p>
                    <div className="flex items-center justify-between mt-1">
                      <p className="text-teal-400 font-mono">{result.decimal}</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.decimal.toString())}
                        className="h-6 px-2"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                      </Button>
                    </div>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500">Binary</p>
                    <div className="flex items-center justify-between mt-1">
                      <p className="text-teal-400 font-mono text-xs break-all">{result.binary}</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.binary)}
                        className="h-6 px-2"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                      </Button>
                    </div>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500">Hexadecimal (Colon)</p>
                    <div className="flex items-center justify-between mt-1">
                      <p className="text-teal-400 font-mono">{result.hex}</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.hex)}
                        className="h-6 px-2"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                      </Button>
                    </div>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500">Hexadecimal (Single)</p>
                    <div className="flex items-center justify-between mt-1">
                      <p className="text-teal-400 font-mono">{result.hexSingle}</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.hexSingle)}
                        className="h-6 px-2"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                      </Button>
                    </div>
                  </div>
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // Extract IP Addresses View
  if (currentView === 'extract-ip') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Network className="w-5 h-5 text-lime-400" />
            Extract IP Addresses
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Extract all IPv4 and IPv6 addresses from text
          </p>
          <div className="mt-2 p-3 rounded bg-lime-900/10 border border-lime-900/30">
            <p className="text-xs text-lime-300 font-medium mb-1">How to use:</p>
            <p className="text-xs text-gray-400">Paste any text containing IP addresses (logs, configs, etc.). The tool will automatically find and extract all IPv4 and IPv6 addresses.</p>
          </div>
        </div>

        <Textarea
          placeholder="Paste text containing IP addresses..."
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-lime-900/30 text-white min-h-[120px]"
        />

        <Button 
          onClick={extractIpAddresses} 
          disabled={!inputValue.trim()}
          className="bg-lime-600 hover:bg-lime-700 w-full"
        >
          Extract IPs
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-lime-900/30">
            <CardContent className="p-4 space-y-3">
              <div className="grid grid-cols-3 gap-3">
                <div className="p-3 rounded bg-lime-900/10 text-center">
                  <p className="text-xs text-gray-500">Total</p>
                  <p className="text-lime-400 font-mono text-xl">{result.total}</p>
                </div>
                <div className="p-3 rounded bg-blue-900/10 text-center">
                  <p className="text-xs text-gray-500">IPv4</p>
                  <p className="text-blue-400 font-mono text-xl">{result.totalIpv4}</p>
                </div>
                <div className="p-3 rounded bg-purple-900/10 text-center">
                  <p className="text-xs text-gray-500">IPv6</p>
                  <p className="text-purple-400 font-mono text-xl">{result.totalIpv6}</p>
                </div>
              </div>

              {result.ipv4.length > 0 && (
                <div>
                  <div className="flex items-center justify-between mb-2">
                    <p className="text-xs text-gray-500">IPv4 Addresses</p>
                    <Button
                      variant="ghost"
                      size="sm"
                      onClick={() => copyToClipboard(result.ipv4.join('\n'))}
                      className="h-6 px-2 text-xs"
                    >
                      {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />} Copy
                    </Button>
                  </div>
                  <ScrollArea className="h-[150px] rounded border border-blue-900/30 p-2">
                    <div className="space-y-1">
                      {result.ipv4.map((ip: string, i: number) => (
                        <div key={i} className="text-blue-400 font-mono text-xs p-1 hover:bg-blue-900/10 rounded">
                          {ip}
                        </div>
                      ))}
                    </div>
                  </ScrollArea>
                </div>
              )}

              {result.ipv6.length > 0 && (
                <div>
                  <div className="flex items-center justify-between mb-2">
                    <p className="text-xs text-gray-500">IPv6 Addresses</p>
                    <Button
                      variant="ghost"
                      size="sm"
                      onClick={() => copyToClipboard(result.ipv6.join('\n'))}
                      className="h-6 px-2 text-xs"
                    >
                      {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />} Copy
                    </Button>
                  </div>
                  <ScrollArea className="h-[150px] rounded border border-purple-900/30 p-2">
                    <div className="space-y-1">
                      {result.ipv6.map((ip: string, i: number) => (
                        <div key={i} className="text-purple-400 font-mono text-xs p-1 hover:bg-purple-900/10 rounded">
                          {ip}
                        </div>
                      ))}
                    </div>
                  </ScrollArea>
                </div>
              )}

              {result.total === 0 && (
                <p className="text-center text-gray-500 py-4">No IP addresses found</p>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // Random IP Generator View
  if (currentView === 'random-ip') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <RefreshCw className="w-5 h-5 text-violet-400" />
            Random IP Generator
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Generate random public IPv4 addresses (excludes private ranges)
          </p>
        </div>

        <Input
          type="number"
          placeholder="Number of IPs (1-100)"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-violet-900/30 text-white"
          min="1"
          max="100"
          onKeyDown={(e) => e.key === 'Enter' && generateRandomIp()}
        />

        <Button 
          onClick={generateRandomIp} 
          className="bg-violet-600 hover:bg-violet-700 w-full"
        >
          Generate Random IPs
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-violet-900/30">
            <CardContent className="p-4 space-y-3">
              {result.error ? (
                <p className="text-red-400 text-sm">{result.error}</p>
              ) : (
                <>
                  <div className="flex items-center justify-between p-3 rounded bg-violet-900/10">
                    <span className="text-sm text-gray-300">Generated IPs</span>
                    <span className="text-violet-400 font-mono text-lg">{result.count}</span>
                  </div>
                  <div>
                    <div className="flex items-center justify-between mb-2">
                      <p className="text-xs text-gray-500">IP Addresses</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.ips.join('\n'))}
                        className="h-6 px-2 text-xs"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />} Copy All
                      </Button>
                    </div>
                    <ScrollArea className="h-[300px] rounded border border-violet-900/30 p-2">
                      <div className="space-y-1">
                        {result.ips.map((ip: string, i: number) => (
                          <div key={i} className="text-violet-400 font-mono text-xs p-1 hover:bg-violet-900/10 rounded">
                            {ip}
                          </div>
                        ))}
                      </div>
                    </ScrollArea>
                  </div>
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // IP to Integer View
  if (currentView === 'ip-to-int') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Network className="w-5 h-5 text-amber-400" />
            IP to Integer Converter
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Convert IPv4 address to 32-bit integer representation
          </p>
        </div>

        <Input
          placeholder="Enter IPv4 address (e.g., 192.168.1.1)"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-amber-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && ipToInteger()}
        />

        <Button 
          onClick={ipToInteger} 
          disabled={!inputValue.trim()}
          className="bg-amber-600 hover:bg-amber-700 w-full"
        >
          Convert to Integer
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-amber-900/30">
            <CardContent className="p-4 space-y-3">
              {result.error ? (
                <p className="text-red-400 text-sm">{result.error}</p>
              ) : (
                <>
                  <div>
                    <p className="text-xs text-gray-500">IP Address</p>
                    <p className="text-white font-mono mt-1">{result.ip}</p>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500">Unsigned Integer (32-bit)</p>
                    <div className="flex items-center justify-between mt-1">
                      <p className="text-amber-400 font-mono text-lg">{result.unsigned}</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.unsigned.toString())}
                        className="h-6 px-2"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                      </Button>
                    </div>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500">Signed Integer</p>
                    <div className="flex items-center justify-between mt-1">
                      <p className="text-amber-400 font-mono">{result.signed}</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.signed.toString())}
                        className="h-6 px-2"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                      </Button>
                    </div>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500">Hexadecimal</p>
                    <div className="flex items-center justify-between mt-1">
                      <p className="text-amber-400 font-mono">{result.hex}</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.hex)}
                        className="h-6 px-2"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                      </Button>
                    </div>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500">Binary</p>
                    <div className="flex items-center justify-between mt-1">
                      <p className="text-amber-400 font-mono text-xs break-all">{result.binary}</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.binary)}
                        className="h-6 px-2"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                      </Button>
                    </div>
                  </div>
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // URL to IP View
  if (currentView === 'url-to-ip') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Globe className="w-5 h-5 text-sky-400" />
            URL to IP Lookup
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Resolve URL to IP address with geolocation information
          </p>
        </div>

        <Input
          placeholder="Enter URL (e.g., google.com or https://google.com)"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-sky-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && urlToIp()}
        />

        <Button 
          onClick={urlToIp} 
          disabled={loading || !inputValue.trim()}
          className="bg-sky-600 hover:bg-sky-700 w-full"
        >
          {loading ? 'Looking up...' : 'Lookup IP'}
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-sky-900/30">
            <CardContent className="p-4 space-y-3">
              {result.error ? (
                <p className="text-red-400 text-sm">{result.error}</p>
              ) : (
                <>
                  <div>
                    <p className="text-xs text-gray-500">URL</p>
                    <p className="text-white font-mono text-sm mt-1 break-all">{result.url}</p>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500">Hostname</p>
                    <p className="text-sky-400 font-mono mt-1">{result.hostname}</p>
                  </div>
                  <div className="flex items-center justify-between p-3 rounded bg-sky-900/10">
                    <span className="text-sm text-gray-300">Total IP Addresses</span>
                    <span className="text-sky-400 font-mono text-lg">{result.count}</span>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500 mb-2">IP Addresses & Locations</p>
                    <div className="space-y-2">
                      {result.ipInfo.map((info: any, i: number) => (
                        <Card key={i} className="bg-sky-900/10 border-sky-900/30">
                          <CardContent className="p-3 space-y-2">
                            <div className="flex items-center justify-between">
                              <p className="text-sky-400 font-mono text-sm">{info.ip}</p>
                              <Button
                                variant="ghost"
                                size="sm"
                                onClick={() => copyToClipboard(info.ip)}
                                className="h-6 px-2"
                              >
                                {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                              </Button>
                            </div>
                            <div className="text-xs space-y-1">
                              <div className="flex items-center gap-2">
                                <span className="text-gray-500">Location:</span>
                                <span className="text-gray-300">{info.city}, {info.country}</span>
                              </div>
                              <div className="flex items-center gap-2">
                                <span className="text-gray-500">Organization:</span>
                                <span className="text-gray-300">{info.org}</span>
                              </div>
                            </div>
                          </CardContent>
                        </Card>
                      ))}
                    </div>
                  </div>
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // IPv6 Test View
  if (currentView === 'ipv6-test') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Check className="w-5 h-5 text-fuchsia-400" />
            IPv6 Address Validator
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Validate and analyze IPv6 addresses
          </p>
        </div>

        <Input
          placeholder="Enter IPv6 address (e.g., 2001:db8::1)"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-fuchsia-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && testIpv6Address()}
        />

        <Button 
          onClick={testIpv6Address} 
          disabled={!inputValue.trim()}
          className="bg-fuchsia-600 hover:bg-fuchsia-700 w-full"
        >
          Validate IPv6
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-fuchsia-900/30">
            <CardContent className="p-4 space-y-3">
              <div className="flex items-center justify-between p-3 rounded bg-fuchsia-900/10">
                <span className="text-sm text-gray-300">Validation Status</span>
                <Badge className={result.valid ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400'}>
                  {result.valid ? 'Valid' : 'Invalid'}
                </Badge>
              </div>
              
              {result.valid ? (
                <>
                  <div>
                    <p className="text-xs text-gray-500">Address Type</p>
                    <p className="text-fuchsia-400 font-medium mt-1">{result.type}</p>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500">Description</p>
                    <p className="text-gray-300 text-sm mt-1">{result.details}</p>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500">Compressed Form</p>
                    <div className="flex items-center justify-between mt-1">
                      <p className="text-fuchsia-400 font-mono text-sm break-all">{result.compressed}</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.compressed)}
                        className="h-6 px-2"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                      </Button>
                    </div>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500">Expanded Form</p>
                    <div className="flex items-center justify-between mt-1">
                      <p className="text-fuchsia-400 font-mono text-xs break-all">{result.expanded}</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.expanded)}
                        className="h-6 px-2"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                      </Button>
                    </div>
                  </div>
                </>
              ) : (
                <div>
                  <p className="text-red-400 text-sm">{result.details}</p>
                </div>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // IP WHOIS Lookup View
  if (currentView === 'ip-whois') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Globe className="w-5 h-5 text-rose-400" />
            IP WHOIS Lookup
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Get detailed registration and geolocation information for an IP address
          </p>
        </div>

        <Input
          placeholder="Enter IP address (e.g., 8.8.8.8)"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-rose-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && lookupWhois()}
        />

        <Button 
          onClick={lookupWhois} 
          disabled={loading || !inputValue.trim()}
          className="bg-rose-600 hover:bg-rose-700 w-full"
        >
          {loading ? 'Looking up...' : 'Lookup WHOIS'}
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-rose-900/30">
            <CardContent className="p-4 space-y-3">
              {result.error ? (
                <p className="text-red-400 text-sm">{result.error}</p>
              ) : (
                <>
                  <div className="p-3 rounded bg-rose-900/10">
                    <p className="text-xs text-gray-500">IP Address</p>
                    <div className="flex items-center justify-between mt-1">
                      <p className="text-rose-400 font-mono text-lg">{result.ip}</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.ip)}
                        className="h-6 px-2"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                      </Button>
                    </div>
                  </div>

                  <div className="grid grid-cols-2 gap-3">
                    <div className="p-3 rounded bg-gray-900/20">
                      <p className="text-xs text-gray-500">Country</p>
                      <p className="text-white text-sm mt-1">{result.country}</p>
                      <p className="text-gray-400 text-xs">{result.countryCode}</p>
                    </div>
                    <div className="p-3 rounded bg-gray-900/20">
                      <p className="text-xs text-gray-500">City</p>
                      <p className="text-white text-sm mt-1">{result.city}</p>
                      <p className="text-gray-400 text-xs">{result.region}</p>
                    </div>
                  </div>

                  <div className="space-y-2">
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">Hostname</span>
                      <span className="text-white text-sm font-mono">{result.hostname}</span>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">ISP / Organization</span>
                      <span className="text-white text-sm">{result.org}</span>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">ASN</span>
                      <span className="text-white text-sm font-mono">{result.asn}</span>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">Timezone</span>
                      <span className="text-white text-sm">{result.timezone}</span>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">Postal Code</span>
                      <span className="text-white text-sm">{result.postal}</span>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">Coordinates</span>
                      <span className="text-white text-sm font-mono">{result.latitude}, {result.longitude}</span>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">Currency</span>
                      <span className="text-white text-sm">{result.currency}</span>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">Languages</span>
                      <span className="text-white text-sm">{result.languages}</span>
                    </div>
                  </div>
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // IP to ASN View
  if (currentView === 'ip-to-asn') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Network className="w-5 h-5 text-slate-400" />
            IP to ASN Lookup
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Find the Autonomous System Number (ASN) and network information for an IP
          </p>
        </div>

        <Input
          placeholder="Enter IP address (e.g., 8.8.8.8)"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-slate-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && lookupAsn()}
        />

        <Button 
          onClick={lookupAsn} 
          disabled={loading || !inputValue.trim()}
          className="bg-slate-600 hover:bg-slate-700 w-full"
        >
          {loading ? 'Looking up...' : 'Lookup ASN'}
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-slate-900/30">
            <CardContent className="p-4 space-y-3">
              {result.error ? (
                <p className="text-red-400 text-sm">{result.error}</p>
              ) : (
                <>
                  <div className="p-3 rounded bg-slate-900/10">
                    <p className="text-xs text-gray-500">IP Address</p>
                    <div className="flex items-center justify-between mt-1">
                      <p className="text-slate-400 font-mono text-lg">{result.ip}</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.ip)}
                        className="h-6 px-2"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                      </Button>
                    </div>
                  </div>

                  <div className="p-4 rounded bg-gradient-to-br from-slate-900/20 to-slate-800/20 border border-slate-700/30">
                    <div className="flex items-center justify-between mb-2">
                      <p className="text-xs text-gray-500">Autonomous System Number</p>
                      <Badge className="bg-slate-500/20 text-slate-300">ASN</Badge>
                    </div>
                    <div className="flex items-center justify-between">
                      <p className="text-slate-300 font-mono text-2xl">{result.asn}</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.asn)}
                        className="h-6 px-2"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                      </Button>
                    </div>
                    <p className="text-gray-400 text-sm mt-2">{result.asnOrg}</p>
                  </div>

                  <div className="space-y-2">
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">Network Range</span>
                      <span className="text-white text-sm font-mono">{result.network}</span>
                    </div>
                    <div className="grid grid-cols-2 gap-2">
                      <div className="p-2 rounded bg-gray-900/20">
                        <p className="text-xs text-gray-500">Network Address</p>
                        <p className="text-white text-sm font-mono mt-1">{result.networkAddress}</p>
                      </div>
                      <div className="p-2 rounded bg-gray-900/20">
                        <p className="text-xs text-gray-500">CIDR</p>
                        <p className="text-white text-sm font-mono mt-1">/{result.cidr}</p>
                      </div>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">ISP</span>
                      <span className="text-white text-sm">{result.isp}</span>
                    </div>
                  </div>

                  <div className="grid grid-cols-2 gap-3">
                    <div className="p-3 rounded bg-gray-900/20">
                      <p className="text-xs text-gray-500">Country</p>
                      <p className="text-white text-sm mt-1">{result.country}</p>
                      <p className="text-gray-400 text-xs">{result.countryCode}</p>
                    </div>
                    <div className="p-3 rounded bg-gray-900/20">
                      <p className="text-xs text-gray-500">Location</p>
                      <p className="text-white text-sm mt-1">{result.city}</p>
                      <p className="text-gray-400 text-xs">{result.region}</p>
                    </div>
                  </div>

                  <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                    <span className="text-xs text-gray-500">Timezone</span>
                    <span className="text-white text-sm">{result.timezone}</span>
                  </div>
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // Traceroute View
  if (currentView === 'traceroute') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={() => { setCurrentView('main'); stopTraceroute(); setTargetHost(''); }}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
          {tracerouteRunning ? (
            <Button onClick={stopTraceroute} variant="destructive" size="sm">
              <Square className="w-4 h-4 mr-2" />
              Stop
            </Button>
          ) : (
            <Button onClick={runTraceroute} className="bg-emerald-600 hover:bg-emerald-700" size="sm">
              <Play className="w-4 h-4 mr-2" />
              Start
            </Button>
          )}
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Route className="w-5 h-5 text-emerald-400" />
            Traceroute
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Display the route and measure transit delays of packets sent from your device towards a target host.
          </p>
        </div>

        <Input
          placeholder="Enter IP or domain"
          value={targetHost}
          onChange={(e) => setTargetHost(e.target.value)}
          className="bg-[#0d120d] border-emerald-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && !tracerouteRunning && runTraceroute()}
        />

        <Button 
          onClick={runTraceroute} 
          disabled={tracerouteRunning || !targetHost.trim()}
          className="bg-emerald-600 hover:bg-emerald-700"
        >
          Traceroute
        </Button>

        <div className="space-y-2">
          <p className="text-sm text-gray-400">Popular targets</p>
          <div className="flex flex-wrap gap-2">
            {POPULAR_TARGETS.map(target => (
              <Badge 
                key={target}
                className="bg-emerald-900/20 text-emerald-400 cursor-pointer hover:bg-emerald-900/40"
                onClick={() => setTargetHost(target)}
              >
                {target}
              </Badge>
            ))}
          </div>
        </div>

        {recentHosts.length > 0 && (
          <div className="space-y-2">
            <div className="flex items-center justify-between">
              <p className="text-sm text-gray-400">Recent hosts</p>
              <Button variant="ghost" size="sm" onClick={clearRecentHosts} className="text-gray-500 hover:text-red-400">
                <Trash2 className="w-4 h-4" />
              </Button>
            </div>
            <div className="space-y-1">
              {recentHosts.slice(0, 5).map((host, i) => (
                <Card 
                  key={i}
                  className="bg-[#0d120d] border-emerald-900/20 cursor-pointer hover:border-emerald-500/30"
                  onClick={() => setTargetHost(host.host)}
                >
                  <CardContent className="p-3 flex items-center gap-3">
                    <Globe className="w-4 h-4 text-gray-500" />
                    <div className="flex-1">
                      <p className="text-sm text-white">{host.host}</p>
                      {host.ip && <p className="text-xs text-gray-500">{host.ip}</p>}
                    </div>
                    <ChevronRight className="w-4 h-4 text-gray-600" />
                  </CardContent>
                </Card>
              ))}
            </div>
          </div>
        )}

        {(tracerouteHops.length > 0 || tracerouteRunning) && (
          <Card className="bg-[#0d120d] border-emerald-900/30">
            <CardHeader className="pb-2">
              <div className="flex items-center justify-between">
                <CardTitle className="text-white text-sm flex items-center gap-2">
                  <Globe className="w-4 h-4 text-emerald-400" />
                  Target host
                </CardTitle>
                <div className="flex items-center gap-2 text-xs text-gray-400">
                  # Hops
                </div>
              </div>
              <div className="flex items-center justify-between text-xs">
                <span className="text-emerald-400">{targetHost}</span>
                <span className="text-white">{tracerouteHops.filter(h => h.status !== 'pending').length}</span>
              </div>
            </CardHeader>
            <CardContent>
              <ScrollArea className="h-[300px]">
                <div className="space-y-2">
                  {tracerouteHops.map((hop, i) => (
                    <div key={i} className="flex items-start gap-3">
                      <div className="flex flex-col items-center">
                        <div className={`w-3 h-3 rounded-full ${
                          hop.status === 'pending' ? 'bg-yellow-500 animate-pulse' :
                          hop.status === 'timeout' ? 'bg-gray-500' : 'bg-emerald-500'
                        }`} />
                        {i < tracerouteHops.length - 1 && (
                          <div className="w-0.5 h-8 bg-gray-700 mt-1" />
                        )}
                      </div>
                      <div className="flex-1 pb-2">
                        <div className="flex items-center justify-between">
                          <p className="text-white font-mono text-sm">
                            {hop.status === 'pending' ? '...' : hop.ip}
                          </p>
                          <Badge className="bg-gray-700 text-gray-300 text-[10px]">
                            Hop #{hop.hop}
                          </Badge>
                        </div>
                        {hop.hostname && (
                          <p className="text-xs text-emerald-400">{hop.hostname}</p>
                        )}
                        {hop.status !== 'pending' && (
                          <p className="text-xs text-gray-500">
                            {hop.status === 'timeout' ? 'Request timed out' : `${hop.time} ms`}
                          </p>
                        )}
                      </div>
                    </div>
                  ))}
                </div>
              </ScrollArea>
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // Ping View
  if (currentView === 'ping') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={() => { setCurrentView('main'); stopPing(); setTargetHost(''); }}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
          {pingRunning ? (
            <Button onClick={stopPing} variant="destructive" size="sm">
              <Square className="w-4 h-4 mr-2" />
              Stop
            </Button>
          ) : (
            <Button onClick={runPing} className="bg-blue-600 hover:bg-blue-700" size="sm">
              <Play className="w-4 h-4 mr-2" />
              Start
            </Button>
          )}
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Activity className="w-5 h-5 text-blue-400" />
            Ping
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Measures the round-trip time for messages sent from your device towards a target host across an IP network.
          </p>
        </div>

        <Input
          placeholder="Enter IP or domain"
          value={targetHost}
          onChange={(e) => setTargetHost(e.target.value)}
          className="bg-[#0d120d] border-blue-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && !pingRunning && runPing()}
        />

        <Button 
          onClick={runPing} 
          disabled={pingRunning || !targetHost.trim()}
          className="bg-blue-600 hover:bg-blue-700"
        >
          Ping
        </Button>

        <div className="space-y-2">
          <p className="text-sm text-gray-400">Popular targets</p>
          <div className="flex flex-wrap gap-2">
            {POPULAR_TARGETS.map(target => (
              <Badge 
                key={target}
                className="bg-blue-900/20 text-blue-400 cursor-pointer hover:bg-blue-900/40"
                onClick={() => setTargetHost(target)}
              >
                {target}
              </Badge>
            ))}
          </div>
        </div>

        {recentHosts.length > 0 && (
          <div className="space-y-2">
            <div className="flex items-center justify-between">
              <p className="text-sm text-gray-400">Recent hosts</p>
              <Button variant="ghost" size="sm" onClick={clearRecentHosts} className="text-gray-500 hover:text-red-400">
                <Trash2 className="w-4 h-4" />
              </Button>
            </div>
            <div className="space-y-1">
              {recentHosts.slice(0, 5).map((host, i) => (
                <Card 
                  key={i}
                  className="bg-[#0d120d] border-blue-900/20 cursor-pointer hover:border-blue-500/30"
                  onClick={() => setTargetHost(host.host)}
                >
                  <CardContent className="p-3 flex items-center gap-3">
                    <Globe className="w-4 h-4 text-gray-500" />
                    <div className="flex-1">
                      <p className="text-sm text-white">{host.host}</p>
                      {host.ip && <p className="text-xs text-gray-500">{host.ip}</p>}
                    </div>
                    <ChevronRight className="w-4 h-4 text-gray-600" />
                  </CardContent>
                </Card>
              ))}
            </div>
          </div>
        )}

        {pingStats && (
          <Card className="bg-[#0d120d] border-blue-900/30">
            <CardHeader className="pb-2">
              <CardTitle className="text-white text-sm flex items-center gap-2">
                <Globe className="w-4 h-4 text-blue-400" />
                Target host: <span className="text-blue-400">{targetHost}</span>
              </CardTitle>
            </CardHeader>
            <CardContent className="space-y-4">
              <div className="space-y-3">
                <div className="flex items-center justify-between p-3 rounded bg-blue-900/10">
                  <div className="flex items-center gap-2">
                    <Activity className="w-4 h-4 text-blue-400" />
                    <span className="text-sm text-gray-300">Average ping</span>
                  </div>
                  <span className="text-white font-mono">{pingStats.avg} ms</span>
                </div>
                
                <div className="flex items-center justify-between p-3 rounded bg-emerald-900/10">
                  <div className="flex items-center gap-2">
                    <Download className="w-4 h-4 text-emerald-400" />
                    <span className="text-sm text-gray-300">Minimum ping</span>
                  </div>
                  <span className="text-white font-mono">{pingStats.min} ms</span>
                </div>
                
                <div className="flex items-center justify-between p-3 rounded bg-orange-900/10">
                  <div className="flex items-center gap-2">
                    <Upload className="w-4 h-4 text-orange-400" />
                    <span className="text-sm text-gray-300">Maximum ping</span>
                  </div>
                  <span className="text-white font-mono">{pingStats.max} ms</span>
                </div>
                
                <div className="flex items-center justify-between p-3 rounded bg-red-900/10">
                  <div className="flex items-center gap-2">
                    <span className="text-red-400">✕</span>
                    <span className="text-sm text-gray-300">Packet loss</span>
                  </div>
                  <span className="text-white font-mono">
                    {pingStats.sent > 0 ? ((pingStats.lost / pingStats.sent) * 100).toFixed(1) : 0} %
                  </span>
                </div>
                
                <div className="flex items-center justify-between p-3 rounded bg-purple-900/10">
                  <div className="flex items-center gap-2">
                    <span className="text-purple-400">σ</span>
                    <span className="text-sm text-gray-300">Std. Dev.</span>
                  </div>
                  <span className="text-white font-mono">{pingStats.stdDev} ms</span>
                </div>
              </div>

              {pingStats.times.length > 1 && (
                <div className="mt-4">
                  <PingGraph times={pingStats.times} />
                </div>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // Port Scanner View
  if (currentView === 'port-scanner') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={() => { setCurrentView('main'); stopPortScan(); setTargetHost(''); }}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
          {portScanRunning && (
            <Button onClick={stopPortScan} variant="destructive" size="sm">
              <Square className="w-4 h-4 mr-2" />
              Stop
            </Button>
          )}
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Server className="w-5 h-5 text-purple-400" />
            Find open ports
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Probe a specific target host to detect open TCP ports to determine available services and assess vulnerabilities.
          </p>
        </div>

        <Input
          placeholder="Enter IP or domain"
          value={targetHost}
          onChange={(e) => setTargetHost(e.target.value)}
          className="bg-[#0d120d] border-purple-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && !portScanRunning && runPortScan()}
        />

        <Button 
          onClick={runPortScan} 
          disabled={portScanRunning || !targetHost.trim()}
          className="bg-purple-600 hover:bg-purple-700"
        >
          Find open ports
        </Button>

        <div className="space-y-2">
          <p className="text-sm text-gray-400">Popular targets</p>
          <div className="flex flex-wrap gap-2">
            {POPULAR_TARGETS.map(target => (
              <Badge 
                key={target}
                className="bg-purple-900/20 text-purple-400 cursor-pointer hover:bg-purple-900/40"
                onClick={() => setTargetHost(target)}
              >
                {target}
              </Badge>
            ))}
          </div>
        </div>

        {recentHosts.length > 0 && (
          <div className="space-y-2">
            <div className="flex items-center justify-between">
              <p className="text-sm text-gray-400">Recent hosts</p>
              <Button variant="ghost" size="sm" onClick={clearRecentHosts} className="text-gray-500 hover:text-red-400">
                <Trash2 className="w-4 h-4" />
              </Button>
            </div>
            <div className="space-y-1">
              {recentHosts.slice(0, 5).map((host, i) => (
                <Card 
                  key={i}
                  className="bg-[#0d120d] border-purple-900/20 cursor-pointer hover:border-purple-500/30"
                  onClick={() => setTargetHost(host.host)}
                >
                  <CardContent className="p-3 flex items-center gap-3">
                    <Globe className="w-4 h-4 text-gray-500" />
                    <div className="flex-1">
                      <p className="text-sm text-white">{host.host}</p>
                      {host.ip && <p className="text-xs text-gray-500">{host.ip}</p>}
                    </div>
                    <ChevronRight className="w-4 h-4 text-gray-600" />
                  </CardContent>
                </Card>
              ))}
            </div>
          </div>
        )}

        {(portResults.length > 0 || portScanRunning) && (
          <Card className="bg-[#0d120d] border-purple-900/30">
            <CardHeader className="pb-2">
              <div className="flex items-center justify-between">
                <CardTitle className="text-white text-sm flex items-center gap-2">
                  <Globe className="w-4 h-4 text-purple-400" />
                  Target host
                </CardTitle>
                <div className="flex items-center gap-2 text-xs text-gray-400">
                  <Server className="w-3 h-3" />
                  Open ports
                </div>
              </div>
              <div className="flex items-center justify-between text-xs">
                <span className="text-purple-400">{targetHost}</span>
                <span className="text-white">{openPortsCount}</span>
              </div>
            </CardHeader>
            <CardContent>
              {portScanRunning && portResults.length === 0 && (
                <div className="text-center py-4">
                  <div className="animate-spin w-6 h-6 border-2 border-purple-500 border-t-transparent rounded-full mx-auto mb-2" />
                  <p className="text-sm text-gray-400">Scanning ports...</p>
                </div>
              )}
              
              <div className="space-y-2">
                {portResults.map((port, i) => (
                  <div key={i} className="flex items-center gap-4 p-3 rounded bg-purple-900/10 border-l-4 border-blue-500">
                    <div className="w-16 text-center">
                      <p className="text-2xl font-bold text-blue-400">{port.port}</p>
                    </div>
                    <div className="flex-1">
                      <p className="text-white font-medium">{port.service}</p>
                      <p className="text-xs text-gray-500">{port.description}</p>
                    </div>
                  </div>
                ))}
              </div>
              
              {!portScanRunning && portResults.length === 0 && (
                <p className="text-center text-gray-500 py-4">No open ports found</p>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // Subnet Calculator View
  if (currentView === 'subnet-calculator') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Network className="w-5 h-5 text-emerald-400" />
            Subnet Calculator
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Calculate subnet information from CIDR notation
          </p>
        </div>

        <Input
          placeholder="Enter CIDR (e.g., 192.168.1.0/24)"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-emerald-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && calculateSubnet()}
        />

        <Button 
          onClick={calculateSubnet} 
          disabled={!inputValue.trim()}
          className="bg-emerald-600 hover:bg-emerald-700 w-full"
        >
          Calculate Subnet
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-emerald-900/30">
            <CardContent className="p-4 space-y-3">
              {result.error ? (
                <p className="text-red-400 text-sm">{result.error}</p>
              ) : (
                <>
                  <div className="grid grid-cols-2 gap-3">
                    <div className="p-3 rounded bg-emerald-900/10">
                      <p className="text-xs text-gray-500">IP Class</p>
                      <p className="text-white font-mono text-lg">{result.ipClass}</p>
                    </div>
                    <div className="p-3 rounded bg-emerald-900/10">
                      <p className="text-xs text-gray-500">Type</p>
                      <p className="text-white font-mono text-lg">{result.isPrivate ? 'Private' : 'Public'}</p>
                    </div>
                  </div>

                  <div className="space-y-2">
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">Network Address</span>
                      <span className="text-emerald-400 font-mono text-sm">{result.networkAddress}/{result.prefix}</span>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">Broadcast Address</span>
                      <span className="text-emerald-400 font-mono text-sm">{result.broadcastAddress}</span>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">Subnet Mask</span>
                      <span className="text-white font-mono text-sm">{result.subnetMask}</span>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">Wildcard Mask</span>
                      <span className="text-white font-mono text-sm">{result.wildcardMask}</span>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">First Usable IP</span>
                      <span className="text-white font-mono text-sm">{result.firstUsable}</span>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">Last Usable IP</span>
                      <span className="text-white font-mono text-sm">{result.lastUsable}</span>
                    </div>
                  </div>

                  <div className="grid grid-cols-2 gap-3">
                    <div className="p-3 rounded bg-blue-900/10">
                      <p className="text-xs text-gray-500">Total Hosts</p>
                      <p className="text-blue-400 font-mono text-xl">{result.totalHosts.toLocaleString()}</p>
                    </div>
                    <div className="p-3 rounded bg-green-900/10">
                      <p className="text-xs text-gray-500">Usable Hosts</p>
                      <p className="text-green-400 font-mono text-xl">{result.usableHosts.toLocaleString()}</p>
                    </div>
                  </div>
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // Reverse IP Lookup View
  if (currentView === 'reverse-ip-lookup') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Globe className="w-5 h-5 text-pink-400" />
            Reverse IP Lookup
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Find all domains hosted on an IP address
          </p>
        </div>

        <Input
          placeholder="Enter IP address (e.g., 8.8.8.8)"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-pink-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && reverseIpLookup()}
        />

        <Button 
          onClick={reverseIpLookup} 
          disabled={loading || !inputValue.trim()}
          className="bg-pink-600 hover:bg-pink-700 w-full"
        >
          {loading ? 'Looking up...' : 'Find Domains'}
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-pink-900/30">
            <CardContent className="p-4 space-y-3">
              {result.error ? (
                <p className="text-red-400 text-sm">{result.error}</p>
              ) : (
                <>
                  <div className="flex items-center justify-between p-3 rounded bg-pink-900/10">
                    <span className="text-sm text-gray-300">Domains Found</span>
                    <span className="text-pink-400 font-mono text-lg">{result.count}</span>
                  </div>
                  <div>
                    <div className="flex items-center justify-between mb-2">
                      <p className="text-xs text-gray-500">Domain Names</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.domains.join('\n'))}
                        className="h-6 px-2 text-xs"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />} Copy All
                      </Button>
                    </div>
                    <ScrollArea className="h-[300px] rounded border border-pink-900/30 p-2">
                      <div className="space-y-1">
                        {result.domains.map((domain: string, i: number) => (
                          <div key={i} className="text-pink-400 font-mono text-xs p-1 hover:bg-pink-900/10 rounded">
                            {domain}
                          </div>
                        ))}
                      </div>
                    </ScrollArea>
                  </div>
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // IP Geolocation View
  if (currentView === 'ip-geolocation') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Globe className="w-5 h-5 text-teal-400" />
            IP Geolocation
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Get detailed geographic location information for an IP address
          </p>
        </div>

        <Input
          placeholder="Enter IP address (e.g., 8.8.8.8)"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-teal-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && lookupGeolocation()}
        />

        <Button 
          onClick={lookupGeolocation} 
          disabled={loading || !inputValue.trim()}
          className="bg-teal-600 hover:bg-teal-700 w-full"
        >
          {loading ? 'Looking up...' : 'Lookup Location'}
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-teal-900/30">
            <CardContent className="p-4 space-y-3">
              {result.error ? (
                <p className="text-red-400 text-sm">{result.error}</p>
              ) : (
                <>
                  <div className="p-3 rounded bg-teal-900/10">
                    <p className="text-xs text-gray-500">IP Address</p>
                    <p className="text-teal-400 font-mono text-lg">{result.ip}</p>
                  </div>

                  {result.flag && (
                    <div className="flex items-center justify-center p-3 rounded bg-gray-900/20">
                      <img src={result.flag} alt={result.country} className="h-12" />
                    </div>
                  )}

                  <div className="grid grid-cols-2 gap-3">
                    <div className="p-3 rounded bg-gray-900/20">
                      <p className="text-xs text-gray-500">Country</p>
                      <p className="text-white text-sm mt-1">{result.country}</p>
                      <p className="text-gray-400 text-xs">{result.countryCode}</p>
                    </div>
                    <div className="p-3 rounded bg-gray-900/20">
                      <p className="text-xs text-gray-500">City</p>
                      <p className="text-white text-sm mt-1">{result.city}</p>
                      <p className="text-gray-400 text-xs">{result.region}</p>
                    </div>
                  </div>

                  <div className="space-y-2">
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">Coordinates</span>
                      <span className="text-white text-sm font-mono">{result.latitude}, {result.longitude}</span>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">Timezone</span>
                      <span className="text-white text-sm">{result.timezone} ({result.utcOffset})</span>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">Postal Code</span>
                      <span className="text-white text-sm">{result.postal}</span>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">Organization</span>
                      <span className="text-white text-sm">{result.org}</span>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">ASN</span>
                      <span className="text-white text-sm font-mono">{result.asn}</span>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">Currency</span>
                      <span className="text-white text-sm">{result.currency}</span>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">Languages</span>
                      <span className="text-white text-sm">{result.languages}</span>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">Calling Code</span>
                      <span className="text-white text-sm">{result.callingCode}</span>
                    </div>
                  </div>

                  <div className="p-3 rounded bg-blue-900/10 border border-blue-900/30">
                    <p className="text-xs text-blue-300 mb-1">Map View</p>
                    <a 
                      href={`https://www.google.com/maps?q=${result.latitude},${result.longitude}`}
                      target="_blank"
                      rel="noopener noreferrer"
                      className="text-blue-400 text-sm hover:underline"
                    >
                      View on Google Maps →
                    </a>
                  </div>
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // IP Blacklist Checker View
  if (currentView === 'ip-blacklist') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Shield className="w-5 h-5 text-red-400" />
            IP Blacklist Checker
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Check if an IP address is listed on DNS-based blacklists (DNSBL)
          </p>
        </div>

        <Input
          placeholder="Enter IP address (e.g., 8.8.8.8)"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-red-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && checkBlacklist()}
        />

        <Button 
          onClick={checkBlacklist} 
          disabled={loading || !inputValue.trim()}
          className="bg-red-600 hover:bg-red-700 w-full"
        >
          {loading ? 'Checking...' : 'Check Blacklist'}
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-red-900/30">
            <CardContent className="p-4 space-y-3">
              {result.error ? (
                <p className="text-red-400 text-sm">{result.error}</p>
              ) : (
                <>
                  <div className="p-3 rounded bg-red-900/10">
                    <p className="text-xs text-gray-500">IP Address</p>
                    <p className="text-red-400 font-mono text-lg">{result.ip}</p>
                  </div>

                  <div className={`p-4 rounded border ${
                    result.isBlacklisted 
                      ? 'bg-red-900/20 border-red-900/30' 
                      : 'bg-green-900/20 border-green-900/30'
                  }`}>
                    <p className="text-sm font-medium mb-2">
                      {result.isBlacklisted ? '⚠️ IP is Blacklisted' : '✓ IP is Clean'}
                    </p>
                    <p className="text-xs text-gray-400">
                      {result.isBlacklisted 
                        ? `Found on ${result.blacklistedCount} blacklist(s)` 
                        : 'Not found on any major blacklists'}
                    </p>
                  </div>

                  {result.blacklists && result.blacklists.length > 0 && (
                    <div className="space-y-2">
                      <p className="text-xs text-gray-500 font-medium">Blacklist Results:</p>
                      <div className="max-h-60 overflow-y-auto rounded border border-gray-700 bg-black/30 p-2">
                        {result.blacklists.map((bl: any, i: number) => (
                          <div key={i} className={`p-2 rounded mb-2 ${
                            bl.listed ? 'bg-red-900/20' : 'bg-green-900/10'
                          }`}>
                            <div className="flex items-center justify-between">
                              <span className="text-xs text-white font-mono">{bl.name}</span>
                              <span className={`text-xs ${bl.listed ? 'text-red-400' : 'text-green-400'}`}>
                                {bl.listed ? 'Listed' : 'Clean'}
                              </span>
                            </div>
                            {bl.reason && (
                              <p className="text-xs text-gray-400 mt-1">{bl.reason}</p>
                            )}
                          </div>
                        ))}
                      </div>
                    </div>
                  )}

                  <div className="p-3 rounded bg-blue-900/10 border border-blue-900/30">
                    <p className="text-xs text-blue-300 mb-1">About Blacklists</p>
                    <p className="text-xs text-gray-400">
                      DNS-based blacklists (DNSBLs) are used to identify IP addresses associated with spam, malware, or other malicious activities.
                    </p>
                  </div>
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // Proxy Check View
  if (currentView === 'proxy-check') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Server className="w-5 h-5 text-purple-400" />
            Proxy Check
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Detect if an IP address is a proxy, VPN, or Tor exit node
          </p>
        </div>

        <Input
          placeholder="Enter IP address (e.g., 8.8.8.8)"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-purple-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && checkProxy()}
        />

        <Button 
          onClick={checkProxy} 
          disabled={loading || !inputValue.trim()}
          className="bg-purple-600 hover:bg-purple-700 w-full"
        >
          {loading ? 'Checking...' : 'Check Proxy'}
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-purple-900/30">
            <CardContent className="p-4 space-y-3">
              {result.error ? (
                <p className="text-red-400 text-sm">{result.error}</p>
              ) : (
                <>
                  <div className="p-3 rounded bg-purple-900/10">
                    <p className="text-xs text-gray-500">IP Address</p>
                    <p className="text-purple-400 font-mono text-lg">{result.ip}</p>
                  </div>

                  <div className={`p-4 rounded border ${
                    result.isProxy 
                      ? 'bg-orange-900/20 border-orange-900/30' 
                      : 'bg-green-900/20 border-green-900/30'
                  }`}>
                    <p className="text-sm font-medium mb-2">
                      {result.isProxy ? '⚠️ Proxy/VPN Detected' : '✓ Direct Connection'}
                    </p>
                    <p className="text-xs text-gray-400">
                      {result.isProxy 
                        ? 'This IP appears to be using a proxy or VPN service' 
                        : 'This IP appears to be a direct connection'}
                    </p>
                  </div>

                  <div className="grid grid-cols-2 gap-3">
                    <div className="p-3 rounded bg-gray-900/20">
                      <p className="text-xs text-gray-500">Proxy Type</p>
                      <p className="text-white text-sm mt-1">{result.proxyType || 'None'}</p>
                    </div>
                    <div className="p-3 rounded bg-gray-900/20">
                      <p className="text-xs text-gray-500">Risk Score</p>
                      <p className={`text-sm mt-1 font-medium ${
                        result.riskScore > 70 ? 'text-red-400' : 
                        result.riskScore > 40 ? 'text-orange-400' : 'text-green-400'
                      }`}>
                        {result.riskScore}%
                      </p>
                    </div>
                  </div>

                  <div className="space-y-2">
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">VPN</span>
                      <span className={`text-sm ${result.isVPN ? 'text-orange-400' : 'text-green-400'}`}>
                        {result.isVPN ? 'Yes' : 'No'}
                      </span>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">Tor Exit Node</span>
                      <span className={`text-sm ${result.isTor ? 'text-orange-400' : 'text-green-400'}`}>
                        {result.isTor ? 'Yes' : 'No'}
                      </span>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">Hosting Provider</span>
                      <span className={`text-sm ${result.isHosting ? 'text-orange-400' : 'text-green-400'}`}>
                        {result.isHosting ? 'Yes' : 'No'}
                      </span>
                    </div>
                    <div className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                      <span className="text-xs text-gray-500">Public Proxy</span>
                      <span className={`text-sm ${result.isPublicProxy ? 'text-orange-400' : 'text-green-400'}`}>
                        {result.isPublicProxy ? 'Yes' : 'No'}
                      </span>
                    </div>
                  </div>

                  {result.provider && (
                    <div className="p-3 rounded bg-gray-900/20">
                      <p className="text-xs text-gray-500">Provider</p>
                      <p className="text-white text-sm mt-1">{result.provider}</p>
                    </div>
                  )}

                  <div className="p-3 rounded bg-blue-900/10 border border-blue-900/30">
                    <p className="text-xs text-blue-300 mb-1">About Proxy Detection</p>
                    <p className="text-xs text-gray-400">
                      This tool detects various types of proxies including VPNs, Tor nodes, hosting providers, and public proxies.
                    </p>
                  </div>
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // Bulk IP Lookup View
  if (currentView === 'bulk-ip-lookup') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Network className="w-5 h-5 text-orange-400" />
            Bulk IP Lookup
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Lookup information for multiple IP addresses at once (max 10)
          </p>
        </div>

        <Textarea
          placeholder="Enter IP addresses (one per line)&#10;8.8.8.8&#10;1.1.1.1&#10;208.67.222.222"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-orange-900/30 text-white min-h-[120px]"
        />

        <Button 
          onClick={bulkIpLookup} 
          disabled={loading || !inputValue.trim()}
          className="bg-orange-600 hover:bg-orange-700 w-full"
        >
          {loading ? 'Looking up...' : 'Lookup All IPs'}
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-orange-900/30">
            <CardContent className="p-4 space-y-3">
              {result.error ? (
                <p className="text-red-400 text-sm">{result.error}</p>
              ) : (
                <>
                  <div className="grid grid-cols-3 gap-3">
                    <div className="p-3 rounded bg-orange-900/10 text-center">
                      <p className="text-xs text-gray-500">Total</p>
                      <p className="text-orange-400 font-mono text-xl">{result.total}</p>
                    </div>
                    <div className="p-3 rounded bg-green-900/10 text-center">
                      <p className="text-xs text-gray-500">Success</p>
                      <p className="text-green-400 font-mono text-xl">{result.successful}</p>
                    </div>
                    <div className="p-3 rounded bg-red-900/10 text-center">
                      <p className="text-xs text-gray-500">Failed</p>
                      <p className="text-red-400 font-mono text-xl">{result.failed}</p>
                    </div>
                  </div>

                  <div>
                    <p className="text-xs text-gray-500 mb-2">Results</p>
                    <ScrollArea className="h-[300px] rounded border border-orange-900/30 p-2">
                      <div className="space-y-2">
                        {result.results.map((item: any, i: number) => (
                          <Card key={i} className={`${item.status === 'success' ? 'bg-green-900/10 border-green-900/30' : 'bg-red-900/10 border-red-900/30'}`}>
                            <CardContent className="p-3 space-y-1">
                              <div className="flex items-center justify-between">
                                <p className="text-white font-mono text-sm">{item.ip}</p>
                                <Badge className={item.status === 'success' ? 'bg-green-500/20 text-green-400' : 'bg-red-500/20 text-red-400'}>
                                  {item.status}
                                </Badge>
                              </div>
                              {item.status === 'success' ? (
                                <div className="text-xs space-y-1">
                                  <div className="flex items-center gap-2">
                                    <span className="text-gray-500">Location:</span>
                                    <span className="text-gray-300">{item.city}, {item.country}</span>
                                  </div>
                                  <div className="flex items-center gap-2">
                                    <span className="text-gray-500">Org:</span>
                                    <span className="text-gray-300">{item.org}</span>
                                  </div>
                                  <div className="flex items-center gap-2">
                                    <span className="text-gray-500">ASN:</span>
                                    <span className="text-gray-300">{item.asn}</span>
                                  </div>
                                </div>
                              ) : (
                                <p className="text-xs text-red-400">{item.error}</p>
                              )}
                            </CardContent>
                          </Card>
                        ))}
                      </div>
                    </ScrollArea>
                  </div>
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // IP Blacklist Check View
  if (currentView === 'ip-blacklist-check') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Shield className="w-5 h-5 text-red-400" />
            IP Blacklist Check
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Check if an IP address is listed on spam/malware blacklists
          </p>
        </div>

        <Input
          placeholder="Enter IP address (e.g., 8.8.8.8)"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-red-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && checkBlacklist()}
        />

        <Button 
          onClick={checkBlacklist} 
          disabled={loading || !inputValue.trim()}
          className="bg-red-600 hover:bg-red-700 w-full"
        >
          {loading ? 'Checking...' : 'Check Blacklists'}
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-red-900/30">
            <CardContent className="p-4 space-y-3">
              {result.error ? (
                <p className="text-red-400 text-sm">{result.error}</p>
              ) : (
                <>
                  <div className="p-4 rounded bg-gradient-to-br from-gray-900/50 to-gray-800/50 border border-gray-700/30">
                    <div className="flex items-center justify-between mb-2">
                      <p className="text-xs text-gray-500">Overall Status</p>
                      <Badge className={
                        result.overallStatus === 'Clean' ? 'bg-green-500/20 text-green-400' :
                        result.overallStatus === 'Warning' ? 'bg-yellow-500/20 text-yellow-400' :
                        'bg-red-500/20 text-red-400'
                      }>
                        {result.overallStatus}
                      </Badge>
                    </div>
                    <p className="text-white font-mono text-2xl">{result.ip}</p>
                  </div>

                  <div className="grid grid-cols-3 gap-3">
                    <div className="p-3 rounded bg-blue-900/10 text-center">
                      <p className="text-xs text-gray-500">Checked</p>
                      <p className="text-blue-400 font-mono text-xl">{result.checked}</p>
                    </div>
                    <div className="p-3 rounded bg-red-900/10 text-center">
                      <p className="text-xs text-gray-500">Listed</p>
                      <p className="text-red-400 font-mono text-xl">{result.listed}</p>
                    </div>
                    <div className="p-3 rounded bg-green-900/10 text-center">
                      <p className="text-xs text-gray-500">Clean</p>
                      <p className="text-green-400 font-mono text-xl">{result.clean}</p>
                    </div>
                  </div>

                  <div>
                    <p className="text-xs text-gray-500 mb-2">Blacklist Results</p>
                    <div className="space-y-2">
                      {result.results.map((bl: any, i: number) => (
                        <div key={i} className={`flex items-center justify-between p-3 rounded ${bl.listed ? 'bg-red-900/10 border border-red-900/30' : 'bg-green-900/10 border border-green-900/30'}`}>
                          <span className="text-sm text-white">{bl.name}</span>
                          <Badge className={bl.listed ? 'bg-red-500/20 text-red-400' : 'bg-green-500/20 text-green-400'}>
                            {bl.status}
                          </Badge>
                        </div>
                      ))}
                    </div>
                  </div>

                  {result.note && (
                    <div className="p-3 rounded bg-yellow-900/10 border border-yellow-900/30">
                      <p className="text-xs text-yellow-400">{result.note}</p>
                    </div>
                  )}
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // IP Tracker View
  if (currentView === 'ip-tracker') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <MapPin className="w-5 h-5 text-cyan-400" />
            IP Tracker
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Track any IP address and get comprehensive location and network information
          </p>
          <div className="mt-2 p-3 rounded bg-cyan-900/10 border border-cyan-900/30">
            <p className="text-xs text-cyan-300 font-medium mb-1">Supports both IPv4 and IPv6</p>
            <p className="text-xs text-gray-400">Enter any IP address to get real-time geolocation data from multiple providers for accurate results.</p>
          </div>
        </div>

        <Input
          placeholder="Enter IP address (e.g., 8.8.8.8 or 2001:4860:4860::8888)"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-cyan-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && trackIp()}
        />

        <Button 
          onClick={trackIp} 
          disabled={loading || !inputValue.trim()}
          className="bg-cyan-600 hover:bg-cyan-700 w-full"
        >
          {loading ? (
            <span className="flex items-center gap-2">
              <RefreshCw className="w-4 h-4 animate-spin" />
              Tracking IP...
            </span>
          ) : (
            <span className="flex items-center gap-2">
              <MapPin className="w-4 h-4" />
              Track IP Address
            </span>
          )}
        </Button>

        {result && (
          <div className="space-y-3">
            {result.error ? (
              <Card className="bg-[#0d120d] border-red-900/30">
                <CardContent className="p-4">
                  <p className="text-red-400 text-sm">{result.error}</p>
                </CardContent>
              </Card>
            ) : (
              <>
                {/* Main IP Info Card */}
                <Card className="bg-gradient-to-br from-cyan-900/20 to-blue-900/20 border-cyan-500/30">
                  <CardHeader className="pb-3">
                    <CardTitle className="text-lg flex items-center justify-between">
                      <span className="text-cyan-400">IP Address Information</span>
                      <Badge className="bg-cyan-500/20 text-cyan-400">
                        {result.apiCount} {result.apiCount === 1 ? 'Source' : 'Sources'}
                      </Badge>
                    </CardTitle>
                  </CardHeader>
                  <CardContent className="space-y-3">
                    <div className="flex items-center justify-between p-3 rounded bg-cyan-900/20">
                      <div>
                        <p className="text-xs text-gray-500">IP Address</p>
                        <p className="text-white font-mono text-lg mt-1">{result.ip}</p>
                      </div>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.ip)}
                        className="h-8 px-3"
                      >
                        {copied ? <Check className="w-4 h-4" /> : <Copy className="w-4 h-4" />}
                      </Button>
                    </div>

                    {result.hostname && result.hostname !== 'N/A' && (
                      <div className="p-3 rounded bg-blue-900/10">
                        <p className="text-xs text-gray-500">Hostname</p>
                        <p className="text-blue-400 font-mono text-sm mt-1">{result.hostname}</p>
                      </div>
                    )}
                  </CardContent>
                </Card>

                {/* Location Card */}
                <Card className="bg-[#0d120d] border-green-900/30">
                  <CardHeader className="pb-3">
                    <CardTitle className="text-base flex items-center gap-2">
                      <MapPin className="w-4 h-4 text-green-400" />
                      <span className="text-green-400">Geographic Location</span>
                    </CardTitle>
                  </CardHeader>
                  <CardContent className="space-y-2">
                    {result.flag && (
                      <div className="flex items-center gap-3 p-3 rounded bg-green-900/10">
                        <img src={result.flag} alt={result.countryCode} className="w-12 h-9 rounded border border-gray-700" />
                        <div>
                          <p className="text-white font-medium">{result.country}</p>
                          <p className="text-xs text-gray-500">{result.countryCode}</p>
                        </div>
                      </div>
                    )}

                    <div className="grid grid-cols-2 gap-2">
                      <div className="p-2 rounded bg-gray-900/30">
                        <p className="text-xs text-gray-500">City</p>
                        <p className="text-white text-sm mt-0.5">{result.city}</p>
                      </div>
                      <div className="p-2 rounded bg-gray-900/30">
                        <p className="text-xs text-gray-500">Region</p>
                        <p className="text-white text-sm mt-0.5">{result.region}</p>
                      </div>
                      <div className="p-2 rounded bg-gray-900/30">
                        <p className="text-xs text-gray-500">Postal Code</p>
                        <p className="text-white text-sm mt-0.5">{result.postal}</p>
                      </div>
                      <div className="p-2 rounded bg-gray-900/30">
                        <p className="text-xs text-gray-500">Continent</p>
                        <p className="text-white text-sm mt-0.5">{result.continent}</p>
                      </div>
                    </div>

                    <div className="grid grid-cols-2 gap-2">
                      <div className="p-2 rounded bg-gray-900/30">
                        <p className="text-xs text-gray-500">Latitude</p>
                        <p className="text-green-400 font-mono text-sm mt-0.5">{result.latitude}</p>
                      </div>
                      <div className="p-2 rounded bg-gray-900/30">
                        <p className="text-xs text-gray-500">Longitude</p>
                        <p className="text-green-400 font-mono text-sm mt-0.5">{result.longitude}</p>
                      </div>
                    </div>

                    {result.latitude !== 'N/A' && result.longitude !== 'N/A' && (
                      <Button
                        variant="outline"
                        size="sm"
                        className="w-full mt-2"
                        onClick={() => window.open(`https://www.google.com/maps?q=${result.latitude},${result.longitude}`, '_blank')}
                      >
                        <MapPin className="w-3 h-3 mr-2" />
                        View on Map
                      </Button>
                    )}
                  </CardContent>
                </Card>

                {/* Network Information Card */}
                <Card className="bg-[#0d120d] border-purple-900/30">
                  <CardHeader className="pb-3">
                    <CardTitle className="text-base flex items-center gap-2">
                      <Network className="w-4 h-4 text-purple-400" />
                      <span className="text-purple-400">Network Information</span>
                    </CardTitle>
                  </CardHeader>
                  <CardContent className="space-y-2">
                    <div className="p-3 rounded bg-purple-900/10">
                      <p className="text-xs text-gray-500">ISP / Organization</p>
                      <p className="text-white text-sm mt-1">{result.isp}</p>
                    </div>

                    {result.org !== result.isp && result.org !== 'N/A' && (
                      <div className="p-3 rounded bg-purple-900/10">
                        <p className="text-xs text-gray-500">Organization</p>
                        <p className="text-white text-sm mt-1">{result.org}</p>
                      </div>
                    )}

                    <div className="p-3 rounded bg-purple-900/10">
                      <p className="text-xs text-gray-500">ASN (Autonomous System Number)</p>
                      <p className="text-purple-400 font-mono text-sm mt-1">{result.asn}</p>
                    </div>
                  </CardContent>
                </Card>

                {/* Additional Information Card */}
                <Card className="bg-[#0d120d] border-yellow-900/30">
                  <CardHeader className="pb-3">
                    <CardTitle className="text-base flex items-center gap-2">
                      <Globe className="w-4 h-4 text-yellow-400" />
                      <span className="text-yellow-400">Additional Information</span>
                    </CardTitle>
                  </CardHeader>
                  <CardContent className="space-y-2">
                    <div className="grid grid-cols-2 gap-2">
                      <div className="p-2 rounded bg-gray-900/30">
                        <p className="text-xs text-gray-500">Timezone</p>
                        <p className="text-white text-sm mt-0.5">{result.timezone}</p>
                      </div>
                      <div className="p-2 rounded bg-gray-900/30">
                        <p className="text-xs text-gray-500">UTC Offset</p>
                        <p className="text-white text-sm mt-0.5">{result.utcOffset || 'N/A'}</p>
                      </div>
                      <div className="p-2 rounded bg-gray-900/30">
                        <p className="text-xs text-gray-500">Currency</p>
                        <p className="text-white text-sm mt-0.5">{result.currency}</p>
                      </div>
                      <div className="p-2 rounded bg-gray-900/30">
                        <p className="text-xs text-gray-500">Calling Code</p>
                        <p className="text-white text-sm mt-0.5">{result.callingCode}</p>
                      </div>
                    </div>

                    {result.languages && result.languages !== 'N/A' && (
                      <div className="p-2 rounded bg-gray-900/30">
                        <p className="text-xs text-gray-500">Languages</p>
                        <p className="text-white text-sm mt-0.5">{result.languages}</p>
                      </div>
                    )}
                  </CardContent>
                </Card>

                {/* Data Sources Info */}
                <Card className="bg-[#0d120d] border-gray-700/30">
                  <CardContent className="p-3">
                    <p className="text-xs text-gray-500 mb-2">Data aggregated from {result.apiCount} geolocation {result.apiCount === 1 ? 'provider' : 'providers'}:</p>
                    <div className="flex flex-wrap gap-2">
                      {result.providers.map((provider: string, i: number) => (
                        <Badge key={i} variant="outline" className="text-xs">
                          {provider}
                        </Badge>
                      ))}
                    </div>
                  </CardContent>
                </Card>
              </>
            )}
          </div>
        )}
      </div>
    )
  }

  return null
}

                          </Badge>
                        </div>
                      ))}
                    </div>
                  </div>
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // MAC Address Lookup View
  if (currentView === 'mac-address-lookup') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Network className="w-5 h-5 text-fuchsia-400" />
            MAC Address Lookup
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Comprehensive MAC address analysis with vendor lookup and properties
          </p>
        </div>

        <Input
          placeholder="Enter MAC address (e.g., 00:1B:44:11:3A:B7)"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-fuchsia-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && lookupMacAddress()}
        />

        <Button 
          onClick={lookupMacAddress} 
          disabled={loading || !inputValue.trim()}
          className="bg-fuchsia-600 hover:bg-fuchsia-700 w-full"
        >
          {loading ? 'Analyzing...' : 'Analyze MAC Address'}
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-fuchsia-900/30">
            <CardContent className="p-4 space-y-4">
              {result.error ? (
                <div>
                  <p className="text-red-400 text-sm">{result.error}</p>
                  {result.note && <p className="text-xs text-gray-500 mt-2">{result.note}</p>}
                </div>
              ) : (
                <>
                  <div>
                    <p className="text-xs text-gray-500">MAC Address</p>
                    <div className="flex items-center justify-between mt-1">
                      <p className="text-white font-mono">{result.mac}</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.mac)}
                        className="h-6 px-2"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                      </Button>
                    </div>
                  </div>

                  <div>
                    <p className="text-xs text-gray-500">OUI (Organizationally Unique Identifier)</p>
                    <p className="text-fuchsia-400 font-mono mt-1">{result.oui}</p>
                  </div>

                  <div>
                    <p className="text-xs text-gray-500">Vendor</p>
                    <p className="text-white mt-1">{result.vendor}</p>
                    {result.companyInfo && (
                      <div className="mt-2 space-y-1">
                        <div className="flex items-center gap-2">
                          <span className="text-gray-500">Country:</span>
                          <span className="text-gray-300">{result.companyInfo.country}</span>
                        </div>
                        <div className="flex items-center gap-2">
                          <span className="text-gray-500">Type:</span>
                          <span className="text-gray-300">{result.companyInfo.type}</span>
                        </div>
                      </div>
                    )}
                  </div>

                  {result.properties && (
                    <div>
                      <p className="text-xs text-gray-500 mb-2">Address Properties</p>
                      <div className="grid grid-cols-2 gap-3">
                        <div className="p-3 rounded bg-gray-900/20">
                          <p className="text-xs text-gray-500">Type</p>
                          <p className="text-white text-sm">{result.properties.addressType}</p>
                        </div>
                        <div className="p-3 rounded bg-gray-900/20">
                          <p className="text-xs text-gray-500">Scope</p>
                          <p className="text-white text-sm">{result.properties.scope}</p>
                        </div>
                        <div className="p-3 rounded bg-gray-900/20">
                          <p className="text-xs text-gray-500">Local</p>
                          <p className={`text-sm ${result.properties.isLocal ? 'text-yellow-400' : 'text-green-400'}`}>
                            {result.properties.isLocal ? 'Yes' : 'No'}
                          </p>
                        </div>
                        <div className="p-3 rounded bg-gray-900/20">
                          <p className="text-xs text-gray-500">Randomized</p>
                          <p className={`text-sm ${result.properties.isRandomized ? 'text-yellow-400' : 'text-green-400'}`}>
                            {result.properties.isRandomized ? 'Likely' : 'No'}
                          </p>
                        </div>
                      </div>
                    </div>
                  )}

                  {result.variations && (
                    <div>
                      <p className="text-xs text-gray-500 mb-2">Format Variations</p>
                      <div className="space-y-2">
                        {result.variations.map((variation: string, i: number) => (
                          <div key={i} className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                            <span className="text-white font-mono text-sm">{variation}</span>
                            <Button
                              variant="ghost"
                              size="sm"
                              onClick={() => copyToClipboard(variation)}
                              className="h-6 px-2"
                            >
                              <Copy className="w-3 h-3" />
                            </Button>
                          </div>
                        ))}
                      </div>
                    </div>
                  )}

                  {result.analysis && (
                    <div>
                      <p className="text-xs text-gray-500 mb-2">Technical Analysis</p>
                      <div className="grid grid-cols-2 gap-3">
                        <div className="p-3 rounded bg-gray-900/20">
                          <p className="text-xs text-gray-500">Format</p>
                          <p className="text-white text-sm">{result.analysis.format}</p>
                        </div>
                        <div className="p-3 rounded bg-gray-900/20">
                          <p className="text-xs text-gray-500">Length</p>
                          <p className="text-white text-sm">{result.analysis.bits} bits ({result.analysis.bytes} bytes)</p>
                        </div>
                      </div>
                    </div>
                  )}
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // IP Calculator View
  if (currentView === 'ip-calculator') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Activity className="w-5 h-5 text-emerald-400" />
            IP Calculator
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Calculate subnet information, convert IP formats, and analyze IP addresses
          </p>
        </div>

        <Input
          placeholder="Enter IP/CIDR (192.168.1.0/24), IP (192.168.1.1), or decimal (3232235777)"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-emerald-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && calculateIpAddress()}
        />

        <Button 
          onClick={calculateIpAddress} 
          disabled={!inputValue.trim()}
          className="bg-emerald-600 hover:bg-emerald-700 w-full"
        >
          Calculate
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-emerald-900/30">
            <CardContent className="p-4 space-y-4">
              {result.error ? (
                <p className="text-red-400 text-sm">{result.error}</p>
              ) : (
                <>
                  <div>
                    <p className="text-xs text-gray-500">Input Type</p>
                    <p className="text-emerald-400 mt-1">{result.inputType}</p>
                  </div>

                  {result.inputType === 'CIDR' && (
                    <>
                      <div className="grid grid-cols-2 gap-4">
                        <div>
                          <p className="text-xs text-gray-500">Network Address</p>
                          <div className="flex items-center justify-between mt-1">
                            <p className="text-white font-mono">{result.networkAddress}</p>
                            <Button
                              variant="ghost"
                              size="sm"
                              onClick={() => copyToClipboard(result.networkAddress)}
                              className="h-6 px-2"
                            >
                              <Copy className="w-3 h-3" />
                            </Button>
                          </div>
                        </div>
                        <div>
                          <p className="text-xs text-gray-500">Broadcast Address</p>
                          <div className="flex items-center justify-between mt-1">
                            <p className="text-white font-mono">{result.broadcastAddress}</p>
                            <Button
                              variant="ghost"
                              size="sm"
                              onClick={() => copyToClipboard(result.broadcastAddress)}
                              className="h-6 px-2"
                            >
                              <Copy className="w-3 h-3" />
                            </Button>
                          </div>
                        </div>
                      </div>

                      <div className="grid grid-cols-2 gap-4">
                        <div>
                          <p className="text-xs text-gray-500">Subnet Mask</p>
                          <p className="text-white font-mono mt-1">{result.subnetMask}</p>
                        </div>
                        <div>
                          <p className="text-xs text-gray-500">Wildcard Mask</p>
                          <p className="text-white font-mono mt-1">{result.wildcardMask}</p>
                        </div>
                      </div>

                      <div className="grid grid-cols-2 gap-4">
                        <div>
                          <p className="text-xs text-gray-500">First Usable</p>
                          <p className="text-white font-mono mt-1">{result.firstUsable}</p>
                        </div>
                        <div>
                          <p className="text-xs text-gray-500">Last Usable</p>
                          <p className="text-white font-mono mt-1">{result.lastUsable}</p>
                        </div>
                      </div>

                      <div className="grid grid-cols-3 gap-4">
                        <div className="p-3 rounded bg-emerald-900/10 text-center">
                          <p className="text-xs text-gray-500">Total Hosts</p>
                          <p className="text-emerald-400 font-mono text-lg">{result.totalHosts.toLocaleString()}</p>
                        </div>
                        <div className="p-3 rounded bg-emerald-900/10 text-center">
                          <p className="text-xs text-gray-500">Usable Hosts</p>
                          <p className="text-emerald-400 font-mono text-lg">{result.usableHosts.toLocaleString()}</p>
                        </div>
                        <div className="p-3 rounded bg-emerald-900/10 text-center">
                          <p className="text-xs text-gray-500">Prefix Length</p>
                          <p className="text-emerald-400 font-mono text-lg">/{result.prefix}</p>
                        </div>
                      </div>

                      <div className="grid grid-cols-2 gap-4">
                        <div>
                          <p className="text-xs text-gray-500">IP Class</p>
                          <p className="text-white mt-1">{result.ipClass}</p>
                        </div>
                        <div>
                          <p className="text-xs text-gray-500">Address Type</p>
                          <p className={`mt-1 ${result.isPrivate ? 'text-yellow-400' : 'text-green-400'}`}>
                            {result.isPrivate ? 'Private' : 'Public'}
                          </p>
                        </div>
                      </div>

                      {result.binary && (
                        <div>
                          <p className="text-xs text-gray-500 mb-2">Binary Representation</p>
                          <div className="space-y-2">
                            <div>
                              <p className="text-xs text-gray-500">IP Address</p>
                              <p className="text-white font-mono text-sm">{result.binary.ip}</p>
                            </div>
                            <div>
                              <p className="text-xs text-gray-500">Subnet Mask</p>
                              <p className="text-white font-mono text-sm">{result.binary.mask}</p>
                            </div>
                            <div>
                              <p className="text-xs text-gray-500">Network Address</p>
                              <p className="text-white font-mono text-sm">{result.binary.network}</p>
                            </div>
                          </div>
                        </div>
                      )}
                    </>
                  )}

                  {result.inputType === 'IP Address' && (
                    <>
                      <div className="grid grid-cols-2 gap-4">
                        <div>
                          <p className="text-xs text-gray-500">Decimal</p>
                          <div className="flex items-center justify-between mt-1">
                            <p className="text-white font-mono">{result.decimal.toLocaleString()}</p>
                            <Button
                              variant="ghost"
                              size="sm"
                              onClick={() => copyToClipboard(result.decimal.toString())}
                              className="h-6 px-2"
                            >
                              <Copy className="w-3 h-3" />
                            </Button>
                          </div>
                        </div>
                        <div>
                          <p className="text-xs text-gray-500">Hexadecimal</p>
                          <div className="flex items-center justify-between mt-1">
                            <p className="text-white font-mono">{result.hex}</p>
                            <Button
                              variant="ghost"
                              size="sm"
                              onClick={() => copyToClipboard(result.hex)}
                              className="h-6 px-2"
                            >
                              <Copy className="w-3 h-3" />
                            </Button>
                          </div>
                        </div>
                      </div>

                      <div>
                        <p className="text-xs text-gray-500">Binary</p>
                        <div className="flex items-center justify-between mt-1">
                          <p className="text-white font-mono text-sm">{result.binary}</p>
                          <Button
                            variant="ghost"
                            size="sm"
                            onClick={() => copyToClipboard(result.binary)}
                            className="h-6 px-2"
                          >
                            <Copy className="w-3 h-3" />
                          </Button>
                        </div>
                      </div>

                      <div className="grid grid-cols-2 gap-4">
                        <div>
                          <p className="text-xs text-gray-500">IP Class</p>
                          <p className="text-white mt-1">{result.ipClass}</p>
                        </div>
                        <div>
                          <p className="text-xs text-gray-500">Default Subnet</p>
                          <p className="text-white mt-1">{result.defaultMask} (/{result.defaultPrefix})</p>
                        </div>
                      </div>

                      <div className="grid grid-cols-2 gap-4">
                        <div>
                          <p className="text-xs text-gray-500">Address Type</p>
                          <p className={`mt-1 ${result.isPrivate ? 'text-yellow-400' : 'text-green-400'}`}>
                            {result.isPrivate ? 'Private' : 'Public'}
                          </p>
                        </div>
                        <div>
                          <p className="text-xs text-gray-500">Special Properties</p>
                          <div className="mt-1 space-y-1">
                            {result.isLoopback && <Badge className="bg-blue-500/20 text-blue-400">Loopback</Badge>}
                            {result.isMulticast && <Badge className="bg-purple-500/20 text-purple-400">Multicast</Badge>}
                            {result.isBroadcast && <Badge className="bg-red-500/20 text-red-400">Broadcast</Badge>}
                          </div>
                        </div>
                      </div>

                      {result.suggestions && (
                        <div>
                          <p className="text-xs text-gray-500 mb-2">Common Subnet Suggestions</p>
                          <div className="space-y-2">
                            {result.suggestions.map((suggestion: string, i: number) => (
                              <div key={i} className="flex items-center justify-between p-2 rounded bg-gray-900/20">
                                <span className="text-white font-mono text-sm">{suggestion}</span>
                                <Button
                                  variant="ghost"
                                  size="sm"
                                  onClick={() => {
                                    setInputValue(suggestion)
                                    calculateIpAddress()
                                  }}
                                  className="h-6 px-2 text-emerald-400"
                                >
                                  Calculate
                                </Button>
                              </div>
                            ))}
                          </div>
                        </div>
                      )}
                    </>
                  )}

                  {result.inputType === 'Decimal' && (
                    <>
                      <div>
                        <p className="text-xs text-gray-500">IP Address</p>
                        <div className="flex items-center justify-between mt-1">
                          <p className="text-white font-mono">{result.ipAddress}</p>
                          <Button
                            variant="ghost"
                            size="sm"
                            onClick={() => copyToClipboard(result.ipAddress)}
                            className="h-6 px-2"
                          >
                            <Copy className="w-3 h-3" />
                          </Button>
                        </div>
                      </div>

                      <div className="grid grid-cols-2 gap-4">
                        <div>
                          <p className="text-xs text-gray-500">Hexadecimal</p>
                          <p className="text-white font-mono mt-1">{result.hex}</p>
                        </div>
                        <div>
                          <p className="text-xs text-gray-500">Binary</p>
                          <p className="text-white font-mono text-sm mt-1">{result.binary}</p>
                        </div>
                      </div>

                      <div>
                        <p className="text-xs text-gray-500">Octets</p>
                        <div className="grid grid-cols-4 gap-2 mt-1">
                          {result.octets.map((octet: number, i: number) => (
                            <div key={i} className="p-2 rounded bg-gray-900/20 text-center">
                              <p className="text-white font-mono">{octet}</p>
                            </div>
                          ))}
                        </div>
                      </div>
                    </>
                  )}
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  return null
}