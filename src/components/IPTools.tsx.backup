  // IP to Hostname View
  if (currentView === 'ip-to-hostname') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Globe className="w-5 h-5 text-cyan-400" />
            IP to Hostname Lookup
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Resolve an IP address to its hostname using reverse DNS lookup
          </p>
        </div>

        <Input
          placeholder="Enter IP address (e.g., 8.8.8.8)"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-cyan-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && ipToHostname()}
        />

        <Button 
          onClick={ipToHostname} 
          disabled={loading || !inputValue.trim()}
          className="bg-cyan-600 hover:bg-cyan-700 w-full"
        >
          {loading ? 'Looking up...' : 'Lookup Hostname'}
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-cyan-900/30">
            <CardContent className="p-4 space-y-3">
              {result.error ? (
                <p className="text-red-400 text-sm">{result.error}</p>
              ) : (
                <>
                  <div>
                    <p className="text-xs text-gray-500">IP Address</p>
                    <div className="flex items-center justify-between mt-1">
                      <p className="text-white font-mono">{result.ip}</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.ip)}
                        className="h-6 px-2"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                      </Button>
                    </div>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500">Hostname</p>
                    <div className="flex items-center justify-between mt-1">
                      <p className="text-cyan-400 font-mono">{result.hostname}</p>
                      <Button
                        variant="ghost"
                        size="sm"
                        onClick={() => copyToClipboard(result.hostname)}
                        className="h-6 px-2"
                      >
                        {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                      </Button>
                    </div>
                  </div>
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // Hostname to IP View
  if (currentView === 'hostname-to-ip') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
            size="sm" 
            onClick={goBack}
            className="text-gray-400 hover:text-white"
          >
            <ArrowLeft className="w-4 h-4 mr-2" />
            Back
          </Button>
        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <Network className="w-5 h-5 text-blue-400" />
            Hostname to IP Lookup
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Resolve a hostname to its IP address(es) using DNS lookup
          </p>
        </div>

        <Input
          placeholder="Enter hostname (e.g., google.com)"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-blue-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && hostnameToIp()}
        />

        <Button 
          onClick={hostnameToIp} 
          disabled={loading || !inputValue.trim()}
          className="bg-blue-600 hover:bg-blue-700 w-full"
        >
          {loading ? 'Looking up...' : 'Lookup IP Address'}
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-blue-900/30">
            <CardContent className="p-4 space-y-3">
              {result.error ? (
                <p className="text-red-400 text-sm">{result.error}</p>
              ) : (
                <>
                  <div>
                    <p className="text-xs text-gray-500">Hostname</p>
                    <p className="text-white font-mono mt-1">{result.hostname}</p>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500 mb-2">IP Address(es)</p>
                    <div className="space-y-2">
                      {result.ips.map((ip: string, i: number) => (
                        <div key={i} className="flex items-center justify-between p-2 rounded bg-blue-900/10">
                          <p className="text-blue-400 font-mono text-sm">{ip}</p>
                          <Button
                            variant="ghost"
                            size="sm"
                            onClick={() => copyToClipboard(ip)}
                            className="h-6 px-2"
                          >
                            {copied ? <Check className="w-3 h-3" /> : <Copy className="w-3 h-3" />}
                          </Button>
                        </div>
                      ))}
                    </div>
                  </div>
                </>
              )}
            </CardContent>
          </Card>
        )}
      </div>
    )
  }

  // IPv4 to IPv6 View
  if (currentView === 'ipv4-to-ipv6') {
    return (
      <div className="space-y-4">
        <div className="flex items-center justify-between">
          <Button 
            variant="ghost" 
