                    <p className="text-xs text-gray-500">IPv4 Address</p>
                    <p className="text-white font-mono mt-1">{result.ipv4}</p>
                  </div>
                  <div>
                    <p className="text-xs text-gray-500">IPv6 (Compressed)</p>
                    <div className="flex items-center justify-between mt-1">
                      <p className="text-purple-400 font-mono text-sm">{result.ipv6}</p>
                      <Button
                        variant="ghost"
