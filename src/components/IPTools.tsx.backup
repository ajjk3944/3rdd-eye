        </div>

        <div>
          <h2 className="text-xl font-bold text-white flex items-center gap-2">
            <RefreshCw className="w-5 h-5 text-purple-400" />
            IPv4 to IPv6 Converter
          </h2>
          <p className="text-xs text-gray-500 mt-1">
            Convert IPv4 address to IPv6 format
          </p>
        </div>

        <Input
          placeholder="Enter IPv4 address (e.g., 192.168.1.1)"
          value={inputValue}
          onChange={(e) => setInputValue(e.target.value)}
          className="bg-[#0d120d] border-purple-900/30 text-white"
          onKeyDown={(e) => e.key === 'Enter' && ipv4ToIpv6()}
        />

        <Button 
          onClick={ipv4ToIpv6} 
          disabled={!inputValue.trim()}
          className="bg-purple-600 hover:bg-purple-700 w-full"
        >
          Convert to IPv6
        </Button>

        {result && (
          <Card className="bg-[#0d120d] border-purple-900/30">
            <CardContent className="p-4 space-y-3">
              {result.error ? (
                <p className="text-red-400 text-sm">{result.error}</p>
              ) : (
                <>
