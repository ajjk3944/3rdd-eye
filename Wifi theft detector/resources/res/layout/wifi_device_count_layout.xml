<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:id="@+id/ll_wifi_info_layout"
    android:tag="layout/wifi_device_count_layout_0"
    android:paddingBottom="10dp"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:layout_gravity="center_horizontal"
        android:orientation="vertical"
        android:id="@+id/lv_wifi_info"
        android:paddingLeft="@dimen/router_manager_space_large"
        android:paddingTop="@dimen/router_manager_space_xmedium"
        android:paddingRight="@dimen/router_manager_space_large"
        android:paddingBottom="@dimen/router_manager_space_middle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="@dimen/router_manager_space_large"
        android:paddingEnd="@dimen/router_manager_space_large">
        <TextView
            android:textSize="20dp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimaryDark"
            android:layout_gravity="center"
            android:id="@+id/tv_wifi_name"
            android:layout_width="wrap_content"
            android:layout_marginTop="@dimen/router_manager_space_middle"
            android:text="---"
            android:textIsSelectable="false"
            style="@style/tv_wifiinfo_content"/>
        <TextView
            android:textSize="15sp"
            android:textColor="@color/colorPrimaryDark"
            android:layout_gravity="center"
            android:id="@+id/tv_wifi_mac"
            android:layout_width="wrap_content"
            android:layout_marginTop="@dimen/router_manager_space_normal"
            android:text="---"
            android:textIsSelectable="false"
            style="@style/tv_wifiinfo_content"/>
        <TextView
            android:textSize="15sp"
            android:textColor="@color/colorPrimaryDark"
            android:layout_gravity="center"
            android:id="@+id/tv_wifi_ip"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_marginTop="@dimen/router_manager_space_normal"
            android:text="---"
            style="@style/tv_wifiinfo_content"/>
    </LinearLayout>
    <LinearLayout
        android:layout_gravity="center_horizontal"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:layout_gravity="center_horizontal"
            android:orientation="vertical"
            android:id="@+id/lv_wifi_status"
            android:background="@drawable/main_status_bg"
            android:paddingLeft="10dp"
            android:paddingTop="5dp"
            android:paddingRight="10dp"
            android:paddingBottom="5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:layout_marginRight="15dp"
            android:paddingStart="10dp"
            android:paddingEnd="10dp"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp">
            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/text_20sp"
                    android:textStyle="bold"
                    android:textColor="@color/light_red"
                    android:id="@+id/tv_online_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"/>
                <TextView
                    android:textSize="@dimen/text_14sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/router_manager_space_middle"
                    android:text="@string/online_device"
                    android:layout_marginStart="@dimen/router_manager_space_middle"/>
            </LinearLayout>
            <LinearLayout
                android:id="@+id/lv_previously_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/router_manager_space_little">
                <TextView
                    android:textSize="@dimen/text_20sp"
                    android:textStyle="bold"
                    android:textColor="@color/light_red"
                    android:id="@+id/tv_previously_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0"/>
                <TextView
                    android:textSize="@dimen/text_14sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/router_manager_space_middle"
                    android:text="@string/previously_device"
                    android:layout_marginStart="@dimen/router_manager_space_middle"/>
            </LinearLayout>
        </LinearLayout>
        <androidx.cardview.widget.CardView
            android:layout_gravity="center_horizontal"
            android:id="@+id/cv_wifi_analyzer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="15dp"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"
            app:cardBackgroundColor="@color/light_blue"
            app:cardCornerRadius="4dp"
            app:cardElevation="2dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/text_15sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center_horizontal"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:text="@string/wifi_analyzer_content"
                    android:drawableRight="@drawable/ic_title_arrow_right"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"/>
                <ImageView
                    android:background="@drawable/ic_ad"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginLeft="3dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginStart="3dp"/>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:layout_gravity="center_horizontal"
            android:id="@+id/cv_speed_test"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:layout_marginTop="5dp"
            android:layout_marginRight="15dp"
            android:layout_marginStart="15dp"
            android:layout_marginEnd="15dp"
            app:cardBackgroundColor="@color/light_blue"
            app:cardCornerRadius="4dp"
            app:cardElevation="2dp">
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="@dimen/text_15sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center_horizontal"
                    android:id="@+id/tv_app_ad2"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10dp"
                    android:layout_marginBottom="10dp"
                    android:text="@string/test_speed"
                    android:drawableRight="@drawable/ic_title_arrow_right"
                    android:layout_marginStart="8dp"
                    android:layout_marginEnd="8dp"/>
                <ImageView
                    android:background="@drawable/ic_ad"
                    android:layout_width="12dp"
                    android:layout_height="12dp"
                    android:layout_marginLeft="3dp"
                    android:layout_marginTop="2dp"
                    android:layout_marginStart="3dp"/>
            </RelativeLayout>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</LinearLayout>
