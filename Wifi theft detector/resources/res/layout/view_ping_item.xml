<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:tag="layout/view_ping_item_0"
    android:padding="@dimen/router_manager_space_xmedium"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="@dimen/text_15sp"
        android:textStyle="bold"
        android:textColor="@color/text_black"
        android:id="@+id/tv_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginRight="@dimen/router_manager_space_medium"
        android:layout_toLeftOf="@+id/tv_time"
        android:textIsSelectable="true"
        android:layout_toStartOf="@+id/tv_time"/>
    <TextView
        android:textSize="@dimen/text_14sp"
        android:textColor="@color/text_72777B"
        android:id="@+id/tv_content"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/router_manager_space_small"
        android:layout_below="@+id/tv_title"
        android:textIsSelectable="true"/>
    <TextView
        android:textSize="@dimen/text_13sp"
        android:textStyle="bold"
        android:textColor="@color/text_black"
        android:id="@+id/tv_time"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:textIsSelectable="true"/>
</RelativeLayout>
