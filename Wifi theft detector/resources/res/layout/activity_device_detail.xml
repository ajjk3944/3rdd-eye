<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:tag="layout/activity_device_detail_0"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include
        android:id="@+id/view_title"
        layout="@layout/view_title"/>
    <ScrollView
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/base_back_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="80dp">
            <LinearLayout
                android:gravity="center"
                android:layout_gravity="center_horizontal"
                android:orientation="horizontal"
                android:id="@+id/lv_name_top"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="15dp"
                android:layout_marginTop="25dp"
                android:layout_marginRight="15dp"
                android:layout_marginBottom="15dp"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="15dp">
                <androidx.appcompat.widget.AppCompatImageView
                    android:id="@+id/activity_devices_detail_device_icon"
                    android:layout_width="@dimen/device_icon_width"
                    android:layout_height="@dimen/device_icon_height"
                    android:src="@drawable/ic_unknow"/>
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="@dimen/detail_title"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimary"
                    android:gravity="center"
                    android:layout_gravity="center_vertical"
                    android:id="@+id/activity_devices_detail_device_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="14dp"
                    android:maxWidth="200dp"
                    android:text="@string/unknown_value"
                    android:textIsSelectable="true"
                    android:layout_marginStart="14dp"/>
                <ImageView
                    android:layout_gravity="center_vertical"
                    android:id="@+id/iv_edit"
                    android:padding="4dp"
                    android:layout_width="30dp"
                    android:layout_height="30dp"
                    android:layout_marginLeft="12dp"
                    android:layout_marginTop="1dp"
                    android:src="@drawable/edit_name"
                    android:layout_marginStart="12dp"/>
            </LinearLayout>
            <TextView
                android:textSize="13sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="13dp"
                android:layout_marginTop="5dp"
                android:layout_marginRight="13dp"
                android:text="@string/long_press_copy"
                android:drawableLeft="@drawable/ic_notice"
                android:drawablePadding="5dp"
                android:drawableStart="@drawable/ic_notice"
                android:layout_marginStart="13dp"
                android:layout_marginEnd="13dp"/>
            <androidx.cardview.widget.CardView
                android:background="@color/white"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="3dp"
                android:layout_marginRight="10dp"
                android:layout_marginBottom="5dp"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                app:cardCornerRadius="3dp"
                app:cardElevation="3dp"
                app:cardUseCompatPadding="false">
                <LinearLayout
                    android:orientation="vertical"
                    android:paddingTop="5dp"
                    android:paddingBottom="10dp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <LinearLayout style="@style/detailItemLayoutStyle">
                        <TextView
                            android:text="@string/device_name"
                            style="@style/detailItemName"/>
                        <TextView
                            android:id="@+id/device_name"
                            style="@style/detailItemValue"/>
                    </LinearLayout>
                    <LinearLayout style="@style/detailItemLayoutStyle">
                        <TextView
                            android:text="@string/device_os"
                            style="@style/detailItemName"/>
                        <TextView
                            android:id="@+id/device_os"
                            android:text="@string/unknown_value"
                            style="@style/detailItemValue"/>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/lv_brand"
                        style="@style/detailItemLayoutStyle">
                        <TextView
                            android:text="@string/brand"
                            style="@style/detailItemName"/>
                        <TextView
                            android:id="@+id/device_brand"
                            android:text="@string/unknown_value"
                            style="@style/detailItemValue"/>
                    </LinearLayout>
                    <LinearLayout style="@style/detailItemLayoutStyle">
                        <TextView
                            android:text="@string/ip_address"
                            style="@style/detailItemName"/>
                        <TextView
                            android:id="@+id/device_ip"
                            android:text="@string/unknown_value"
                            style="@style/detailItemValue"/>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/lv_mac"
                        style="@style/detailItemLayoutStyle">
                        <TextView
                            android:text="@string/mac_address"
                            style="@style/detailItemName"/>
                        <TextView
                            android:id="@+id/device_mac"
                            android:text="@string/unknown_value"
                            style="@style/detailItemValue"/>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/lv_gateway"
                        android:visibility="gone"
                        style="@style/detailItemLayoutStyle">
                        <TextView
                            android:id="@+id/tv_title_gateway"
                            android:text="@string/gate_way"
                            style="@style/detailItemName"/>
                        <TextView
                            android:id="@+id/tv_gateway"
                            android:text="@string/unknown_value"
                            style="@style/detailItemValue"/>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/lv_dns1"
                        android:visibility="gone"
                        style="@style/detailItemLayoutStyle">
                        <TextView
                            android:id="@+id/tv_title_dns1"
                            android:text="@string/dns"
                            style="@style/detailItemName"/>
                        <TextView
                            android:id="@+id/tv_dns_1"
                            android:text="@string/unknown_value"
                            style="@style/detailItemValue"/>
                    </LinearLayout>
                    <LinearLayout
                        android:id="@+id/lv_dns2"
                        android:visibility="gone"
                        style="@style/detailItemLayoutStyle">
                        <TextView
                            android:id="@+id/tv_title_dns2"
                            android:text="@string/dns"
                            style="@style/detailItemName"/>
                        <TextView
                            android:id="@+id/tv_dns2"
                            android:text="@string/unknown_value"
                            style="@style/detailItemValue"/>
                    </LinearLayout>
                    <RelativeLayout
                        android:id="@+id/lv_known"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginBottom="@dimen/router_manager_space_middle"
                        android:minHeight="45dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:text="@string/known_or_not"
                            android:layout_centerVertical="true"
                            style="@style/detailItemName"/>
                        <androidx.appcompat.widget.AppCompatButton
                            android:textSize="13sp"
                            android:textColor="@color/white"
                            android:gravity="center"
                            android:id="@+id/btn_sign"
                            android:background="@drawable/btn_gray_bg_rectangle"
                            android:paddingLeft="4dp"
                            android:paddingRight="4dp"
                            android:layout_width="90dp"
                            android:layout_height="36dp"
                            android:layout_marginRight="25dp"
                            android:text="@string/stranger"
                            android:layout_alignParentRight="true"
                            android:layout_centerVertical="true"
                            android:textAllCaps="false"
                            android:paddingStart="4dp"
                            android:paddingEnd="4dp"
                            android:layout_marginEnd="25dp"
                            android:layout_alignParentEnd="true"/>
                    </RelativeLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_ad_container"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="2dp"
                android:layout_marginRight="10dp"
                android:layout_marginBottom="5dp"
                android:layout_below="@+id/lv_line_two"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="3dp"
                app:cardElevation="3dp">
                <FrameLayout
                    android:id="@+id/fl_ad_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </androidx.cardview.widget.CardView>
            <TextView
                android:textSize="@dimen/text_22sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimaryDark"
                android:id="@+id/tv_or_tip"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="25dp"
                android:text="Or you can:"
                android:layout_marginStart="20dp"/>
            <Button
                android:textSize="16sp"
                android:textColor="@color/white"
                android:id="@+id/go_to_route"
                android:background="@drawable/btn_blue_bg_rectangle"
                android:padding="10dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="50dp"
                android:layout_marginTop="28dp"
                android:layout_marginRight="50dp"
                android:layout_marginBottom="16dp"
                android:minHeight="50dp"
                android:text="@string/forbid_txt"
                android:textAllCaps="false"
                android:layout_marginStart="50dp"
                android:layout_marginEnd="50dp"/>
            <View
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginLeft="15dp"
                android:layout_marginRight="15dp"
                android:layout_marginStart="15dp"
                android:layout_marginEnd="15dp"/>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
