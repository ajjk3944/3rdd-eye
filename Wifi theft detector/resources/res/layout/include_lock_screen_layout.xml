<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:tag="layout/include_lock_screen_layout_0"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:paddingTop="8dp"
        android:paddingBottom="8dp"
        android:clipChildren="true"
        android:layout_width="180dp"
        android:layout_height="180dp">
        <FrameLayout
            android:id="@+id/widget_ripple"
            android:background="@drawable/widget_round_ripple"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:layout_centerInParent="true"/>
        <ImageView
            android:background="@drawable/widget_background"
            android:padding="20dp"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_trans"
            android:layout_centerInParent="true"/>
        <ImageView
            android:id="@+id/widget_leidabo"
            android:layout_width="140dp"
            android:layout_height="140dp"
            android:src="@drawable/radar"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <androidx.cardview.widget.CardView
        android:id="@+id/router_manager_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="10dp"
        android:layout_marginRight="10dp"
        android:layout_marginBottom="8dp"
        android:layout_marginStart="10dp"
        android:layout_marginEnd="10dp"
        app:cardBackgroundColor="@color/colorPrimary"
        app:cardCornerRadius="4dp"
        app:cardElevation="1dp">
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/lv_router_manager"
                android:padding="8dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <RelativeLayout
                    android:paddingTop="8dp"
                    android:paddingBottom="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="18dp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:id="@+id/tv_wifi_you_family"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="8dp"
                        android:drawableLeft="@drawable/ic_wifi"
                        android:drawablePadding="8dp"
                        android:drawableStart="@drawable/ic_wifi"
                        android:layout_marginStart="8dp"/>
                    <TextView
                        android:textSize="23sp"
                        android:textStyle="bold"
                        android:textColor="@color/light_red"
                        android:gravity="center"
                        android:id="@+id/tv_online_devices"
                        android:layout_width="30dp"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dp"
                        android:layout_marginTop="6dp"
                        android:text="0"
                        android:layout_below="@+id/tv_wifi_you_family"
                        android:layout_marginStart="5dp"/>
                    <TextView
                        android:textStyle="bold"
                        android:textColor="@color/light_red"
                        android:gravity="bottom"
                        android:id="@+id/tv_new_joined_device"
                        android:paddingBottom="3dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="4dp"
                        android:text="@string/online_devices"
                        android:singleLine="true"
                        android:layout_toRightOf="@+id/tv_online_devices"
                        android:layout_below="@+id/tv_wifi_you_family"
                        android:layout_alignTop="@+id/tv_online_devices"
                        android:layout_alignBottom="@+id/tv_online_devices"
                        android:layout_marginStart="4dp"
                        android:layout_toEndOf="@+id/tv_online_devices"/>
                    <TextView
                        android:textSize="23sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:id="@+id/tv_stranger_device_num"
                        android:layout_width="30dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="-"
                        android:layout_below="@+id/tv_new_joined_device"
                        android:layout_alignLeft="@+id/tv_online_devices"
                        android:layout_alignStart="@+id/tv_online_devices"/>
                    <TextView
                        android:textColor="@color/white"
                        android:gravity="bottom"
                        android:id="@+id/tv_stranger_device"
                        android:paddingBottom="3dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="4dp"
                        android:text="@string/stranger_devices"
                        android:singleLine="true"
                        android:layout_toRightOf="@+id/tv_stranger_device_num"
                        android:layout_below="@+id/tv_new_joined_device"
                        android:layout_alignTop="@+id/tv_stranger_device_num"
                        android:layout_alignBottom="@+id/tv_stranger_device_num"
                        android:layout_marginStart="4dp"
                        android:layout_toEndOf="@+id/tv_stranger_device_num"/>
                    <TextView
                        android:textSize="23sp"
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:id="@+id/tv_known_device_num"
                        android:layout_width="30dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="-"
                        android:layout_below="@+id/tv_stranger_device"
                        android:layout_alignLeft="@+id/tv_online_devices"
                        android:layout_alignStart="@+id/tv_online_devices"/>
                    <TextView
                        android:textColor="@color/white"
                        android:gravity="bottom"
                        android:id="@+id/tv_known_device"
                        android:paddingBottom="3dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="4dp"
                        android:text="@string/familiar_devices"
                        android:singleLine="true"
                        android:layout_toRightOf="@+id/tv_known_device_num"
                        android:layout_below="@+id/tv_stranger_device"
                        android:layout_alignTop="@+id/tv_known_device_num"
                        android:layout_alignBottom="@+id/tv_known_device_num"
                        android:layout_marginStart="4dp"
                        android:layout_toEndOf="@+id/tv_known_device_num"/>
                    <TextView
                        android:textStyle="bold"
                        android:textColor="@color/white"
                        android:gravity="center"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5dp"
                        android:layout_marginRight="8dp"
                        android:text="@string/widget_go_detail"
                        android:drawableRight="@drawable/widget_go_detail"
                        android:drawablePadding="5dp"
                        android:layout_below="@+id/tv_known_device"
                        android:layout_alignParentRight="true"
                        android:layout_centerVertical="true"
                        android:layout_marginEnd="8dp"
                        android:layout_alignParentEnd="true"/>
                </RelativeLayout>
            </LinearLayout>
        </ScrollView>
    </androidx.cardview.widget.CardView>
</LinearLayout>
