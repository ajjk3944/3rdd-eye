<?xml version="1.0" encoding="utf-8"?>
<com.google.android.gms.ads.nativead.NativeAdView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:background="@color/ad_background"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.google.android.gms.ads.nativead.MediaView
                android:gravity="center"
                android:id="@+id/ad_media"
                android:layout_width="match_parent"
                android:layout_height="190dp"/>
            <TextView
                android:textSize="12sp"
                android:textColor="#ffffff"
                android:layout_gravity="start"
                android:background="#ffcc66"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="AD"/>
        </RelativeLayout>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/ad_app_icon"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginLeft="8dp"
                android:adjustViewBounds="true"
                android:layout_marginStart="8dp"/>
            <LinearLayout
                android:gravity="bottom"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="8dp"
                android:layout_marginStart="8dp">
                <TextView
                    android:textSize="14sp"
                    android:textStyle="bold"
                    android:textColor="@color/ad_title_color"
                    android:ellipsize="end"
                    android:id="@+id/ad_headline"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="20dp"
                    android:maxLines="1"
                    android:layout_marginEnd="20dp"/>
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:gravity="bottom"
                        android:id="@+id/ad_advertiser"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"/>
                    <RatingBar
                        android:id="@+id/ad_stars"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        android:numStars="5"
                        android:stepSize="0.5"
                        android:isIndicator="true"
                        style="?android:attr/ratingBarStyleSmall"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="5dp"
                        android:layout_marginStart="5dp">
                        <TextView
                            android:textSize="13sp"
                            android:textStyle="bold"
                            android:gravity="bottom"
                            android:id="@+id/ad_price"
                            android:layout_width="wrap_content"
                            android:layout_height="match_parent"/>
                        <TextView
                            android:textSize="13sp"
                            android:id="@+id/ad_store"
                            android:paddingLeft="5dp"
                            android:paddingRight="5dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:paddingStart="5dp"
                            android:paddingEnd="5dp"/>
                    </LinearLayout>
                </LinearLayout>
                <TextView
                    android:textSize="13sp"
                    android:textColor="@color/ad_content_color"
                    android:ellipsize="end"
                    android:id="@+id/ad_body"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginRight="20dp"
                    android:maxLines="2"
                    android:layout_marginEnd="20dp"/>
            </LinearLayout>
        </LinearLayout>
        <FrameLayout
            android:id="@+id/fl_content_action"
            android:background="@drawable/bg_corner_light_blue"
            android:layout_width="match_parent"
            android:layout_height="45dp"
            android:layout_margin="6dp">
            <Button
                android:textSize="16sp"
                android:textColor="#ffffff"
                android:gravity="center"
                android:id="@+id/ad_call_to_action"
                android:background="@null"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:textAllCaps="false"/>
            <View
                android:id="@+id/view_light"
                android:background="@drawable/ad_shape_gradient"
                android:visibility="gone"
                android:layout_width="50dp"
                android:layout_height="match_parent"/>
        </FrameLayout>
    </LinearLayout>
</com.google.android.gms.ads.nativead.NativeAdView>
