<?xml version="1.0" encoding="utf-8"?>
<com.wifihacker.detector.mvp.view.widget.SildingFinishLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/sfl"
    android:tag="layout/activity_lock_screen_0"
    android:background="@drawable/bg_lock_screen"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/rl_time"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/iv_block_wifi_thief_logo"
            android:background="@drawable/widget_logo"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="11dp"
            android:layout_marginStart="16dp"/>
        <TextView
            android:textSize="@dimen/text_14sp"
            android:textColor="@color/white"
            android:gravity="center_vertical"
            android:id="@+id/tv_app_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="8dp"
            android:text="@string/app_name"
            android:layout_toRightOf="@+id/iv_block_wifi_thief_logo"
            android:layout_alignTop="@+id/iv_block_wifi_thief_logo"
            android:layout_alignBottom="@+id/iv_block_wifi_thief_logo"
            android:layout_marginStart="8dp"
            android:layout_toEndOf="@+id/iv_block_wifi_thief_logo"/>
        <ImageView
            android:id="@+id/iv_setting"
            android:background="@drawable/ic_setting"
            android:padding="4dp"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="10dp"
            android:layout_alignParentRight="true"
            android:layout_marginEnd="16dp"
            android:layout_alignParentEnd="true"/>
        <TextView
            android:textSize="50dp"
            android:textColor="@color/white"
            android:id="@+id/tv_local_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginTop="40dp"
            android:text="13:14"
            android:layout_marginStart="16dp"/>
        <RelativeLayout
            android:id="@+id/rl_battery"
            android:background="@drawable/bg_battery"
            android:layout_width="98dp"
            android:layout_height="40dp"
            android:layout_marginTop="10dp"
            android:layout_marginRight="60dp"
            android:layout_marginBottom="10dp"
            android:layout_alignTop="@+id/tv_local_time"
            android:layout_alignBottom="@+id/tv_local_time"
            android:layout_alignParentRight="true"
            android:layout_centerHorizontal="true"
            android:layout_marginEnd="60dp"
            android:layout_alignParentEnd="true">
            <TextView
                android:id="@+id/tv_battery_bg"
                android:background="@drawable/battery_round_bg"
                android:layout_width="46dp"
                android:layout_height="match_parent"
                android:layout_alignParentLeft="true"
                android:layout_alignParentStart="true"/>
            <TextView
                android:textColor="@color/white"
                android:id="@+id/tv_battery_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="40%"
                android:layout_centerInParent="true"/>
        </RelativeLayout>
        <TextView
            android:textSize="15sp"
            android:textColor="@color/white"
            android:id="@+id/tv_month"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_below="@+id/tv_local_time"
            android:layout_alignLeft="@+id/tv_local_time"
            android:layout_alignStart="@+id/tv_local_time"/>
        <TextView
            android:textSize="15sp"
            android:textColor="@color/white"
            android:id="@+id/tv_day"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_toRightOf="@+id/tv_month"
            android:layout_below="@+id/tv_local_time"
            android:layout_alignTop="@+id/tv_month"
            android:layout_marginStart="10dp"
            android:layout_toEndOf="@+id/tv_month"/>
    </RelativeLayout>
    <TextView
        android:textSize="17sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:id="@+id/tv_title_info"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="16dp"
        android:layout_marginTop="10dp"
        android:layout_marginBottom="6dp"
        android:text="@string/lock_screen_title_info"
        android:layout_below="@+id/rl_time"
        android:layout_marginStart="16dp"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:tag="binding_1"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/tv_unlock"
        android:layout_below="@+id/tv_title_info">
        <include
            android:id="@+id/include_lock_screen_layout"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="16dp"
            android:layout_marginRight="16dp"
            android:layout_below="@+id/tv_title_info"
            layout="@layout/include_lock_screen_layout"/>
    </LinearLayout>
    <TextView
        android:textStyle="bold"
        android:textColor="@color/white"
        android:gravity="center_vertical"
        android:id="@+id/tv_unlock"
        android:layout_width="wrap_content"
        android:layout_height="40dp"
        android:text="@string/unlock"
        android:drawableLeft="@drawable/ic_unlock"
        android:drawablePadding="8dp"
        android:layout_alignParentBottom="true"
        android:layout_centerHorizontal="true"
        android:drawableStart="@drawable/ic_unlock"/>
</com.wifihacker.detector.mvp.view.widget.SildingFinishLayout>
