<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="8dp"
    android:layout_marginTop="6dp"
    android:layout_marginRight="8dp"
    android:layout_marginBottom="2dp"
    android:layout_marginStart="8dp"
    android:layout_marginEnd="8dp">
    <LinearLayout
        android:orientation="horizontal"
        android:padding="8dp"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ImageView
            android:layout_gravity="center_vertical"
            android:id="@+id/iv_history_list_icon"
            android:layout_width="55dp"
            android:layout_height="55dp"
            android:layout_marginLeft="10dp"
            android:layout_marginRight="18dp"
            android:src="@drawable/ic_wifi_lock_history"
            android:layout_marginStart="10dp"
            android:layout_marginEnd="18dp"/>
        <LinearLayout
            android:layout_gravity="center_vertical"
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="10dp"
            android:layout_marginBottom="10dp">
            <TextView
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimary"
                android:ellipsize="end"
                android:id="@+id/tv_history_wifi_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/unknown_value"
                android:maxLines="1"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/black_54"
                android:ellipsize="end"
                android:id="@+id/tv_history_online_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/online_device_count"
                android:maxLines="1"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/black_54"
                android:ellipsize="end"
                android:id="@+id/tv_history_offline_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:layout_marginBottom="5dp"
                android:text="@string/offline_device_count"
                android:maxLines="1"/>
            <TextView
                android:textSize="13sp"
                android:textColor="@color/black_54"
                android:ellipsize="end"
                android:gravity="right"
                android:id="@+id/tv_history_time"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/unknown_value"
                android:maxLines="1"/>
        </LinearLayout>
    </LinearLayout>
    <FrameLayout
        android:background="@color/bg_grey"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"/>
</LinearLayout>
