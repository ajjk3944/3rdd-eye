<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/rate_guide_layout"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="8dp"
    app:cardBackgroundColor="#f8faff"
    app:cardCornerRadius="4dp"
    app:cardElevation="3dp">
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:orientation="vertical"
            android:padding="25dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginRight="20dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp">
                <TextView
                    android:textSize="19sp"
                    android:textStyle="bold"
                    android:textColor="@color/contact_edit_finish"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/rate_us"/>
            </LinearLayout>
            <TextView
                android:textSize="15sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimaryDark"
                android:gravity="center_horizontal"
                android:layout_gravity="center_horizontal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:text="@string/rate_sub_text"
                android:lineSpacingMultiplier="1.5"/>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="18dp"
                android:layout_marginTop="25dp"
                android:layout_marginRight="18dp"
                android:layout_marginBottom="8dp"
                android:layout_marginStart="18dp"
                android:layout_marginEnd="18dp">
                <TextView
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/contact_edit_finish"
                    android:gravity="center"
                    android:id="@+id/tv_rate"
                    android:background="@drawable/yes_selector"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:clickable="true"
                    android:layout_width="match_parent"
                    android:layout_height="43dp"
                    android:text="@string/apprate"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"/>
                <TextView
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:textColor="@color/colorPrimaryDark"
                    android:gravity="center"
                    android:id="@+id/tv_tousu"
                    android:background="@drawable/yes_selector"
                    android:paddingLeft="12dp"
                    android:paddingRight="12dp"
                    android:clickable="true"
                    android:layout_width="match_parent"
                    android:layout_height="43dp"
                    android:layout_marginTop="8dp"
                    android:text="@string/appcomplaint"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"/>
            </LinearLayout>
        </LinearLayout>
        <ImageView
            android:id="@+id/im_close"
            android:padding="13dp"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:layout_marginTop="3dp"
            android:layout_marginBottom="3dp"
            android:src="@drawable/ic_close"
            android:layout_alignParentRight="true"
            android:layout_marginStart="3dp"
            android:layout_marginEnd="3dp"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
</androidx.cardview.widget.CardView>
