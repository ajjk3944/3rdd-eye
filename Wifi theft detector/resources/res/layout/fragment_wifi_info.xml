<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:tag="layout/fragment_wifi_info_0"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:padding="@dimen/router_manager_space_middle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/text_13sp"
                android:textColor="@color/colorPrimaryDark"
                android:gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:layout_marginTop="5dp"
                android:layout_marginRight="10dp"
                android:text="@string/long_press_copy"
                android:drawableLeft="@drawable/ic_notice"
                android:drawablePadding="5dp"
                android:drawableStart="@drawable/ic_notice"
                android:layout_marginStart="10dp"
                android:layout_marginEnd="10dp"/>
            <androidx.cardview.widget.CardView
                android:layout_gravity="center_horizontal"
                android:id="@+id/cv_wifi_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="4dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:paddingBottom="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="@dimen/text_17sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/router_manager_space_comm"
                        android:layout_marginTop="@dimen/router_manager_space_medium"
                        android:text="@string/wifi_info"
                        android:layout_marginStart="@dimen/router_manager_space_comm"/>
                    <TextView
                        android:id="@+id/tv_net_ip"
                        style="@style/tv_wifiinfo_content"/>
                    <TextView
                        android:id="@+id/tv_wifi_gateway"
                        style="@style/tv_wifiinfo_content"/>
                    <TextView
                        android:id="@+id/tv_wifi_netmask"
                        style="@style/tv_wifiinfo_content"/>
                    <TextView
                        android:id="@+id/tv_wifi_mac"
                        style="@style/tv_wifiinfo_content"/>
                    <TextView
                        android:id="@+id/tv_wifi_dns1"
                        style="@style/tv_wifiinfo_content"/>
                    <TextView
                        android:id="@+id/tv_wifi_dns2"
                        style="@style/tv_wifiinfo_content"/>
                    <TextView
                        android:id="@+id/tv_wifi_broadcast_address"
                        style="@style/tv_wifiinfo_content"/>
                    <TextView
                        android:id="@+id/tv_wifi_frequency"
                        style="@style/tv_wifiinfo_content"/>
                    <TextView
                        android:id="@+id/tv_wifi_channel"
                        style="@style/tv_wifiinfo_content"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:layout_gravity="center_horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="5dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="4dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:paddingBottom="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="@dimen/text_16sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/router_manager_space_comm"
                        android:layout_marginTop="@dimen/router_manager_space_medium"
                        android:text="@string/my_device_info"
                        android:textIsSelectable="true"
                        android:layout_marginStart="@dimen/router_manager_space_comm"/>
                    <TextView
                        android:id="@+id/tv_device_ip"
                        style="@style/tv_wifiinfo_content"/>
                    <TextView
                        android:id="@+id/tv_device_mac"
                        style="@style/tv_wifiinfo_content"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
