<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@color/white"
    android:paddingTop="10dp"
    android:paddingBottom="10dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ImageView
        android:id="@+id/iv_notification"
        android:layout_width="42dp"
        android:layout_height="42dp"
        android:layout_marginLeft="10dp"
        android:layout_alignParentLeft="true"
        android:layout_centerVertical="true"
        android:layout_marginStart="10dp"
        android:layout_alignParentStart="true"/>
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="42dp"
        android:layout_marginLeft="10dp"
        android:layout_toLeftOf="@+id/btn_notification"
        android:layout_toRightOf="@+id/iv_notification"
        android:layout_alignTop="@+id/iv_notification"
        android:layout_marginStart="10dp"
        android:layout_toStartOf="@+id/btn_notification"
        android:layout_toEndOf="@+id/iv_notification">
        <TextView
            android:textSize="16sp"
            android:textColor="@color/black"
            android:ellipsize="end"
            android:id="@+id/tv_title_notification"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:maxLines="1"/>
        <LinearLayout
            android:orientation="horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textColor="@color/black"
                android:ellipsize="end"
                android:id="@+id/tv_notification_new_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"/>
            <TextView
                android:textColor="@color/black"
                android:ellipsize="end"
                android:id="@+id/tv_notification_new_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"/>
            <TextView
                android:textColor="@color/black"
                android:ellipsize="end"
                android:id="@+id/tv_notification_unknow_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"/>
            <TextView
                android:textColor="@color/black"
                android:ellipsize="end"
                android:id="@+id/tv_notification_unknow_content"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxLines="1"/>
        </LinearLayout>
    </LinearLayout>
    <TextView
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/btn_notification"
        android:background="@drawable/btn_blue_bg_rectangle"
        android:layout_width="64dp"
        android:layout_height="32dp"
        android:layout_marginRight="8dp"
        android:text="Test"
        android:layout_alignParentRight="true"
        android:layout_centerVertical="true"
        android:textAllCaps="false"
        android:layout_marginEnd="8dp"
        android:layout_alignParentEnd="true"/>
</RelativeLayout>
