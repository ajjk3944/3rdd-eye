<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:tag="layout/activity_help_0"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include
        android:id="@+id/toolbar_help"
        layout="@layout/view_title"/>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <LinearLayout
            android:orientation="vertical"
            android:padding="@dimen/router_manager_space_middle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardElevation="@dimen/router_manager_space_tiny">
                <LinearLayout
                    android:orientation="vertical"
                    android:padding="@dimen/router_manager_space_medium"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent">
                    <TextView
                        android:textSize="@dimen/text_20sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/router_passwords"/>
                    <TextView
                        android:textSize="@dimen/text_15sp"
                        android:textColor="@color/text_black"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/router_manager_space_medium"
                        android:text="@string/help_password_content1"
                        android:lineSpacingMultiplier="1.3"/>
                    <ImageView
                        android:layout_gravity="center_horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="255dp"
                        android:layout_marginTop="@dimen/router_manager_space_medium"
                        android:src="@drawable/bg_router_intro"/>
                    <TextView
                        android:textSize="@dimen/text_15sp"
                        android:textColor="@color/text_black"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="15dp"
                        android:text="@string/help_password_content2"
                        android:lineSpacingMultiplier="1.2"/>
                    <ImageView
                        android:layout_gravity="center_horizontal"
                        android:layout_width="match_parent"
                        android:layout_height="270dp"
                        android:layout_marginTop="@dimen/router_manager_space_medium"
                        android:src="@drawable/bg_router_intro_2"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
    <androidx.cardview.widget.CardView
        android:id="@+id/cv_router_notice"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:onClick="onPassClick"
        app:cardBackgroundColor="@color/colorPrimary"
        app:cardCornerRadius="3dp"
        app:cardElevation="2dp">
        <TextView
            android:textSize="@dimen/text_14sp"
            android:textColor="@color/white"
            android:id="@+id/tv_router_notice"
            android:paddingLeft="@dimen/router_manager_space_medium"
            android:paddingTop="@dimen/router_manager_space_normal_6"
            android:paddingRight="@dimen/router_manager_space_normal_6"
            android:paddingBottom="@dimen/router_manager_space_normal_6"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/notice_router"
            android:drawableLeft="@drawable/ic_notice"
            android:drawableRight="@drawable/ic_title_arrow_right"
            android:drawablePadding="@dimen/router_manager_space_middle"
            android:lineSpacingMultiplier="1.1"
            android:drawableStart="@drawable/ic_notice"
            android:drawableEnd="@drawable/ic_title_arrow_right"
            android:paddingStart="@dimen/router_manager_space_medium"
            android:paddingEnd="@dimen/router_manager_space_normal_6"/>
    </androidx.cardview.widget.CardView>
</LinearLayout>
