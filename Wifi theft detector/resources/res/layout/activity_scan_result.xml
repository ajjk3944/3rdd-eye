<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:tag="layout/activity_scan_result_0"
    android:background="@color/colorPrimary"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include
        android:id="@+id/toolbar_help"
        layout="@layout/view_title"/>
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@+id/lv_device_detail">
            <LinearLayout
                android:orientation="vertical"
                android:paddingLeft="@dimen/router_manager_space_middle"
                android:paddingRight="@dimen/router_manager_space_middle"
                android:paddingBottom="@dimen/router_manager_space_middle"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingStart="@dimen/router_manager_space_middle"
                android:paddingEnd="@dimen/router_manager_space_middle">
                <TextView
                    android:textSize="@dimen/text_20sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:id="@+id/tv_wifi_name"
                    android:layout_marginTop="8dp"
                    android:layout_marginBottom="@dimen/router_manager_space_comm"
                    android:text="-----"
                    android:onClick="onWiFiInfoClick"
                    style="@style/tv_wifiinfo_content"/>
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/lv_r_total_device"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <androidx.cardview.widget.CardView
                        android:layout_marginTop="10dp"
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="3dp"
                        app:cardElevation="2dp"
                        style="@style/ScanOptionStyle">
                        <LinearLayout
                            android:orientation="vertical"
                            android:paddingTop="15dp"
                            android:paddingBottom="10dp"
                            style="@style/MatchCommonStyle">
                            <TextView
                                android:text="@string/online_devices"
                                style="@style/OptionViewStyle"/>
                            <TextView
                                android:textSize="38sp"
                                android:id="@+id/tv_r_online_count"
                                android:text="0"
                                style="@style/ScanValueStyle"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/lv_total_device"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:onClick="onDeviceDetailClick">
                    <androidx.cardview.widget.CardView
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="3dp"
                        app:cardElevation="2dp"
                        style="@style/ScanOptionStyle">
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="vertical"
                            style="@style/MatchCommonStyle">
                            <TextView
                                android:text="@string/online_devices"
                                style="@style/OptionViewStyle"/>
                            <TextView
                                android:id="@+id/tv_online_count"
                                android:text="--"
                                style="@style/ScanValueStyle"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                    <androidx.cardview.widget.CardView
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="3dp"
                        app:cardElevation="2dp"
                        style="@style/ScanOptionStyle">
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="vertical"
                            style="@style/MatchCommonStyle">
                            <TextView
                                android:text="@string/offline_devices"
                                style="@style/OptionViewStyle"/>
                            <TextView
                                android:id="@+id/tv_offline_count"
                                android:text="--"
                                style="@style/ScanValueStyle"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
                <LinearLayout
                    android:orientation="horizontal"
                    android:id="@+id/lv_know_device"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="130dp"
                    android:onClick="onDeviceDetailClick">
                    <androidx.cardview.widget.CardView
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="3dp"
                        app:cardElevation="2dp"
                        style="@style/ScanOptionStyle">
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="vertical"
                            style="@style/MatchCommonStyle">
                            <TextView
                                android:text="@string/familiar_devices"
                                style="@style/OptionViewStyle"/>
                            <TextView
                                android:id="@+id/tv_known_device"
                                android:text="--"
                                style="@style/ScanValueStyle"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                    <androidx.cardview.widget.CardView
                        app:cardBackgroundColor="@color/white"
                        app:cardCornerRadius="3dp"
                        app:cardElevation="2dp"
                        style="@style/ScanOptionStyle">
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="vertical"
                            style="@style/MatchCommonStyle">
                            <TextView
                                android:text="@string/stranger_devices"
                                style="@style/OptionViewStyle"/>
                            <TextView
                                android:id="@+id/tv_stranger_device"
                                android:text="--"
                                style="@style/ScanValueStyle"/>
                        </LinearLayout>
                    </androidx.cardview.widget.CardView>
                </LinearLayout>
                <androidx.cardview.widget.CardView
                    android:id="@+id/cv_ad_container"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="4dp"
                    android:layout_marginTop="8dp"
                    android:layout_marginRight="4dp"
                    android:layout_marginStart="4dp"
                    android:layout_marginEnd="4dp"
                    app:cardBackgroundColor="@color/white"
                    app:cardCornerRadius="3dp"
                    app:cardElevation="2dp">
                    <FrameLayout
                        android:id="@+id/fl_ad_container"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </androidx.cardview.widget.CardView>
                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>
        </ScrollView>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/lv_device_detail"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:layout_alignParentBottom="true"
            android:onClick="onDeviceDetailClick">
            <View
                android:background="@color/white"
                android:layout_width="match_parent"
                android:layout_height="0.5dp"
                android:layout_marginLeft="25dp"
                android:layout_marginRight="25dp"
                android:layout_marginStart="25dp"
                android:layout_marginEnd="25dp"/>
            <LinearLayout
                android:gravity="bottom|center_horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <TextView
                    android:textSize="35sp"
                    android:textStyle="bold"
                    android:textColor="@color/origin"
                    android:id="@+id/tv_connected_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="15dp"
                    android:layout_marginTop="10dp"
                    android:text="0"
                    android:layout_marginStart="15dp"/>
                <TextView
                    android:textSize="@dimen/text_14sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/router_manager_space_middle"
                    android:layout_marginRight="15dp"
                    android:layout_marginBottom="3dp"
                    android:text="@string/online_device"
                    android:layout_marginStart="@dimen/router_manager_space_middle"
                    android:layout_marginEnd="15dp"/>
            </LinearLayout>
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_device_detail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="20dp"
                android:layout_marginTop="-6dp"
                android:layout_marginRight="20dp"
                android:layout_marginBottom="16dp"
                android:layout_marginStart="20dp"
                android:layout_marginEnd="20dp"
                app:cardBackgroundColor="@color/light_blue"
                app:cardCornerRadius="20dp"
                app:cardElevation="2dp">
                <TextView
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/white"
                    android:gravity="center"
                    android:layout_gravity="center"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="25dp"
                    android:layout_marginTop="15dp"
                    android:layout_marginRight="25dp"
                    android:layout_marginBottom="15dp"
                    android:text="@string/device_detail"
                    android:drawableRight="@drawable/ic_title_arrow_right"
                    android:drawablePadding="3dp"
                    android:drawableEnd="@drawable/ic_title_arrow_right"
                    android:layout_marginStart="25dp"
                    android:layout_marginEnd="25dp"/>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>
