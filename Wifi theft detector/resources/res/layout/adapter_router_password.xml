<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="46dp">
        <TextView
            android:textSize="@dimen/text_13sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimaryDark"
            android:gravity="center"
            android:id="@+id/tv_item_brand"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:textIsSelectable="true"/>
        <TextView
            android:textSize="@dimen/text_13sp"
            android:textColor="@color/colorPrimaryDark"
            android:gravity="center"
            android:id="@+id/tv_item_type"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:textIsSelectable="true"/>
        <TextView
            android:textSize="@dimen/text_13sp"
            android:textColor="@color/black_87"
            android:gravity="center"
            android:id="@+id/tv_item_username"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:textIsSelectable="true"/>
        <TextView
            android:textSize="@dimen/text_13sp"
            android:textColor="@color/black_87"
            android:gravity="center"
            android:id="@+id/tv_item_password"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:textIsSelectable="true"/>
    </LinearLayout>
    <FrameLayout
        android:background="@color/light_grey"
        android:layout_width="match_parent"
        android:layout_height="1px"
        android:layout_marginLeft="@dimen/router_manager_space_comm"
        android:layout_marginRight="@dimen/router_manager_space_comm"
        android:layout_marginStart="@dimen/router_manager_space_comm"
        android:layout_marginEnd="@dimen/router_manager_space_comm"/>
</LinearLayout>
