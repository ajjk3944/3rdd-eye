<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:tag="layout/activity_splash_0"
    android:background="@color/white"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginTop="50dp"
        android:layout_above="@+id/lv_bottom_content">
        <ImageView
            android:id="@+id/im_logo"
            android:background="@drawable/ic_logo"
            android:visibility="invisible"
            android:layout_width="150dp"
            android:layout_height="150dp"/>
        <TextView
            android:textSize="20sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:id="@+id/tv_app_name"
            android:paddingLeft="15dp"
            android:paddingRight="15dp"
            android:visibility="invisible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="@string/app_name"
            android:singleLine="true"
            android:paddingStart="15dp"
            android:paddingEnd="15dp"/>
        <TextView
            android:textSize="15sp"
            android:textStyle="bold"
            android:textColor="@color/colorPrimary"
            android:gravity="center"
            android:id="@+id/tv_app_tip"
            android:paddingLeft="30dp"
            android:paddingRight="30dp"
            android:visibility="invisible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:text="@string/who_wifi"
            android:paddingStart="30dp"
            android:paddingEnd="30dp"/>
        <com.youdao.material.views.WYProgressView
            android:id="@+id/progress_wheel"
            android:visibility="invisible"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:layout_marginTop="10dp"
            app:matProg_barColor="@color/colorPrimary"
            app:matProg_progressIndeterminate="true"/>
    </LinearLayout>
    <FrameLayout
        android:id="@+id/lv_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_above="@+id/lv_bottom_content"/>
    <LinearLayout
        android:gravity="start"
        android:orientation="vertical"
        android:id="@+id/lv_bottom_content"
        android:paddingLeft="25dp"
        android:paddingTop="20dp"
        android:paddingBottom="20dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:paddingStart="25dp">
        <TextView
            android:textSize="12sp"
            android:textColor="@color/section_text_gray"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="5dp"
            android:text="@string/version_right"/>
    </LinearLayout>
</RelativeLayout>
