<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:tag="layout/activity_wifi_info_0"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <include
        android:id="@+id/toolbar_help"
        layout="@layout/view_title"/>
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:padding="@dimen/router_manager_space_middle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="@dimen/text_13sp"
                android:textStyle="bold"
                android:textColor="@color/colorPrimaryDark"
                android:gravity="center_vertical"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:layout_marginRight="5dp"
                android:text="@string/long_press_copy"
                android:drawableLeft="@drawable/ic_notice"
                android:drawablePadding="5dp"
                android:drawableStart="@drawable/ic_notice"
                android:layout_marginStart="5dp"
                android:layout_marginEnd="5dp"/>
            <androidx.cardview.widget.CardView
                android:layout_gravity="center_horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="3dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="4dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:paddingBottom="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="@dimen/text_16sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimaryDark"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/router_manager_space_large"
                        android:layout_marginTop="@dimen/router_manager_space_large"
                        android:text="@string/my_device_info"
                        android:textIsSelectable="true"
                        android:layout_marginStart="@dimen/router_manager_space_large"/>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">
                        <LinearLayout style="@style/InfoItemLayoutStyle">
                            <TextView
                                android:id="@+id/tv_title_device_ip"
                                style="@style/InfoItemName"/>
                            <TextView
                                android:id="@+id/tv_device_ip"
                                style="@style/InfoItemValue"/>
                        </LinearLayout>
                        <LinearLayout
                            android:id="@+id/lv_device_mac"
                            style="@style/InfoItemLayoutStyle">
                            <TextView
                                android:id="@+id/tv_title_device_mac"
                                style="@style/InfoItemName"/>
                            <TextView
                                android:id="@+id/tv_device_mac"
                                android:text="@string/unknown_value"
                                style="@style/InfoItemValue"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:id="@+id/cv_ad_container"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="3dp"
                android:layout_marginTop="3dp"
                android:layout_marginRight="3dp"
                android:layout_marginBottom="3dp"
                android:layout_marginStart="3dp"
                android:layout_marginEnd="3dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="3dp"
                app:cardElevation="3dp">
                <FrameLayout
                    android:id="@+id/fl_ad_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:layout_gravity="center_horizontal"
                android:id="@+id/cv_wifi_info"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_margin="3dp"
                app:cardBackgroundColor="@color/white"
                app:cardCornerRadius="4dp"
                app:cardElevation="2dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:paddingBottom="8dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textSize="@dimen/text_17sp"
                        android:textStyle="bold"
                        android:textColor="@color/colorPrimaryDark"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginLeft="@dimen/router_manager_space_large"
                        android:layout_marginTop="@dimen/router_manager_space_large"
                        android:text="@string/wifi_info"
                        android:layout_marginStart="@dimen/router_manager_space_large"/>
                    <LinearLayout
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">
                        <LinearLayout
                            android:id="@+id/lv_net_ip"
                            android:visibility="gone"
                            style="@style/InfoItemLayoutStyle">
                            <TextView
                                android:id="@+id/tv_title_net_ip"
                                style="@style/InfoItemName"/>
                            <TextView
                                android:id="@+id/tv_net_ip"
                                style="@style/InfoItemValue"/>
                        </LinearLayout>
                        <LinearLayout style="@style/InfoItemLayoutStyle">
                            <TextView
                                android:id="@+id/tv_title_wifi_gateway"
                                style="@style/InfoItemName"/>
                            <TextView
                                android:id="@+id/tv_wifi_gateway"
                                android:text="@string/unknown_value"
                                style="@style/InfoItemValue"/>
                        </LinearLayout>
                        <LinearLayout style="@style/InfoItemLayoutStyle">
                            <TextView
                                android:id="@+id/tv_title_wifi_netmask"
                                style="@style/InfoItemName"/>
                            <TextView
                                android:id="@+id/tv_wifi_netmask"
                                android:text="@string/unknown_value"
                                style="@style/InfoItemValue"/>
                        </LinearLayout>
                        <LinearLayout style="@style/InfoItemLayoutStyle">
                            <TextView
                                android:id="@+id/tv_title_wifi_mac"
                                style="@style/InfoItemName"/>
                            <TextView
                                android:id="@+id/tv_wifi_mac"
                                android:text="@string/unknown_value"
                                style="@style/InfoItemValue"/>
                        </LinearLayout>
                        <LinearLayout style="@style/InfoItemLayoutStyle">
                            <TextView
                                android:id="@+id/tv_title_wifi_dns1"
                                style="@style/InfoItemName"/>
                            <TextView
                                android:id="@+id/tv_wifi_dns1"
                                android:text="@string/unknown_value"
                                style="@style/InfoItemValue"/>
                        </LinearLayout>
                        <LinearLayout style="@style/InfoItemLayoutStyle">
                            <TextView
                                android:id="@+id/tv_title_wifi_dns2"
                                style="@style/InfoItemName"/>
                            <TextView
                                android:id="@+id/tv_wifi_dns2"
                                android:text="@string/unknown_value"
                                style="@style/InfoItemValue"/>
                        </LinearLayout>
                        <LinearLayout style="@style/InfoItemLayoutStyle">
                            <TextView
                                android:id="@+id/tv_title_wifi_broadcast_address"
                                style="@style/InfoItemName"/>
                            <TextView
                                android:id="@+id/tv_wifi_broadcast_address"
                                android:text="@string/unknown_value"
                                style="@style/InfoItemValue"/>
                        </LinearLayout>
                        <LinearLayout style="@style/InfoItemLayoutStyle">
                            <TextView
                                android:id="@+id/tv_title_wifi_frequency"
                                style="@style/InfoItemName"/>
                            <TextView
                                android:id="@+id/tv_wifi_frequency"
                                android:text="@string/unknown_value"
                                style="@style/InfoItemValue"/>
                        </LinearLayout>
                        <LinearLayout style="@style/InfoItemLayoutStyle">
                            <TextView
                                android:id="@+id/tv_title_wifi_channel"
                                style="@style/InfoItemName"/>
                            <TextView
                                android:id="@+id/tv_wifi_channel"
                                android:text="@string/unknown_value"
                                style="@style/InfoItemValue"/>
                        </LinearLayout>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</LinearLayout>
