<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto" android:orientation="vertical">
    <androidx.cardview.widget.CardView
        android:id="@+id/analyze_item"
        android:nextFocusUp="@+id/buttons_container"
        android:nextFocusDown="@+id/recyclerview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="?attr/analyzer_content_padding"
        android:layout_marginTop="?attr/analyzer_content_padding"
        android:layout_marginRight="?attr/analyzer_content_padding"
        android:foreground="@null"
        android:layout_marginHorizontal="?attr/analyzer_content_padding"
        style="?attr/analyzer_card_style">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:padding="?attr/analyzer_content_padding"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/head_icon"
                android:visibility="gone"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="14sp"
                android:textColor="?android:attr/textColorPrimary"
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="?attr/analyzer_content_padding"
                app:layout_constraintStart_toEndOf="@+id/head_icon"
                app:layout_constraintTop_toTopOf="@+id/head_icon"
                app:layout_goneMarginStart="0dp"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#f64c4c"
                android:id="@+id/tv_size"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="8dp"
                app:layout_constraintBottom_toBottomOf="@+id/tv_title"
                app:layout_constraintStart_toEndOf="@+id/tv_title"
                app:layout_constraintTop_toTopOf="@+id/tv_title"/>
            <TextView
                android:textSize="12sp"
                android:id="@+id/tv_summary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@+id/tv_title"
                app:layout_constraintTop_toBottomOf="@+id/tv_size"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">
        <ProgressBar
            android:layout_gravity="center"
            android:id="@+id/progress"
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/empty_file"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/fa_ic_empty_file"
            android:contentDescription="@null"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:orientation="vertical"
            android:id="@+id/list_data_area"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <com.liuzho.lib.ui.CardRecyclerView
                android:id="@+id/recyclerview"
                android:paddingTop="?attr/analyzer_content_padding"
                android:scrollbars="none"
                android:nextFocusLeft="@+id/buttons_container"
                android:nextFocusRight="@+id/buttons_container"
                android:nextFocusUp="@+id/analyze_item"
                android:nextFocusDown="@+id/buttons_container"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                app:layout_constraintBottom_toTopOf="@+id/buttons_container"
                app:layout_constraintTop_toTopOf="parent"/>
            <View
                android:id="@+id/buttons_divider"
                android:background="@drawable/fa_top_shadow"
                android:layout_width="match_parent"
                android:layout_height="5dp"
                app:layout_constraintBottom_toTopOf="@+id/buttons_container"/>
            <LinearLayout
                android:gravity="center"
                android:id="@+id/buttons_container"
                android:nextFocusUp="@+id/recyclerview"
                android:nextFocusDown="@+id/analyze_item"
                android:layout_width="match_parent"
                android:layout_height="54dp"
                android:baselineAligned="false"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent">
                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.5"/>
                <FrameLayout
                    android:id="@+id/sort_btn"
                    android:background="?android:attr/selectableItemBackground"
                    android:paddingLeft="2dp"
                    android:paddingRight="2dp"
                    android:nextFocusLeft="@+id/clear_btn"
                    android:nextFocusRight="@+id/clear_btn"
                    android:nextFocusUp="@+id/recyclerview"
                    android:nextFocusDown="@+id/analyze_item"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:paddingHorizontal="2dp">
                    <TextView
                        android:textSize="10sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:gravity="center"
                        android:layout_gravity="center"
                        android:id="@+id/txt_sort"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/fa_sort"
                        android:singleLine="true"
                        android:drawablePadding="2dp"
                        app:drawableTopCompat="@drawable/fa_ic_sort"/>
                </FrameLayout>
                <FrameLayout
                    android:id="@+id/clear_btn"
                    android:background="?android:attr/selectableItemBackground"
                    android:paddingLeft="2dp"
                    android:paddingRight="2dp"
                    android:nextFocusLeft="@+id/sort_btn"
                    android:nextFocusRight="@+id/sort_btn"
                    android:nextFocusUp="@+id/recyclerview"
                    android:nextFocusDown="@+id/analyze_item"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:paddingHorizontal="2dp">
                    <TextView
                        android:textSize="10sp"
                        android:textColor="?android:attr/textColorPrimary"
                        android:gravity="center"
                        android:layout_gravity="center"
                        android:id="@+id/txt_delete"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/fa_string_clear"
                        android:singleLine="true"
                        android:drawablePadding="2dp"
                        app:drawableTopCompat="@drawable/fa_ic_delete"/>
                </FrameLayout>
                <Space
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1.5"/>
            </LinearLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>
</merge>
