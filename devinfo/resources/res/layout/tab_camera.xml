<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/main_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <HorizontalScrollView
            android:padding="@dimen/content_padding_half"
            android:scrollbars="none"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <com.liuzh.deviceinfo.view.togglebuttongroup.SingleSelectToggleGroup
                android:id="@+id/camera_group"
                android:layout_width="wrap_content"
                android:layout_height="match_parent"/>
        </HorizontalScrollView>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/content_padding"
            android:layout_marginRight="@dimen/content_padding"
            android:layout_marginBottom="@dimen/content_padding"
            android:layout_marginHorizontal="@dimen/content_padding"
            style="@style/CommonCardViewStyle">
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
            <TextView
                android:layout_gravity="center"
                android:id="@+id/message"
                android:padding="@dimen/content_padding_double"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/failed"/>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
    <FrameLayout
        android:id="@+id/note_container"
        android:background="#33000000"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/note_content"
            android:background="@color/common_card_color"
            android:padding="@dimen/content_padding"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorPrimary"
                android:id="@+id/note_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/camera_note_title"
                android:fontFamily="sans-serif-medium"/>
            <TextView
                android:textColor="?android:attr/textColorTertiary"
                android:paddingTop="@dimen/content_padding_half"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/camera_note"/>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorPrimary"
                android:layout_gravity="end"
                android:id="@+id/got_it"
                android:background="?android:attr/selectableItemBackground"
                android:paddingTop="6dp"
                android:paddingBottom="6dp"
                android:focusable="true"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_padding"
                android:text="@string/got_it"
                android:textAllCaps="true"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"/>
        </LinearLayout>
    </FrameLayout>
</FrameLayout>
