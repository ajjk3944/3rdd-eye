<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        style="@style/ToolbarStyle.Perspective"/>
    <include
        android:id="@+id/scanning_layout"
        android:paddingTop="@dimen/toolbar_height"
        layout="@layout/clean_scanning"/>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/scan_result_layout"
        android:background="@color/color_background"
        android:paddingTop="@dimen/toolbar_height"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.coordinatorlayout.widget.CoordinatorLayout
            android:id="@+id/coordinator"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toTopOf="parent">
            <com.google.android.material.appbar.AppBarLayout
                android:background="@android:color/transparent"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:elevation="0dp">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/top_layout"
                    android:background="@drawable/bg_common_card"
                    android:padding="@dimen/content_padding_plus2"
                    android:clipChildren="false"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="@dimen/content_padding"
                    android:layout_marginTop="@dimen/content_padding"
                    android:layout_marginRight="@dimen/content_padding"
                    android:minHeight="80dp"
                    android:elevation="@dimen/common_card_elevation"
                    android:layout_marginHorizontal="@dimen/content_padding"
                    app:layout_scrollFlags="scroll">
                    <ImageView
                        android:id="@+id/icon_head"
                        android:background="@drawable/bg_circle_22dp"
                        android:layout_width="44dp"
                        android:layout_height="44dp"
                        android:src="@drawable/ic_clean_cleanup"
                        android:scaleType="centerInside"
                        android:contentDescription="@null"/>
                    <TextView
                        android:textColor="?android:attr/textColorPrimary"
                        android:id="@+id/tv_result_title_size"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/content_padding_half"/>
                    <TextView
                        android:id="@+id/clean_tips"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/content_padding_half"
                        android:text="@string/clean_up_immediately"/>
                </LinearLayout>
            </com.google.android.material.appbar.AppBarLayout>
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/recycler_view"
                android:paddingBottom="120dp"
                android:clipToPadding="false"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                app:layout_behavior="@string/appbar_scrolling_view_behavior"/>
        </androidx.coordinatorlayout.widget.CoordinatorLayout>
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/empty_animation"
            android:visibility="gone"
            android:layout_width="220dp"
            android:layout_height="180dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <Button
            android:textColor="@color/white"
            android:gravity="center"
            android:id="@+id/confirm_button"
            android:paddingTop="12dp"
            android:paddingBottom="12dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="12dp"
            android:text="@string/action_clean"
            android:paddingVertical="12dp"
            app:layout_constraintBottom_toBottomOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/clean_layout"
        android:paddingTop="@dimen/toolbar_height"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottie_animation_cleaning"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintHeight_percent="0.7"
            app:layout_constraintTop_toTopOf="parent"
            app:lottie_fileName="lottie/storage_clean_cleaning.json"
            app:lottie_loop="true"/>
        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lottie_animation_finish"
            android:visibility="gone"
            android:layout_width="140dp"
            android:layout_height="140dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:lottie_fileName="lottie/storage_clean_finish.json"/>
        <TextView
            android:textSize="16sp"
            android:gravity="center"
            android:id="@+id/tv_cleaned"
            android:paddingLeft="28dp"
            android:paddingRight="28dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="28dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/lottie_animation_finish"/>
        <TextView
            android:id="@+id/tv_cleaning"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/lottie_animation_cleaning"/>
        <androidx.cardview.widget.CardView
            android:id="@+id/ad_container"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/content_padding"
            android:layout_marginRight="@dimen/content_padding"
            android:layout_marginHorizontal="@dimen/content_padding"
            app:cardCornerRadius="@dimen/common_card_radius"
            app:cardUseCompatPadding="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="parent"
            app:layout_constraintWidth_max="420dp"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
