<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.cardview.widget.CardView
        android:id="@+id/analyze_item"
        android:nextFocusLeft="@null"
        android:nextFocusRight="@null"
        android:nextFocusUp="@null"
        android:nextFocusDown="@+id/info_card"
        android:clickable="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="?attr/analyzer_content_padding"
        android:layout_marginTop="?attr/analyzer_content_padding"
        android:layout_marginRight="?attr/analyzer_content_padding"
        android:foreground="@null"
        android:layout_marginHorizontal="?attr/analyzer_content_padding"
        style="?attr/analyzer_card_style">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:padding="?attr/analyzer_content_padding"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/head_icon"
                android:visibility="gone"
                android:layout_width="24dp"
                android:layout_height="24dp"
                android:contentDescription="@null"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="14sp"
                android:textColor="?android:attr/textColorPrimary"
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:layout_marginStart="?attr/analyzer_content_padding"
                app:layout_constraintStart_toEndOf="@+id/head_icon"
                app:layout_constraintTop_toTopOf="@+id/head_icon"
                app:layout_goneMarginStart="0dp"/>
            <TextView
                android:textSize="14sp"
                android:textColor="#f64c4c"
                android:id="@+id/tv_size"
                android:paddingLeft="8dp"
                android:paddingRight="8dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="8dp"
                app:layout_constraintBottom_toBottomOf="@+id/tv_title"
                app:layout_constraintStart_toEndOf="@+id/tv_title"
                app:layout_constraintTop_toTopOf="@+id/tv_title"/>
            <TextView
                android:textSize="12sp"
                android:id="@+id/tv_summary"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@+id/tv_title"
                app:layout_constraintTop_toBottomOf="@+id/tv_size"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.cardview.widget.CardView>
    <androidx.cardview.widget.CardView
        android:id="@+id/info_card"
        android:focusable="true"
        android:nextFocusLeft="@null"
        android:nextFocusRight="@null"
        android:nextFocusUp="@+id/analyze_item"
        android:nextFocusDown="@+id/clear_btn"
        android:clickable="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="?attr/analyzer_content_padding"
        android:foreground="@null"
        app:contentPaddingBottom="22dp"
        app:contentPaddingTop="22dp"
        style="?attr/analyzer_card_style">
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:baselineAligned="false">
            <LinearLayout
                android:gravity="end"
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1">
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="18sp"
                    android:ellipsize="end"
                    android:gravity="end"
                    android:id="@+id/empty_file_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:text="@string/fa_empty_file"
                    android:singleLine="true"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    app:autoSizeMaxTextSize="18sp"
                    app:autoSizeMinTextSize="6sp"
                    app:autoSizeStepGranularity="1dp"
                    app:autoSizeTextType="uniform"/>
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="18sp"
                    android:ellipsize="end"
                    android:gravity="end"
                    android:id="@+id/empty_folder_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:text="@string/fa_empty_folder"
                    android:singleLine="true"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    app:autoSizeMaxTextSize="18sp"
                    app:autoSizeMinTextSize="6sp"
                    app:autoSizeStepGranularity="1dp"
                    app:autoSizeTextType="uniform"/>
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="18sp"
                    android:ellipsize="end"
                    android:gravity="end"
                    android:id="@+id/log_file_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:text="@string/fa_log_file"
                    android:singleLine="true"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    app:autoSizeMaxTextSize="18sp"
                    app:autoSizeMinTextSize="6sp"
                    app:autoSizeStepGranularity="1dp"
                    app:autoSizeTextType="uniform"/>
                <androidx.appcompat.widget.AppCompatTextView
                    android:textSize="18sp"
                    android:ellipsize="end"
                    android:gravity="end"
                    android:id="@+id/tmp_file_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/fa_tmp_file"
                    android:singleLine="true"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"
                    app:autoSizeMaxTextSize="18sp"
                    app:autoSizeMinTextSize="6sp"
                    app:autoSizeStepGranularity="1dp"
                    app:autoSizeTextType="uniform"/>
            </LinearLayout>
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="0.75">
                <TextView
                    android:textSize="18sp"
                    android:gravity="start"
                    android:id="@+id/empty_file"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"/>
                <TextView
                    android:textSize="18sp"
                    android:gravity="start"
                    android:id="@+id/empty_folder"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"/>
                <TextView
                    android:textSize="18sp"
                    android:gravity="start"
                    android:id="@+id/log_file"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"/>
                <TextView
                    android:textSize="18sp"
                    android:gravity="start"
                    android:id="@+id/tmp_file"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:paddingStart="18dp"
                    android:paddingEnd="18dp"/>
            </LinearLayout>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
    <Space
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"/>
    <LinearLayout
        android:gravity="center"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="?attr/analyzer_content_padding">
        <ProgressBar
            android:layout_gravity="center"
            android:id="@+id/progressbar"
            android:visibility="gone"
            android:layout_width="30dp"
            android:layout_height="40dp"/>
        <TextView
            android:gravity="bottom|center_horizontal"
            android:layout_gravity="center"
            android:id="@+id/status_text"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <Button
        android:textSize="16sp"
        android:layout_gravity="center"
        android:id="@+id/clear_btn"
        android:nextFocusLeft="@null"
        android:nextFocusRight="@null"
        android:nextFocusUp="@+id/info_card"
        android:nextFocusDown="@+id/analyze_item"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_margin="?attr/analyzer_content_padding"
        android:text="@string/fa_action_clean"
        android:singleLine="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>
</merge>
