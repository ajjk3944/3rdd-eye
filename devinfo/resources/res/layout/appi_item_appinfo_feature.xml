<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="?attr/appi_card_color"
    app:cardCornerRadius="?attr/appi_card_radius"
    app:cardElevation="?attr/appi_card_elevation">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <FrameLayout
            android:id="@+id/head_container"
            android:focusable="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:foreground="?android:attr/selectableItemBackground">
            <TextView
                android:textSize="13sp"
                android:gravity="start|center_vertical"
                android:id="@+id/tv_class"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="36dp"
                android:textAlignment="viewStart"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"/>
        </FrameLayout>
        <LinearLayout
            android:gravity="center"
            android:orientation="horizontal"
            android:background="?android:attr/selectableItemBackground"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:focusable="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:minHeight="34dp"
            android:paddingStart="14dp"
            android:paddingEnd="14dp">
            <TextView
                android:textSize="12sp"
                android:textColor="?android:attr/textColorPrimary"
                android:gravity="start|center_vertical"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/appi_feature_required"
                android:layout_weight="1"/>
            <TextView
                android:textSize="12sp"
                android:textColor="?android:attr/textColorPrimary"
                android:gravity="end|center_vertical"
                android:id="@+id/required"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="2"
                android:textAlignment="viewEnd"/>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
