<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/group_container"
    android:background="?attr/analyzer_bg_item"
    android:paddingTop="?attr/analyzer_content_padding_half"
    android:paddingBottom="?attr/analyzer_content_padding_half"
    android:focusable="true"
    android:nextFocusRight="@+id/checkbox"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="?attr/analyzer_content_padding"
    android:layout_marginTop="?attr/analyzer_content_padding"
    android:layout_marginRight="?attr/analyzer_content_padding"
    android:minHeight="40dp"
    android:paddingStart="?attr/analyzer_content_padding"
    android:paddingEnd="0dp"
    android:layout_marginHorizontal="?attr/analyzer_content_padding"
    android:paddingVertical="?attr/analyzer_content_padding_half">
    <ImageView
        android:id="@+id/expand_arrow"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@null"
        android:layout_marginStart="8dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@+id/group_count"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/fa_ic_arrow_expand"
        app:tint="?android:attr/textColorSecondary"/>
    <TextView
        android:textSize="14sp"
        android:textColor="?android:attr/textColorPrimary"
        android:id="@+id/group_count"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="?attr/analyzer_content_padding_half"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="14sp"
        android:textColor="?android:attr/textColorPrimary"
        android:id="@+id/size"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/checkbox"
        app:layout_constraintTop_toTopOf="parent"/>
    <androidx.appcompat.widget.AppCompatCheckBox
        android:id="@+id/checkbox"
        android:focusable="true"
        android:nextFocusLeft="@+id/group_container"
        android:nextFocusRight="@+id/group_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingStart="0dp"
        android:paddingEnd="?attr/analyzer_content_padding"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="?attr/checkboxStyle"/>
</androidx.constraintlayout.widget.ConstraintLayout>
