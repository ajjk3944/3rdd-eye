<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textSize="13sp"
        android:gravity="center"
        android:id="@+id/tool_widget"
        android:background="@drawable/bg_common_card_ripple_radius"
        android:padding="@dimen/content_padding_half"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/title_widgets"
        android:drawablePadding="2dp"
        android:layout_weight="1"
        app:drawableTopCompat="@drawable/ic_home_widget"/>
    <TextView
        android:textSize="13sp"
        android:gravity="center"
        android:id="@+id/tool_monitor"
        android:background="@drawable/bg_common_card_ripple_radius"
        android:padding="@dimen/content_padding_half"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/content_padding"
        android:layout_marginRight="@dimen/content_padding"
        android:text="@string/home_monitor"
        android:drawablePadding="2dp"
        android:layout_weight="1"
        android:layout_marginHorizontal="@dimen/content_padding"
        app:drawableTopCompat="@drawable/ic_home_monitor"/>
    <TextView
        android:textSize="13sp"
        android:gravity="center"
        android:id="@+id/tool_test"
        android:background="@drawable/bg_common_card_ripple_radius"
        android:padding="@dimen/content_padding_half"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/testes"
        android:drawablePadding="2dp"
        android:layout_weight="1"
        app:drawableTopCompat="@drawable/ic_home_test"/>
</LinearLayout>
