<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:padding="?attr/appa_content_padding"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/details_header"
        android:background="@drawable/appa_bg_card"
        android:padding="?attr/appa_card_inner_padding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="?attr/appa_card_elevation">
        <TextView
            android:textSize="16sp"
            android:textColor="?android:attr/textColorPrimary"
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"/>
        <TextView
            android:textSize="13sp"
            android:textColor="?android:attr/textColorSecondary"
            android:id="@+id/tv_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:alpha="0.8"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:id="@+id/pie_chart_container"
        android:background="@drawable/appa_bg_card"
        android:padding="?attr/appa_card_inner_padding"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="?attr/appa_content_padding"
        android:elevation="?attr/appa_card_elevation">
        <com.github.mikephil.charting.charts.PieChart
            android:id="@+id/pie_chart"
            android:layout_width="match_parent"
            android:layout_height="240dp"
            android:layout_marginLeft="20dp"
            android:layout_marginRight="20dp"
            android:layout_marginHorizontal="20dp"/>
        <TextView
            android:textSize="10sp"
            android:gravity="center"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/appa_rotate_pie_chart"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/content_container"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="?attr/appa_content_padding_half"/>
</LinearLayout>
