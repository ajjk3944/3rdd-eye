<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center"
        android:orientation="vertical"
        android:padding="?attr/dialogPreferredPadding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="13sp"
            android:gravity="center_horizontal"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_padding"
            android:layout_marginBottom="@dimen/content_padding"
            android:text="@string/custom_theme"
            android:drawablePadding="4dp"
            android:contentDescription="@null"
            android:layout_marginVertical="@dimen/content_padding"
            app:drawableTopCompat="@drawable/ic_pro_theme_color_colored"/>
        <TextView
            android:textSize="14sp"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_padding"
            android:text="@string/reward_theme_color_summary"/>
        <TextView
            android:id="@+id/buy_pro"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_padding_double"
            android:text="@string/buy_pro_version"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium"
            style="@style/PrimaryButton.Light"/>
        <TextView
            android:id="@+id/watch_ad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_padding"
            android:text="@string/watch_video_ad"
            android:textAllCaps="false"
            android:fontFamily="sans-serif-medium"
            style="@style/PrimaryButton.Light"/>
        <TextView
            android:gravity="center"
            android:id="@+id/cancel"
            android:background="?attr/selectableItemBackground"
            android:paddingTop="@dimen/content_padding_half"
            android:paddingBottom="@dimen/content_padding_half"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_padding"
            android:text="@string/cancel"
            android:paddingVertical="@dimen/content_padding_half"/>
    </LinearLayout>
</ScrollView>
