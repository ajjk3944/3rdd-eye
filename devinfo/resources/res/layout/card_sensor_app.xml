<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <FrameLayout
        android:id="@+id/sensors"
        android:background="@drawable/bg_common_card"
        android:focusable="true"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:foreground="@drawable/btn_default_bg_without_color"
        android:layout_weight="1"
        android:layout_marginEnd="@dimen/content_padding_half"
        android:elevation="@dimen/common_card_elevation">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_gravity="center"
            android:padding="@dimen/content_padding"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp"
            android:layout_marginVertical="2dp">
            <ImageView
                android:id="@+id/sensor_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_sensors"
                android:contentDescription="@null"
                android:scaleX="1.08"
                android:scaleY="1.08"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorSecondary"
                android:id="@+id/sensor_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:includeFontPadding="false"
                android:layout_marginStart="@dimen/content_padding"
                app:layout_constraintBottom_toTopOf="@+id/sensor_title"
                app:layout_constraintStart_toEndOf="@+id/sensor_icon"
                app:layout_constraintTop_toTopOf="@+id/sensor_icon"
                app:layout_constraintVertical_chainStyle="packed"/>
            <TextView
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorSecondary"
                android:id="@+id/sensor_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/sensors"
                app:layout_constraintBottom_toBottomOf="@+id/sensor_icon"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@+id/sensor_count"
                app:layout_constraintTop_toBottomOf="@+id/sensor_count"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>
    <FrameLayout
        android:id="@+id/apps"
        android:background="@drawable/bg_common_card"
        android:focusable="true"
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:foreground="@drawable/btn_default_bg_without_color"
        android:layout_weight="1"
        android:layout_marginStart="@dimen/content_padding_half"
        android:elevation="@dimen/common_card_elevation">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:padding="@dimen/content_padding"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="2dp"
            android:layout_marginBottom="2dp"
            android:layout_marginVertical="2dp">
            <ImageView
                android:id="@+id/app_icon"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:src="@drawable/ic_apps"
                android:contentDescription="@null"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <TextView
                android:textSize="26sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorSecondary"
                android:id="@+id/app_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:includeFontPadding="false"
                android:layout_marginStart="@dimen/content_padding"
                app:layout_constraintBottom_toTopOf="@+id/app_title"
                app:layout_constraintStart_toEndOf="@+id/app_icon"
                app:layout_constraintTop_toTopOf="@+id/app_icon"
                app:layout_constraintVertical_chainStyle="packed"/>
            <TextView
                android:textSize="14sp"
                android:textStyle="bold"
                android:textColor="?android:attr/textColorSecondary"
                android:id="@+id/app_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/all_apps"
                app:layout_constraintBottom_toBottomOf="@+id/app_icon"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@+id/app_count"
                app:layout_constraintTop_toBottomOf="@+id/app_count"/>
            <ImageView
                android:id="@+id/iv_warning"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_baseline_error"
                android:contentDescription="@null"
                android:translationX="@dimen/content_padding_half"
                android:translationY="@dimen/content_padding_half_negative"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="#8f8f8f"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </FrameLayout>
</merge>
