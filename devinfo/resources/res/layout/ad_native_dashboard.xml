<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="9dp"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageView
        android:id="@+id/ad_icon"
        android:layout_width="54dp"
        android:layout_height="54dp"
        android:src="@color/colorAccent"
        android:contentDescription="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="13sp"
        android:textStyle="bold"
        android:id="@+id/ad_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:singleLine="true"
        android:textAlignment="viewStart"
        android:layout_marginStart="4dp"
        android:layout_marginEnd="6dp"
        app:layout_constraintBottom_toTopOf="@+id/ad_description"
        app:layout_constraintEnd_toStartOf="@+id/ad_button"
        app:layout_constraintStart_toEndOf="@+id/ad_tips"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="12sp"
        android:ellipsize="end"
        android:id="@+id/ad_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="6dp"
        android:layout_marginRight="6dp"
        android:maxLines="4"
        android:fontFamily="sans-serif-condensed-medium"
        android:textAlignment="viewStart"
        android:layout_marginHorizontal="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@+id/ad_button"
        app:layout_constraintStart_toEndOf="@+id/ad_icon"
        app:layout_constraintTop_toBottomOf="@+id/ad_title"/>
    <TextView
        android:textSize="9sp"
        android:textColor="@color/white"
        android:gravity="center"
        android:id="@+id/ad_source"
        android:background="@drawable/bg_ad_source"
        android:paddingLeft="3dp"
        android:paddingTop="1dp"
        android:paddingRight="3dp"
        android:paddingBottom="1dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:paddingHorizontal="3dp"
        android:paddingVertical="1dp"
        app:layout_constraintBottom_toBottomOf="@+id/ad_title"
        app:layout_constraintStart_toEndOf="@+id/ad_icon"
        app:layout_constraintTop_toTopOf="@+id/ad_title"
        app:layout_goneMarginStart="6dp"/>
    <TextView
        android:textSize="9sp"
        android:textColor="@android:color/white"
        android:gravity="center"
        android:id="@+id/ad_tips"
        android:background="@drawable/bg_ad_choice"
        android:paddingLeft="3dp"
        android:paddingTop="1dp"
        android:paddingRight="3dp"
        android:paddingBottom="1dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AD"
        android:fontFamily="sans-serif-medium"
        android:layout_marginStart="2dp"
        android:paddingHorizontal="3dp"
        android:paddingVertical="1dp"
        app:layout_constraintBottom_toBottomOf="@+id/ad_title"
        app:layout_constraintStart_toEndOf="@+id/ad_source"
        app:layout_constraintTop_toTopOf="@+id/ad_title"
        app:layout_goneMarginStart="6dp"/>
    <Button
        android:textSize="12sp"
        android:id="@+id/ad_button"
        android:paddingTop="0dp"
        android:paddingBottom="0dp"
        android:layout_width="wrap_content"
        android:layout_height="34dp"
        android:layout_marginTop="6dp"
        android:maxWidth="100dp"
        android:minWidth="50dp"
        android:singleLine="true"
        android:textAllCaps="false"
        android:paddingStart="6dp"
        android:paddingEnd="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/PrimaryButton"/>
    <FrameLayout
        android:id="@+id/ad_options_container"
        android:background="@color/ad_options_bg"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:maxWidth="100dp"
        android:maxHeight="30dp"
        android:translationX="9dp"
        android:translationY="-9dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
