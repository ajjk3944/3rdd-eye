<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        style="@style/ToolbarStyle.Perspective"/>
    <ScrollView
        android:id="@+id/scroll_view"
        android:paddingTop="@dimen/toolbar_height"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:padding="@dimen/content_padding"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorPrimary"
                android:id="@+id/category_settings"
                android:paddingLeft="@dimen/content_padding"
                android:paddingRight="@dimen/content_padding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/settings"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="@dimen/content_padding"/>
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_padding_half"
                style="@style/CommonCardViewStyle">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:paddingLeft="@dimen/content_padding"
                    android:paddingTop="@dimen/content_padding_half"
                    android:paddingRight="@dimen/content_padding"
                    android:paddingBottom="@dimen/content_padding_half"
                    android:clipToPadding="false"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingHorizontal="@dimen/content_padding"
                    android:paddingVertical="@dimen/content_padding_half">
                    <TextView
                        android:id="@+id/label_alpha"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/transparency"
                        android:paddingVertical="14dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"/>
                    <TextView
                        android:id="@+id/label_text_size"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/text_size"
                        android:paddingVertical="14dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/label_alpha"/>
                    <TextView
                        android:id="@+id/label_spacing"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/spacing"
                        android:paddingVertical="14dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/label_text_size"/>
                    <TextView
                        android:id="@+id/label_text_color"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/text_color"
                        android:paddingVertical="14dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/label_spacing"/>
                    <TextView
                        android:id="@+id/label_touch_mode"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/fixed_position"
                        android:paddingVertical="14dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/label_text_color"/>
                    <ImageView
                        android:id="@+id/btn_helper_touch_mode"
                        android:background="?android:attr/actionBarItemBackground"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_help"
                        android:scaleType="center"
                        android:contentDescription="@null"
                        android:layout_marginStart="3dp"
                        app:layout_constraintBottom_toBottomOf="@+id/label_touch_mode"
                        app:layout_constraintStart_toEndOf="@+id/label_touch_mode"
                        app:layout_constraintTop_toTopOf="@+id/label_touch_mode"/>
                    <TextView
                        android:id="@+id/label_record_status"
                        android:paddingTop="14dp"
                        android:paddingBottom="14dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/record_switch_status"
                        android:paddingVertical="14dp"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/label_touch_mode"/>
                    <ImageView
                        android:id="@+id/btn_helper_record_status"
                        android:background="?android:attr/actionBarItemBackground"
                        android:layout_width="26dp"
                        android:layout_height="26dp"
                        android:src="@drawable/ic_help"
                        android:scaleType="center"
                        android:contentDescription="@null"
                        android:layout_marginStart="3dp"
                        app:layout_constraintBottom_toBottomOf="@+id/label_record_status"
                        app:layout_constraintStart_toEndOf="@+id/label_record_status"
                        app:layout_constraintTop_toTopOf="@+id/label_record_status"/>
                    <androidx.constraintlayout.widget.Barrier
                        android:theme="@style/Theme.MaterialComponents"
                        android:id="@+id/barrier"
                        android:layout_width="wrap_content"
                        android:layout_height="match_parent"
                        app:barrierDirection="end"
                        app:constraint_referenced_ids="label_alpha,label_text_color,label_text_size,label_touch_mode,label_record_status"/>
                    <com.google.android.material.slider.Slider
                        android:theme="@style/Slider"
                        android:value="40"
                        android:id="@+id/slider_transparency"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:valueFrom="0"
                        android:valueTo="100"
                        android:layout_marginStart="6dp"
                        app:layout_constraintBottom_toBottomOf="@+id/label_alpha"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/barrier"
                        app:layout_constraintTop_toTopOf="@+id/label_alpha"/>
                    <com.google.android.material.slider.Slider
                        android:theme="@style/Slider"
                        android:value="14"
                        android:id="@+id/slider_text_size"
                        android:layout_width="0dp"
                        android:layout_height="30dp"
                        android:valueFrom="10"
                        android:valueTo="30"
                        android:layout_marginStart="6dp"
                        app:layout_constraintBottom_toBottomOf="@+id/label_text_size"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/barrier"
                        app:layout_constraintTop_toTopOf="@+id/label_text_size"/>
                    <com.google.android.material.slider.Slider
                        android:theme="@style/Slider"
                        android:value="10"
                        android:id="@+id/slider_spacing"
                        android:layout_width="0dp"
                        android:layout_height="30dp"
                        android:valueFrom="0"
                        android:valueTo="20"
                        android:layout_marginStart="6dp"
                        app:layout_constraintBottom_toBottomOf="@+id/label_spacing"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintStart_toEndOf="@+id/barrier"
                        app:layout_constraintTop_toTopOf="@+id/label_spacing"/>
                    <RadioGroup
                        android:orientation="horizontal"
                        android:id="@+id/radio_group_text_color"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:checkedButton="@+id/radio_text_light"
                        app:layout_constraintBottom_toBottomOf="@+id/label_text_color"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/label_text_color">
                        <RadioButton
                            android:id="@+id/radio_text_light"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="@string/light"/>
                        <RadioButton
                            android:id="@+id/radio_text_dark"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="@string/dark"/>
                    </RadioGroup>
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_fixed_position"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        app:layout_constraintBottom_toBottomOf="@+id/label_touch_mode"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/label_touch_mode"/>
                    <androidx.appcompat.widget.SwitchCompat
                        android:id="@+id/switch_record"
                        android:layout_width="wrap_content"
                        android:layout_height="40dp"
                        app:layout_constraintBottom_toBottomOf="@+id/label_record_status"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="@+id/label_record_status"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="?android:attr/textColorSecondary"
                        android:paddingTop="3dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/monitor_settings_card_tips"
                        android:alpha="0.8"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/label_record_status"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>
            <TextView
                android:textSize="14sp"
                android:textColor="@color/colorPrimary"
                android:id="@+id/category_monitors"
                android:paddingLeft="@dimen/content_padding"
                android:paddingTop="@dimen/content_padding"
                android:paddingRight="@dimen/content_padding"
                android:paddingBottom="@dimen/content_padding_half"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/floating_monitor"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="@dimen/content_padding"/>
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                style="@style/CommonCardViewStyle">
                <LinearLayout
                    android:orientation="vertical"
                    android:paddingTop="@dimen/content_padding_half"
                    android:paddingBottom="@dimen/content_padding_half"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingVertical="@dimen/content_padding_half">
                    <LinearLayout
                        android:gravity="center"
                        android:id="@+id/custom_monitor_entrance"
                        android:background="?android:attr/selectableItemBackground"
                        android:paddingLeft="@dimen/content_padding"
                        android:paddingTop="@dimen/content_padding_half"
                        android:paddingRight="@dimen/content_padding"
                        android:paddingBottom="@dimen/content_padding_half"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="@dimen/content_padding"
                        android:paddingVertical="@dimen/content_padding_half">
                        <TextView
                            android:gravity="center_vertical"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            android:text="@string/custom_monitor"
                            android:paddingStart="0dp"
                            android:paddingEnd="5dp"
                            style="@style/MonitorItemTitle"/>
                        <TextView
                            android:textSize="10sp"
                            android:textColor="?android:attr/textColorPrimary"
                            android:background="@drawable/bg_pro_tag"
                            android:paddingLeft="2dp"
                            android:paddingTop="1dp"
                            android:paddingRight="2dp"
                            android:paddingBottom="1dp"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="PRO"
                            android:alpha="0.7"
                            android:fontFamily="sans-serif-medium"
                            android:layout_marginStart="4dp"
                            android:paddingHorizontal="2dp"
                            android:paddingVertical="1dp"/>
                        <Space
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"/>
                        <ImageView
                            android:layout_gravity="end|center_vertical"
                            android:layout_width="22dp"
                            android:layout_height="22dp"
                            android:src="@drawable/ic_arrow_forward"
                            android:contentDescription="@null"
                            android:alpha="0.6"
                            app:tint="@color/menu_icon_tint_color"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@+id/item_battery"
                        android:background="?android:attr/selectableItemBackground"
                        android:paddingLeft="@dimen/content_padding"
                        android:paddingTop="@dimen/content_padding_half"
                        android:paddingRight="@dimen/content_padding"
                        android:paddingBottom="@dimen/content_padding_half"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="@dimen/content_padding"
                        android:paddingVertical="@dimen/content_padding_half">
                        <TextView
                            android:id="@+id/tv_battery_monitor"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/battery_monitor"
                            android:layout_weight="1"
                            app:layout_constraintBottom_toBottomOf="@+id/battery_switch"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/battery_switch"
                            style="@style/MonitorItemTitle"/>
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/battery_switch"
                            android:background="@null"
                            android:focusable="false"
                            android:clickable="false"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@+id/item_cpu"
                        android:background="?android:attr/selectableItemBackground"
                        android:paddingLeft="@dimen/content_padding"
                        android:paddingTop="@dimen/content_padding_half"
                        android:paddingRight="@dimen/content_padding"
                        android:paddingBottom="@dimen/content_padding_half"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="@dimen/content_padding"
                        android:paddingVertical="@dimen/content_padding_half">
                        <TextView
                            android:id="@+id/tv_cpu_monitor"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/cpu_monitor"
                            android:layout_weight="1"
                            app:layout_constraintBottom_toBottomOf="@+id/battery_switch"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/battery_switch"
                            style="@style/MonitorItemTitle"/>
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/cpu_switch"
                            android:background="@null"
                            android:focusable="false"
                            android:clickable="false"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@+id/item_gpu"
                        android:background="?android:attr/selectableItemBackground"
                        android:paddingLeft="@dimen/content_padding"
                        android:paddingTop="@dimen/content_padding_half"
                        android:paddingRight="@dimen/content_padding"
                        android:paddingBottom="@dimen/content_padding_half"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="@dimen/content_padding"
                        android:paddingVertical="@dimen/content_padding_half">
                        <TextView
                            android:id="@+id/tv_gpu_monitor"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/gpu_monitor"
                            android:layout_weight="1"
                            app:layout_constraintBottom_toBottomOf="@+id/battery_switch"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/battery_switch"
                            style="@style/MonitorItemTitle"/>
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/gpu_switch"
                            android:background="@null"
                            android:focusable="false"
                            android:clickable="false"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@+id/item_ram"
                        android:background="?android:attr/selectableItemBackground"
                        android:paddingLeft="@dimen/content_padding"
                        android:paddingTop="@dimen/content_padding_half"
                        android:paddingRight="@dimen/content_padding"
                        android:paddingBottom="@dimen/content_padding_half"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="@dimen/content_padding"
                        android:paddingVertical="@dimen/content_padding_half">
                        <TextView
                            android:id="@+id/tv_ram_monitor"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/ram_monitor"
                            android:layout_weight="1"
                            app:layout_constraintBottom_toBottomOf="@+id/battery_switch"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/battery_switch"
                            style="@style/MonitorItemTitle"/>
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/ram_switch"
                            android:background="@null"
                            android:focusable="false"
                            android:clickable="false"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@+id/item_fps"
                        android:background="?android:attr/selectableItemBackground"
                        android:paddingLeft="@dimen/content_padding"
                        android:paddingTop="@dimen/content_padding_half"
                        android:paddingRight="@dimen/content_padding"
                        android:paddingBottom="@dimen/content_padding_half"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="@dimen/content_padding"
                        android:paddingVertical="@dimen/content_padding_half">
                        <TextView
                            android:id="@+id/tv_fps_monitor"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/fps_monitor"
                            android:layout_weight="1"
                            app:layout_constraintBottom_toBottomOf="@+id/battery_switch"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/battery_switch"
                            style="@style/MonitorItemTitle"/>
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/fps_switch"
                            android:background="@null"
                            android:focusable="false"
                            android:clickable="false"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@+id/item_signal"
                        android:background="?android:attr/selectableItemBackground"
                        android:paddingLeft="@dimen/content_padding"
                        android:paddingTop="@dimen/content_padding_half"
                        android:paddingRight="@dimen/content_padding"
                        android:paddingBottom="@dimen/content_padding_half"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="@dimen/content_padding"
                        android:paddingVertical="@dimen/content_padding_half">
                        <TextView
                            android:id="@+id/tv_signal_monitor"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/signal_monitor"
                            android:layout_weight="1"
                            app:layout_constraintBottom_toBottomOf="@+id/battery_switch"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/battery_switch"
                            style="@style/MonitorItemTitle"/>
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/signal_switch"
                            android:background="@null"
                            android:focusable="false"
                            android:clickable="false"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                    </LinearLayout>
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@+id/item_speed"
                        android:background="?android:attr/selectableItemBackground"
                        android:paddingLeft="@dimen/content_padding"
                        android:paddingTop="@dimen/content_padding_half"
                        android:paddingRight="@dimen/content_padding"
                        android:paddingBottom="@dimen/content_padding_half"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="@dimen/content_padding"
                        android:paddingVertical="@dimen/content_padding_half">
                        <TextView
                            android:id="@+id/tv_speed"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/net_speed_monitor"
                            android:layout_weight="1"
                            app:layout_constraintBottom_toBottomOf="@+id/battery_switch"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/battery_switch"
                            style="@style/MonitorItemTitle"/>
                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/speed_switch"
                            android:background="@null"
                            android:focusable="false"
                            android:clickable="false"
                            android:layout_width="wrap_content"
                            android:layout_height="40dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
