<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="?attr/appi_content_padding"
            app:cardBackgroundColor="?attr/appi_card_color"
            app:cardCornerRadius="?attr/appi_card_radius"
            app:cardElevation="?attr/appi_card_elevation">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:paddingTop="22dp"
                android:paddingBottom="14dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <ImageView
                    android:layout_gravity="center"
                    android:id="@+id/icon"
                    android:layout_width="54dp"
                    android:layout_height="54dp"
                    android:scaleType="fitCenter"
                    android:contentDescription="@null"
                    android:layout_marginStart="18dp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"/>
                <TextView
                    android:textSize="16sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:id="@+id/app_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="14dp"
                    android:layout_marginRight="14dp"
                    android:lines="1"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginHorizontal="14dp"
                    android:textFontWeight="500"
                    app:autoSizeMaxTextSize="16sp"
                    app:autoSizeMinTextSize="12sp"
                    app:autoSizeTextType="uniform"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/icon"
                    app:layout_constraintTop_toTopOf="parent"/>
                <TextView
                    android:textSize="14sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:id="@+id/pkg_name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="@+id/app_name"
                    app:layout_constraintStart_toStartOf="@+id/app_name"
                    app:layout_constraintTop_toBottomOf="@+id/app_name"/>
                <TextView
                    android:textSize="13sp"
                    android:textColor="?android:attr/textColorSecondary"
                    android:id="@+id/version_info"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="@+id/app_name"
                    app:layout_constraintStart_toStartOf="@+id/app_name"
                    app:layout_constraintTop_toBottomOf="@+id/pkg_name"/>
                <TextView
                    android:textSize="10sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:id="@+id/tag_bit"
                    android:background="@drawable/appi_bg_tag"
                    android:paddingLeft="2dp"
                    android:paddingTop="2dp"
                    android:paddingRight="2dp"
                    android:paddingBottom="2dp"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="4dp"
                    android:maxLines="1"
                    android:includeFontPadding="false"
                    android:paddingHorizontal="2dp"
                    android:paddingVertical="2dp"
                    app:autoSizeMaxTextSize="10sp"
                    app:autoSizeMinTextSize="6sp"
                    app:autoSizeTextType="uniform"
                    app:layout_constraintStart_toStartOf="@+id/version_info"
                    app:layout_constraintTop_toBottomOf="@+id/version_info"/>
                <TextView
                    android:textSize="10sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:ellipsize="end"
                    android:gravity="center"
                    android:id="@+id/tag_api"
                    android:background="@drawable/appi_bg_tag"
                    android:paddingLeft="2dp"
                    android:paddingTop="2dp"
                    android:paddingRight="2dp"
                    android:paddingBottom="2dp"
                    android:layout_width="40dp"
                    android:layout_height="wrap_content"
                    android:maxLines="1"
                    android:includeFontPadding="false"
                    android:layout_marginStart="?attr/appi_content_padding"
                    android:paddingHorizontal="2dp"
                    android:paddingVertical="2dp"
                    app:autoSizeMaxTextSize="10sp"
                    app:autoSizeMinTextSize="6sp"
                    app:autoSizeTextType="uniform"
                    app:layout_constraintStart_toEndOf="@+id/tag_bit"
                    app:layout_constraintTop_toTopOf="@+id/tag_bit"/>
                <HorizontalScrollView
                    android:id="@+id/tags_scroller"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    app:layout_constraintTop_toBottomOf="@+id/tag_bit">
                    <LinearLayout
                        android:orientation="horizontal"
                        android:id="@+id/tags_container"
                        android:paddingLeft="18dp"
                        android:paddingTop="8dp"
                        android:paddingRight="18dp"
                        android:paddingBottom="8dp"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="18dp"
                        android:paddingVertical="8dp">
                        <ImageView
                            android:id="@+id/tag_aab"
                            android:src="@drawable/appi_ic_app_bundle"
                            android:contentDescription="@null"
                            style="@style/AppiAppTag"/>
                        <ImageView
                            android:id="@+id/tag_kotlin"
                            android:src="@drawable/appi_ic_kotlin"
                            android:contentDescription="@string/appi_kotlin_used"
                            style="@style/AppiAppTag"/>
                        <ImageView
                            android:id="@+id/tag_gradle"
                            android:src="@drawable/appi_ic_gradle"
                            android:contentDescription="@null"
                            style="@style/AppiAppTag"/>
                        <ImageView
                            android:id="@+id/tag_flutter"
                            android:src="@drawable/appi_ic_flutter"
                            android:contentDescription="@string/appi_flutter_used"
                            style="@style/AppiAppTag"/>
                        <ImageView
                            android:id="@+id/tag_react_native"
                            android:src="@drawable/appi_ic_react_native"
                            android:contentDescription="@string/appi_react_native_used"
                            style="@style/AppiAppTag"/>
                        <ImageView
                            android:id="@+id/tag_unity"
                            android:src="@drawable/appi_ic_unity"
                            android:contentDescription="@string/appi_unity_used"
                            style="@style/AppiAppTag"/>
                        <ImageView
                            android:id="@+id/tag_unreal_engine"
                            android:src="@drawable/appi_ic_unreal_engine"
                            android:contentDescription="@string/appi_unreal_engine_used"
                            style="@style/AppiAppTag"/>
                    </LinearLayout>
                </HorizontalScrollView>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.cardview.widget.CardView>
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="?attr/appi_content_padding"
            android:layout_marginRight="?attr/appi_content_padding"
            android:layout_marginBottom="?attr/appi_content_padding"
            android:layout_marginHorizontal="?attr/appi_content_padding"
            app:cardBackgroundColor="?attr/appi_card_color"
            app:cardCornerRadius="?attr/appi_card_radius"
            app:cardElevation="?attr/appi_card_elevation">
            <LinearLayout
                android:orientation="vertical"
                android:id="@+id/content"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:divider="@drawable/appi_divider_appinfo"
                android:showDividers="middle"/>
        </androidx.cardview.widget.CardView>
    </LinearLayout>
</ScrollView>
