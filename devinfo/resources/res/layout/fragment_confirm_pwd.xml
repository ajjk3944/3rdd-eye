<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="120dp">
        <LinearLayout
            android:orientation="vertical"
            android:paddingLeft="@dimen/content_padding_double"
            android:paddingRight="@dimen/content_padding_double"
            android:paddingBottom="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/content_padding_double">
            <TextView
                android:layout_marginTop="32dp"
                android:text="@string/create_password"
                style="@style/AccountPageHeaderText"/>
            <TextView
                android:id="@+id/tv_summary"
                android:layout_marginTop="@dimen/content_padding_x1_5"
                android:text="@string/create_password_summary"
                style="@style/AccountPageSummaryText"/>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_marginTop="@dimen/content_padding_triple"
                android:hint="@string/password"
                app:passwordToggleDrawable="@drawable/ic_pwd_eye"
                app:passwordToggleEnabled="true"
                app:startIconDrawable="@drawable/ic_password"
                style="@style/PrimaryFilledTextInputLayout">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"/>
            </com.google.android.material.textfield.TextInputLayout>
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_marginTop="@dimen/content_padding_x1_5"
                android:hint="@string/retype_password"
                app:passwordToggleDrawable="@drawable/ic_pwd_eye"
                app:passwordToggleEnabled="true"
                app:startIconDrawable="@drawable/ic_password"
                style="@style/PrimaryFilledTextInputLayout">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_retype_password"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textPassword"/>
            </com.google.android.material.textfield.TextInputLayout>
        </LinearLayout>
    </ScrollView>
    <com.google.android.material.button.MaterialButton
        android:layout_gravity="bottom"
        android:id="@+id/btn_next_step"
        android:layout_marginLeft="@dimen/content_padding_double"
        android:layout_marginRight="@dimen/content_padding_double"
        android:layout_marginBottom="32dp"
        android:text="@string/next_step"
        android:layout_marginHorizontal="@dimen/content_padding_double"
        style="@style/AccountPrimaryMaterialButton"/>
</FrameLayout>
