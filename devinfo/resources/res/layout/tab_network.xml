<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:padding="@dimen/content_padding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/head_card"
            android:background="@drawable/bg_common_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="@dimen/common_card_elevation"
            android:backgroundTint="@color/bg_primary_card">
            <ImageView
                android:id="@+id/iv_network"
                android:padding="20dp"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:scaleType="fitCenter"
                android:contentDescription="@null"
                android:layout_marginStart="@dimen/content_padding_half"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="?android:attr/textColorPrimary"/>
            <TextView
                android:textSize="18sp"
                android:textColor="?android:attr/textColorPrimary"
                android:id="@+id/network_type"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_padding"
                android:fontFamily="sans-serif-black"
                android:layout_marginStart="12dp"
                app:layout_constraintBottom_toTopOf="@+id/network_name"
                app:layout_constraintStart_toEndOf="@+id/iv_network"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintVertical_chainStyle="packed"/>
            <TextView
                android:textSize="16sp"
                android:textColor="?android:attr/textColorPrimary"
                android:id="@+id/network_name"
                android:background="?android:attr/selectableItemBackground"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintBottom_toTopOf="@+id/signal_strength"
                app:layout_constraintStart_toStartOf="@+id/network_type"
                app:layout_constraintTop_toBottomOf="@+id/network_type"/>
            <TextView
                android:textSize="16sp"
                android:textColor="?android:attr/textColorPrimary"
                android:id="@+id/signal_strength"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/content_padding"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="@+id/network_type"
                app:layout_constraintTop_toBottomOf="@+id/network_name"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <com.liuzh.deviceinfo.view.kv.KvCard
            android:id="@+id/wifi_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_padding"/>
        <com.liuzh.deviceinfo.view.kv.KvCard
            android:id="@+id/mobile_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_padding"/>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/sim_container"
            android:background="@drawable/bg_common_card"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_padding"/>
    </LinearLayout>
</ScrollView>
