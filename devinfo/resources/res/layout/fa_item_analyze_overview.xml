<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:focusable="true"
    android:clickable="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="?attr/analyzer_content_padding"
    android:layout_marginTop="?attr/analyzer_content_padding_half"
    android:layout_marginRight="?attr/analyzer_content_padding"
    android:layout_marginBottom="?attr/analyzer_content_padding_half"
    android:layout_marginHorizontal="?attr/analyzer_content_padding"
    android:layout_marginVertical="?attr/analyzer_content_padding_half"
    style="?attr/analyzer_card_style">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:paddingLeft="?attr/analyzer_content_padding"
        android:paddingTop="?attr/analyzer_content_padding_half"
        android:paddingRight="?attr/analyzer_content_padding"
        android:paddingBottom="?attr/analyzer_content_padding"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="?attr/analyzer_content_padding">
        <com.github.mikephil.charting.charts.PieChart
            android:id="@+id/chart"
            android:layout_width="82dp"
            android:layout_height="82dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <Space
            android:id="@+id/guide_line"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/chart"
            app:layout_constraintTop_toTopOf="parent"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/container1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="0dp"
            app:layout_constraintBottom_toTopOf="@+id/container2"
            app:layout_constraintEnd_toStartOf="@+id/guide_line"
            app:layout_constraintStart_toEndOf="@+id/chart"
            app:layout_constraintTop_toTopOf="@+id/chart"
            app:layout_constraintVertical_chainStyle="packed">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/color1"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:src="@drawable/fa_ic_circle_8dp"
                android:contentDescription="@null"
                app:tint="@color/md_blue_400"/>
            <TextView
                android:textSize="11sp"
                android:textColor="?android:attr/textColorPrimary"
                android:id="@+id/label1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/fa_root_images"
                android:singleLine="true"
                android:alpha="0.8"
                android:layout_marginStart="6dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/container2"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:paddingStart="20dp"
            android:paddingEnd="0dp"
            app:layout_constraintBottom_toTopOf="@+id/container3"
            app:layout_constraintEnd_toStartOf="@+id/guide_line"
            app:layout_constraintStart_toEndOf="@+id/chart"
            app:layout_constraintTop_toBottomOf="@+id/container1">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/color2"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:src="@drawable/fa_ic_circle_8dp"
                android:contentDescription="@null"
                app:tint="@color/md_deep_purple_400"/>
            <TextView
                android:textSize="11sp"
                android:textColor="?android:attr/textColorPrimary"
                android:id="@+id/label2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/fa_root_videos"
                android:singleLine="true"
                android:alpha="0.8"
                android:layout_marginStart="6dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/container3"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingStart="20dp"
            android:paddingEnd="0dp"
            app:layout_constraintBottom_toBottomOf="@+id/chart"
            app:layout_constraintEnd_toStartOf="@+id/guide_line"
            app:layout_constraintStart_toEndOf="@+id/chart"
            app:layout_constraintTop_toBottomOf="@+id/container2">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/color3"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:src="@drawable/fa_ic_circle_8dp"
                android:contentDescription="@null"
                app:tint="@color/md_deep_purple_400"/>
            <TextView
                android:textSize="11sp"
                android:textColor="?android:attr/textColorPrimary"
                android:id="@+id/label3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/fa_root_audio"
                android:singleLine="true"
                android:alpha="0.8"
                android:layout_marginStart="6dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/container4"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingStart="6dp"
            android:paddingEnd="0dp"
            app:layout_constraintBottom_toTopOf="@+id/container5"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/guide_line"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/color4"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:src="@drawable/fa_ic_circle_8dp"
                android:contentDescription="@null"
                app:tint="@color/md_pink_400"/>
            <TextView
                android:textSize="11sp"
                android:textColor="?android:attr/textColorPrimary"
                android:id="@+id/label4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/fa_root_documents"
                android:singleLine="true"
                android:alpha="0.8"
                android:layout_marginStart="6dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/container5"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="4dp"
            android:paddingStart="6dp"
            android:paddingEnd="0dp"
            app:layout_constraintBottom_toTopOf="@+id/container6"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/guide_line"
            app:layout_constraintTop_toBottomOf="@+id/container4">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/color5"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:src="@drawable/fa_ic_circle_8dp"
                android:contentDescription="@null"
                app:tint="@color/md_deep_orange_400"/>
            <TextView
                android:textSize="11sp"
                android:textColor="?android:attr/textColorPrimary"
                android:id="@+id/label5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/fa_root_apk"
                android:singleLine="true"
                android:alpha="0.8"
                android:layout_marginStart="6dp"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/container6"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:paddingStart="6dp"
            android:paddingEnd="0dp"
            app:layout_constraintBottom_toBottomOf="@+id/chart"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/guide_line"
            app:layout_constraintTop_toBottomOf="@+id/container5">
            <ImageView
                android:layout_gravity="center"
                android:id="@+id/color6"
                android:layout_width="8dp"
                android:layout_height="8dp"
                android:src="@drawable/fa_ic_circle_8dp"
                android:contentDescription="@null"
                app:tint="@color/md_grey_400"/>
            <TextView
                android:textSize="11sp"
                android:textColor="?android:attr/textColorPrimary"
                android:id="@+id/label6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/fa_others"
                android:singleLine="true"
                android:alpha="0.8"
                android:layout_marginStart="6dp"/>
        </LinearLayout>
        <TextView
            android:textSize="10sp"
            android:ellipsize="end"
            android:layout_gravity="end|bottom"
            android:id="@+id/tv_path"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/fa_storage_analyze_overview_summary"
            android:maxLines="2"
            android:includeFontPadding="false"
            android:translationY="5dp"
            android:paddingStart="90dp"
            android:paddingEnd="0dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/container6"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
