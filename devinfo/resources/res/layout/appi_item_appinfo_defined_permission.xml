<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="?attr/appi_card_color"
    app:cardCornerRadius="?attr/appi_card_radius"
    app:cardElevation="?attr/appi_card_elevation">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <FrameLayout
            android:id="@+id/head_container"
            android:focusable="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:foreground="?android:attr/selectableItemBackground">
            <TextView
                android:textSize="13sp"
                android:gravity="start|center_vertical"
                android:id="@+id/tv_permission"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="36dp"
                android:textAlignment="viewStart"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"
                android:layout_marginEnd="40dp"/>
            <ImageView
                android:layout_gravity="end|center_vertical"
                android:id="@+id/arrow"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/appi_ic_arrow_drop_down"
                android:scaleType="center"
                android:contentDescription="@null"
                app:tint="#ff999999"/>
        </FrameLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/details_container"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="@drawable/appi_divider_appinfo"
            android:showDividers="middle">
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:background="?android:attr/selectableItemBackground"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:focusable="true"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="34dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">
                <TextView
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:gravity="start|center_vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/appi_name"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:gravity="end|center_vertical"
                    android:id="@+id/name"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:textAlignment="viewEnd"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:background="?android:attr/selectableItemBackground"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:focusable="true"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="34dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">
                <TextView
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:gravity="start|center_vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/appi_description"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:gravity="end|center_vertical"
                    android:id="@+id/description"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:textAlignment="viewEnd"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:background="?android:attr/selectableItemBackground"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:focusable="true"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="34dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">
                <TextView
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:gravity="start|center_vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/appi_defined_permissions_group"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:gravity="end|center_vertical"
                    android:id="@+id/group"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:textAlignment="viewEnd"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:background="?android:attr/selectableItemBackground"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:focusable="true"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="34dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">
                <TextView
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:gravity="start|center_vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/appi_protection_level"
                    android:layout_weight="1"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:gravity="end|center_vertical"
                    android:id="@+id/protection_level"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:textAlignment="viewEnd"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
