<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageView
        android:id="@+id/launcher_icon"
        android:padding="2dp"
        android:layout_width="50dp"
        android:layout_height="50dp"
        android:src="@mipmap/ic_icon_eas"
        android:contentDescription="@null"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="16sp"
        android:textColor="?android:attr/textColorPrimary"
        android:id="@+id/launcher_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/app_name_eas"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintBottom_toTopOf="@+id/launcher_slogan"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/launcher_icon"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="14sp"
        android:textColor="?android:attr/textColorSecondary"
        android:id="@+id/launcher_slogan"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/slogan_eas"
        android:paddingStart="12dp"
        android:paddingEnd="12dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/launcher_icon"
        app:layout_constraintTop_toBottomOf="@+id/launcher_title"/>
</merge>
