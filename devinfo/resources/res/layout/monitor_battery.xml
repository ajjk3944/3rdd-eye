<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="@dimen/monitor_padding"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <TextView
        android:id="@+id/label_level"
        android:text="@string/battery_level"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/MonitorLabel"/>
    <TextView
        android:id="@+id/label_current"
        android:layout_marginTop="2dp"
        android:text="@string/battery_current"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/label_level"
        style="@style/MonitorLabel"/>
    <TextView
        android:id="@+id/label_voltage"
        android:layout_marginTop="2dp"
        android:text="@string/voltage"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/label_current"
        style="@style/MonitorLabel"/>
    <TextView
        android:id="@+id/label_temperature"
        android:layout_marginTop="2dp"
        android:text="@string/temperature"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/label_voltage"
        style="@style/MonitorLabel"/>
    <TextView
        android:id="@+id/label_power"
        android:layout_marginTop="2dp"
        android:text="@string/battery_power"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/label_temperature"
        style="@style/MonitorLabel"/>
    <androidx.constraintlayout.widget.Barrier
        android:id="@+id/barrier"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        app:barrierDirection="end"
        app:constraint_referenced_ids="label_level,label_current,label_voltage,label_temperature"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:id="@+id/val_level"
        app:layout_constraintBaseline_toBaselineOf="@+id/label_level"
        app:layout_constraintStart_toEndOf="@+id/barrier"
        style="@style/MonitorValue"/>
    <TextView
        android:id="@+id/val_current"
        app:layout_constraintBaseline_toBaselineOf="@+id/label_current"
        app:layout_constraintStart_toEndOf="@+id/barrier"
        style="@style/MonitorValue"/>
    <TextView
        android:id="@+id/val_voltage"
        app:layout_constraintBaseline_toBaselineOf="@+id/label_voltage"
        app:layout_constraintStart_toEndOf="@+id/barrier"
        style="@style/MonitorValue"/>
    <TextView
        android:id="@+id/val_temperature"
        app:layout_constraintBaseline_toBaselineOf="@+id/label_temperature"
        app:layout_constraintStart_toEndOf="@+id/barrier"
        style="@style/MonitorValue"/>
    <TextView
        android:id="@+id/val_power"
        app:layout_constraintBaseline_toBaselineOf="@+id/label_power"
        app:layout_constraintStart_toEndOf="@+id/barrier"
        style="@style/MonitorValue"/>
</androidx.constraintlayout.widget.ConstraintLayout>
