<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="120dp">
        <LinearLayout
            android:orientation="vertical"
            android:paddingLeft="@dimen/content_padding_double"
            android:paddingRight="@dimen/content_padding_double"
            android:paddingBottom="24dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingHorizontal="@dimen/content_padding_double">
            <TextView
                android:id="@+id/tv_title"
                android:layout_marginTop="32dp"
                android:text="@string/create_account"
                style="@style/AccountPageHeaderText"/>
            <com.google.android.material.textfield.TextInputLayout
                android:id="@+id/input_email_layout"
                android:layout_marginTop="@dimen/content_padding_triple"
                android:hint="@string/email"
                app:startIconDrawable="@drawable/ic_email"
                style="@style/PrimaryFilledTextInputLayout">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/input_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textEmailAddress"/>
            </com.google.android.material.textfield.TextInputLayout>
            <LinearLayout
                android:orientation="horizontal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_padding_x1_5"
                android:baselineAligned="false">
                <com.google.android.material.textfield.TextInputLayout
                    android:layout_width="0dp"
                    android:hint="@string/verification_code"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/content_padding"
                    app:startIconDrawable="@drawable/ic_protect"
                    style="@style/PrimaryFilledTextInputLayout">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/input_vcode"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:maxLength="8"
                        android:digits="@string/vcode_digits"
                        android:inputType="textCapCharacters"/>
                </com.google.android.material.textfield.TextInputLayout>
                <FrameLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent">
                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/btn_get_code"
                        style="@style/GetCodeButton"/>
                    <ProgressBar
                        android:layout_gravity="center"
                        android:id="@+id/progressbar_get_code"
                        android:visibility="gone"
                        android:layout_width="24dp"
                        android:layout_height="24dp"/>
                </FrameLayout>
            </LinearLayout>
            <TextView
                android:textSize="14sp"
                android:id="@+id/text_login_now"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_padding_double"
                android:text="@string/already_have_an_account"/>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/checkbox_container"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="26dp">
                <CheckBox
                    android:id="@+id/checkbox_agree"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:minHeight="0dp"
                    android:translationX="@dimen/checkbox_trans_x"
                    android:buttonTint="?android:attr/textColorHint"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorHint"
                    android:layout_gravity="center"
                    android:id="@+id/tv_agree_content"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginStart="-4dp"/>
            </LinearLayout>
            <ImageView
                android:id="@+id/hint_arrow"
                android:visibility="invisible"
                android:layout_width="40dp"
                android:layout_height="wrap_content"
                android:src="@drawable/ic_arrow_drop_down"
                android:contentDescription="@null"
                android:translationX="@dimen/checkbox_trans_x"
                android:rotation="180"
                app:tint="@color/black_white"/>
        </LinearLayout>
    </ScrollView>
    <com.google.android.material.button.MaterialButton
        android:layout_gravity="bottom"
        android:id="@+id/btn_next_step"
        android:layout_marginLeft="20dp"
        android:layout_marginRight="20dp"
        android:layout_marginBottom="40dp"
        android:text="@string/next_step"
        android:layout_marginHorizontal="20dp"
        style="@style/AccountPrimaryMaterialButton"/>
</FrameLayout>
