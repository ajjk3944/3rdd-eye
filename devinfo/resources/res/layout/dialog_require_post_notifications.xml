<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="vertical"
        android:paddingLeft="?attr/dialogPreferredPadding"
        android:paddingTop="@dimen/content_padding_half"
        android:paddingRight="?attr/dialogPreferredPadding"
        android:clipChildren="false"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="?attr/dialogPreferredPadding">
        <ImageView
            android:layout_gravity="center"
            android:layout_width="80dp"
            android:layout_height="64dp"
            android:layout_marginTop="@dimen/content_padding"
            android:layout_marginBottom="@dimen/content_padding"
            android:src="@drawable/ic_noti_tips"
            android:contentDescription="@null"
            android:layout_marginVertical="@dimen/content_padding"/>
        <TextView
            android:textSize="15sp"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_padding_half"
            android:text="@string/require_post_notifications_permission_dialog_msg"/>
        <TextView
            android:textSize="15sp"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_padding"
            android:text="@string/device_overview"
            android:drawablePadding="@dimen/content_padding_half"
            app:drawableStartCompat="@drawable/bg_dot"
            app:drawableTint="@color/menu_icon_tint_color"/>
        <TextView
            android:textSize="13sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_notification_summary"/>
        <TextView
            android:textSize="15sp"
            android:textColor="?android:attr/textColorPrimary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_padding"
            android:text="@string/settings_new_app_notification_title"
            android:drawablePadding="@dimen/content_padding_half"
            app:drawableStartCompat="@drawable/bg_dot"
            app:drawableTint="@color/menu_icon_tint_color"/>
        <TextView
            android:textSize="13sp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/settings_new_app_notification_summary"/>
        <LinearLayout
            android:orientation="horizontal"
            android:clipChildren="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_padding_double"
            android:layout_marginBottom="@dimen/content_padding_x1_5">
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_cancel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/cancel"
                android:layout_weight="1"
                android:layout_marginEnd="@dimen/content_padding_half"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"/>
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_grant"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:text="@string/grant"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/content_padding_half"/>
        </LinearLayout>
    </LinearLayout>
</ScrollView>
