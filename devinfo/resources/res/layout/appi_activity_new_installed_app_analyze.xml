<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        style="?attr/appi_toolbar_style"/>
    <ScrollView
        android:id="@+id/scrollview"
        android:paddingTop="?attr/actionBarSize"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:padding="?attr/appi_content_padding"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:animateLayoutChanges="true">
            <androidx.cardview.widget.CardView
                android:id="@+id/info_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:foreground="?android:attr/selectableItemBackground"
                app:cardBackgroundColor="?attr/appi_card_color"
                app:cardCornerRadius="?attr/appi_card_radius"
                app:cardElevation="?attr/appi_card_elevation">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/info_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:paddingTop="14dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingStart="14dp"
                        android:paddingEnd="14dp">
                        <ImageView
                            android:id="@+id/icon"
                            android:layout_width="60dp"
                            android:layout_height="60dp"
                            android:contentDescription="@null"
                            android:layout_marginStart="10dp"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"/>
                        <TextView
                            android:textSize="16sp"
                            android:textColor="?android:attr/textColorPrimary"
                            android:id="@+id/app_name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:textAlignment="viewStart"
                            android:layout_marginStart="16dp"
                            android:textFontWeight="500"
                            app:layout_constraintBottom_toTopOf="@+id/pkg_name"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toEndOf="@+id/icon"
                            app:layout_constraintTop_toTopOf="parent"/>
                        <TextView
                            android:textSize="14sp"
                            android:textColor="?android:attr/textColorPrimary"
                            android:id="@+id/pkg_name"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            app:layout_constraintBottom_toTopOf="@+id/version"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="@+id/app_name"
                            app:layout_constraintTop_toBottomOf="@+id/app_name"/>
                        <TextView
                            android:textSize="13sp"
                            android:id="@+id/version"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            app:layout_constraintBottom_toTopOf="@+id/app_size"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="@+id/app_name"
                            app:layout_constraintTop_toBottomOf="@+id/pkg_name"/>
                        <TextView
                            android:textSize="13sp"
                            android:id="@+id/app_size"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="@+id/app_name"
                            app:layout_constraintTop_toBottomOf="@+id/version"/>
                        <LinearLayout
                            android:orientation="horizontal"
                            android:id="@+id/tags_container"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="4dp"
                            android:layout_marginBottom="4dp"
                            android:layout_marginVertical="4dp"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="@+id/app_name"
                            app:layout_constraintTop_toBottomOf="@+id/app_size">
                            <TextView
                                android:textSize="8sp"
                                android:textColor="?android:attr/textColorPrimary"
                                android:gravity="center"
                                android:id="@+id/target_api"
                                android:background="@drawable/appi_bg_tag"
                                android:paddingLeft="5dp"
                                android:paddingTop="3dp"
                                android:paddingRight="5dp"
                                android:paddingBottom="3dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:includeFontPadding="false"
                                android:textAllCaps="true"
                                android:fontFamily="sans-serif-medium"
                                android:paddingHorizontal="5dp"
                                android:paddingVertical="3dp"
                                app:layout_constraintStart_toStartOf="@+id/icon"
                                app:layout_constraintTop_toTopOf="@+id/icon"/>
                            <TextView
                                android:textSize="8sp"
                                android:textColor="?android:attr/textColorPrimary"
                                android:gravity="center"
                                android:id="@+id/native_lib"
                                android:background="@drawable/appi_bg_tag"
                                android:paddingLeft="5dp"
                                android:paddingTop="3dp"
                                android:paddingRight="5dp"
                                android:paddingBottom="3dp"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:includeFontPadding="false"
                                android:textAllCaps="true"
                                android:fontFamily="sans-serif-medium"
                                android:layout_marginStart="6dp"
                                android:paddingHorizontal="5dp"
                                android:paddingVertical="3dp"
                                app:layout_constraintStart_toStartOf="@+id/icon"
                                app:layout_constraintTop_toTopOf="@+id/icon"/>
                        </LinearLayout>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
            <androidx.cardview.widget.CardView
                android:id="@+id/ad_container"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="?attr/appi_content_padding"
                app:cardBackgroundColor="?attr/appi_card_color"
                app:cardCornerRadius="?attr/appi_card_radius"
                app:cardElevation="?attr/appi_card_elevation"/>
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="?attr/appi_content_padding"
                android:minHeight="60dp"
                app:cardBackgroundColor="?attr/appi_card_color"
                app:cardCornerRadius="?attr/appi_card_radius"
                app:cardElevation="?attr/appi_card_elevation">
                <LinearLayout
                    android:orientation="vertical"
                    android:id="@+id/permission_content"
                    android:paddingTop="6dp"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <TextView
                        android:textColor="?android:attr/textColorPrimary"
                        android:paddingLeft="14dp"
                        android:paddingTop="5dp"
                        android:paddingRight="14dp"
                        android:paddingBottom="5dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="@string/appi_string_sensitive_permission"
                        android:fontFamily="sans-serif-medium"
                        android:paddingHorizontal="14dp"
                        android:paddingVertical="5dp"/>
                    <TextView
                        android:textColor="@android:color/holo_red_light"
                        android:id="@+id/permission_sub_title"
                        android:paddingLeft="14dp"
                        android:paddingRight="14dp"
                        android:paddingBottom="8dp"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:paddingHorizontal="14dp"/>
                    <View
                        android:id="@+id/divider"
                        android:background="#28666666"
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginLeft="14dp"
                        android:layout_marginRight="14dp"
                        android:layout_marginHorizontal="14dp"/>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>
    </ScrollView>
</FrameLayout>
