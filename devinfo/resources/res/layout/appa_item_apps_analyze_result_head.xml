<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="?attr/appa_content_padding"
    android:layout_marginTop="?attr/appa_content_padding_half"
    android:layout_marginRight="?attr/appa_content_padding"
    android:layout_marginBottom="?attr/appa_content_padding_half"
    android:layout_marginHorizontal="?attr/appa_content_padding"
    android:layout_marginVertical="?attr/appa_content_padding_half"
    app:cardBackgroundColor="?attr/appa_card_color"
    app:cardCornerRadius="?attr/appa_card_radius"
    app:cardElevation="?attr/appa_card_elevation">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:orientation="vertical"
        android:padding="?attr/appa_card_inner_padding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.constraintlayout.widget.Guideline
            android:orientation="vertical"
            android:id="@+id/guideline_vertical_center"
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            app:layout_constraintGuide_percent="0.5"/>
        <TextView
            android:textSize="16sp"
            android:textColor="?android:attr/textColorPrimary"
            android:id="@+id/tv_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/appa_analyze_result"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed"/>
        <TextView
            android:textSize="16sp"
            android:textColor="#f64c4c"
            android:id="@+id/tv_total_size"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="4dp"
            app:layout_constraintBottom_toBottomOf="@+id/tv_title"
            app:layout_constraintEnd_toStartOf="@+id/apk_file_tips"
            app:layout_constraintTop_toTopOf="@+id/tv_title"/>
        <TextView
            android:textSize="10sp"
            android:textColor="?android:attr/textColorSecondary"
            android:id="@+id/apk_file_tips"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/appa_apk_total_size"
            app:layout_constraintBaseline_toBaselineOf="@+id/tv_total_size"
            app:layout_constraintEnd_toEndOf="parent"/>
        <TextView
            android:textSize="12sp"
            android:id="@+id/tv_total_apps"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_title"/>
        <TextView
            android:textSize="12sp"
            android:textColor="?android:attr/textColorPrimary"
            android:gravity="center_vertical"
            android:id="@+id/tv_success"
            android:layout_width="0dp"
            android:layout_height="16dp"
            android:layout_marginTop="16dp"
            android:text="@string/appa_analyze_success"
            android:singleLine="true"
            android:alpha="0.7"
            app:layout_constraintEnd_toStartOf="@+id/tv_success_count"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_total_apps"/>
        <TextView
            android:textSize="12sp"
            android:textColor="#2bb74e"
            android:gravity="center"
            android:id="@+id/tv_success_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="6dp"
            android:paddingEnd="0dp"
            app:layout_constraintBottom_toBottomOf="@+id/tv_success"
            app:layout_constraintEnd_toStartOf="@+id/guideline_vertical_center"
            app:layout_constraintStart_toEndOf="@+id/tv_success"
            app:layout_constraintTop_toTopOf="@+id/tv_success"/>
        <TextView
            android:textSize="12sp"
            android:textColor="?android:attr/textColorPrimary"
            android:gravity="center_vertical"
            android:id="@+id/tv_failed"
            android:layout_width="0dp"
            android:layout_height="16dp"
            android:text="@string/appa_analyze_failed"
            android:singleLine="true"
            android:alpha="0.7"
            app:layout_constraintEnd_toStartOf="@+id/tv_failed_count"
            app:layout_constraintStart_toEndOf="@+id/guideline_vertical_center"
            app:layout_constraintTop_toTopOf="@+id/tv_success"/>
        <TextView
            android:textSize="12sp"
            android:textColor="#e33030"
            android:gravity="center"
            android:id="@+id/tv_failed_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="6dp"
            android:paddingEnd="0dp"
            app:layout_constraintBottom_toBottomOf="@+id/tv_failed"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tv_failed"
            app:layout_constraintTop_toTopOf="@+id/tv_failed"/>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="12sp"
            android:textColor="?android:attr/textColorPrimary"
            android:gravity="center_vertical"
            android:id="@+id/tv_sys_apps"
            android:layout_width="0dp"
            android:layout_height="16dp"
            android:layout_marginTop="8dp"
            android:text="@string/appa_system_apps"
            android:singleLine="true"
            android:alpha="0.7"
            app:layout_constraintEnd_toStartOf="@+id/tv_sys_apps_count"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/tv_success"/>
        <TextView
            android:textSize="12sp"
            android:textColor="?android:attr/textColorPrimary"
            android:gravity="center"
            android:id="@+id/tv_sys_apps_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="6dp"
            android:paddingEnd="0dp"
            app:layout_constraintBottom_toBottomOf="@+id/tv_sys_apps"
            app:layout_constraintEnd_toStartOf="@+id/guideline_vertical_center"
            app:layout_constraintStart_toEndOf="@+id/tv_sys_apps"
            app:layout_constraintTop_toTopOf="@+id/tv_sys_apps"/>
        <TextView
            android:textSize="12sp"
            android:textColor="?android:attr/textColorPrimary"
            android:gravity="center_vertical"
            android:id="@+id/tv_user_apps"
            android:layout_width="0dp"
            android:layout_height="16dp"
            android:layout_marginTop="8dp"
            android:text="@string/appa_user_apps"
            android:singleLine="true"
            android:alpha="0.7"
            app:layout_constraintEnd_toStartOf="@+id/tv_user_apps_count"
            app:layout_constraintStart_toEndOf="@+id/guideline_vertical_center"
            app:layout_constraintTop_toBottomOf="@+id/tv_failed"/>
        <TextView
            android:textSize="12sp"
            android:textColor="?android:attr/textColorPrimary"
            android:gravity="center"
            android:id="@+id/tv_user_apps_count"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:fontFamily="sans-serif-medium"
            android:paddingStart="6dp"
            android:paddingEnd="0dp"
            app:layout_constraintBottom_toBottomOf="@+id/tv_user_apps"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tv_user_apps"
            app:layout_constraintTop_toTopOf="@+id/tv_user_apps"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
