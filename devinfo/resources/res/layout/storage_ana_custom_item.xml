<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/custom_view"
    android:background="?android:attr/selectableItemBackground"
    android:paddingLeft="@dimen/content_padding"
    android:paddingTop="@dimen/content_padding"
    android:paddingRight="@dimen/content_padding"
    android:paddingBottom="@dimen/content_padding_half"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/content_padding">
    <ImageView
        android:id="@+id/icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:src="@mipmap/ic_icon_eas"
        android:contentDescription="@null"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@+id/title"/>
    <TextView
        android:textSize="18sp"
        android:textColor="?android:attr/textColorPrimary"
        android:id="@+id/title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/app_name_eas"
        android:singleLine="true"
        android:fontFamily="sans-serif-medium"
        android:layout_marginStart="@dimen/content_padding"
        app:layout_constraintBottom_toTopOf="@+id/summary"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/icon"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:id="@+id/summary"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/slogan_eas_clean_files"
        app:layout_constraintBottom_toTopOf="@+id/more_detail"
        app:layout_constraintEnd_toEndOf="@+id/title"
        app:layout_constraintStart_toStartOf="@+id/title"
        app:layout_constraintTop_toBottomOf="@+id/title"/>
    <TextView
        android:textSize="14sp"
        android:gravity="center"
        android:layout_gravity="center"
        android:id="@+id/more_detail"
        android:paddingTop="6dp"
        android:paddingBottom="6dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:text="@string/download"
        android:fontFamily="sans-serif-medium"
        android:paddingVertical="6dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/summary"/>
    <ImageView
        android:id="@+id/iv_more_detail"
        android:layout_width="18dp"
        android:layout_height="18dp"
        android:src="@drawable/fa_ic_arrow_forward"
        android:contentDescription="@null"
        android:alpha="0.6"
        android:rotation="@integer/fa_rtl_rotation_compat"
        android:layout_marginStart="4dp"
        app:layout_constraintBottom_toBottomOf="@+id/more_detail"
        app:layout_constraintStart_toEndOf="@+id/more_detail"
        app:layout_constraintTop_toTopOf="@+id/more_detail"/>
    <TextView
        android:textSize="10sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:background="@drawable/bg_ad_choice"
        android:paddingLeft="4dp"
        android:paddingTop="2dp"
        android:paddingRight="4dp"
        android:paddingBottom="2dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="AD"
        android:paddingHorizontal="4dp"
        android:paddingVertical="2dp"
        app:layout_constraintBottom_toBottomOf="@+id/title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@+id/title"/>
</androidx.constraintlayout.widget.ConstraintLayout>
