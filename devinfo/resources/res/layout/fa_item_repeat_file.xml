<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/item_container"
    android:background="?attr/analyzer_bg_item"
    android:paddingTop="?attr/analyzer_content_padding"
    android:paddingBottom="?attr/analyzer_content_padding"
    android:focusable="true"
    android:nextFocusRight="@+id/checkbox"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="?attr/analyzer_content_padding"
    android:layout_marginRight="?attr/analyzer_content_padding"
    android:paddingStart="?attr/analyzer_content_padding"
    android:paddingEnd="0dp"
    android:layout_marginHorizontal="?attr/analyzer_content_padding"
    android:paddingVertical="?attr/analyzer_content_padding">
    <ImageView
        android:id="@+id/icon"
        android:background="@drawable/fa_bg_large_file_size"
        android:layout_width="@dimen/icon_size"
        android:layout_height="@dimen/icon_size"
        android:scaleType="center"
        android:contentDescription="@null"
        android:layout_marginStart="?attr/analyzer_content_padding_half"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <ImageView
        android:id="@+id/thumbnail_icon"
        android:visibility="gone"
        android:layout_width="@dimen/icon_size"
        android:layout_height="@dimen/icon_size"
        android:scaleType="centerCrop"
        android:contentDescription="@null"
        app:layout_constraintBottom_toBottomOf="@+id/icon"
        app:layout_constraintLeft_toLeftOf="@+id/icon"
        app:layout_constraintRight_toRightOf="@+id/icon"
        app:layout_constraintTop_toTopOf="@+id/icon"/>
    <TextView
        android:textSize="14sp"
        android:textColor="?android:attr/textColorPrimary"
        android:ellipsize="middle"
        android:id="@+id/name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="12dp"
        android:layout_marginRight="12dp"
        android:singleLine="true"
        android:textAlignment="viewStart"
        android:layout_marginHorizontal="12dp"
        app:layout_constraintEnd_toStartOf="@+id/checkbox"
        app:layout_constraintStart_toEndOf="@+id/icon"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="12sp"
        android:textColor="?android:attr/textColorSecondary"
        android:ellipsize="middle"
        android:id="@+id/path"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:singleLine="true"
        android:textAlignment="viewStart"
        app:layout_constraintEnd_toEndOf="@+id/name"
        app:layout_constraintStart_toStartOf="@+id/name"
        app:layout_constraintTop_toBottomOf="@+id/name"/>
    <TextView
        android:textSize="12sp"
        android:textColor="?android:attr/textColorSecondary"
        android:id="@+id/time"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        app:layout_constraintStart_toStartOf="@+id/name"
        app:layout_constraintTop_toBottomOf="@+id/path"/>
    <TextView
        android:textSize="10sp"
        android:textColor="?android:attr/textColorSecondary"
        android:id="@+id/size"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@+id/time"
        app:layout_constraintEnd_toEndOf="@+id/name"
        app:layout_constraintTop_toTopOf="@+id/time"/>
    <androidx.appcompat.widget.AppCompatCheckBox
        android:id="@+id/checkbox"
        android:nextFocusLeft="@+id/item_container"
        android:nextFocusRight="@+id/item_container"
        android:nextFocusUp="@+id/item_container"
        android:layout_width="wrap_content"
        android:layout_height="0dp"
        android:paddingStart="0dp"
        android:paddingEnd="?attr/analyzer_content_padding"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="?attr/checkboxStyle"/>
    <TextView
        android:textSize="12sp"
        android:textColor="#000"
        android:id="@+id/warning"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/fa_repeat_file_dangerous_warning"
        app:layout_constraintStart_toStartOf="@+id/name"
        app:layout_constraintTop_toBottomOf="@+id/time"/>
</androidx.constraintlayout.widget.ConstraintLayout>
