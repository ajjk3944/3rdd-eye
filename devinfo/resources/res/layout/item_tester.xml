<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@drawable/bg_common_card"
    android:padding="@dimen/content_padding"
    android:focusable="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/content_padding_half"
    android:foreground="@drawable/btn_default_bg_without_color"
    android:elevation="@dimen/common_card_elevation">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/icon"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:contentDescription="@null"
            app:tint="#999999"/>
        <TextView
            android:textSize="16sp"
            android:textStyle="bold"
            android:id="@+id/name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:textAlignment="viewStart"
            android:layout_marginStart="15dp"/>
        <ImageView
            android:id="@+id/status"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:src="@drawable/ic_test_state_default"
            android:contentDescription="@null"
            app:tint="@color/test_default"/>
        <TextView
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="@color/test_success"
            android:gravity="center"
            android:id="@+id/text"
            android:visibility="gone"
            android:layout_width="25dp"
            android:layout_height="25dp"/>
    </LinearLayout>
</FrameLayout>
