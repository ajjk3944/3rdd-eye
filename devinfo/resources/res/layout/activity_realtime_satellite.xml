<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/root_container"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/ToolbarStyle.Perspective"/>
    <ScrollView
        android:id="@+id/scrollview"
        android:paddingTop="@dimen/toolbar_height"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginBottom="4dp"
        app:layout_constraintBottom_toTopOf="@+id/btm_ad_container"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_goneMarginBottom="0dp">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:padding="@dimen/content_padding"
            android:clipChildren="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:animateLayoutChanges="true">
            <FrameLayout
                android:id="@+id/sky_container"
                android:background="@drawable/bg_common_card"
                android:padding="@dimen/content_padding"
                android:clipChildren="false"
                android:clipToPadding="false"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:elevation="@dimen/common_card_elevation"
                app:layout_constraintDimensionRatio="1:1"
                app:layout_constraintTop_toTopOf="parent">
                <com.liuzh.deviceinfo.view.GpsSkyView
                    android:id="@+id/sky_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_margin="6dp"/>
            </FrameLayout>
            <FrameLayout
                android:id="@+id/mid_ad_container"
                android:background="@drawable/bg_common_card"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_padding"
                app:layout_constraintTop_toBottomOf="@+id/sky_container"/>
            <FrameLayout
                android:id="@+id/legend_container"
                android:background="@drawable/bg_common_card"
                android:saveEnabled="false"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:layout_marginTop="@dimen/content_padding"
                android:elevation="@dimen/common_card_elevation"
                app:layout_constraintTop_toBottomOf="@+id/mid_ad_container"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </ScrollView>
    <FrameLayout
        android:id="@+id/btm_ad_container"
        android:background="@color/common_card_color"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"/>
</androidx.constraintlayout.widget.ConstraintLayout>
