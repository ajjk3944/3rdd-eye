<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        app:title="@string/pro_version"
        style="@style/ToolbarStyle.Perspective"/>
    <ScrollView
        android:id="@+id/scroll_view"
        android:paddingTop="@dimen/toolbar_height"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:paddingLeft="@dimen/content_padding_x1_5"
            android:paddingTop="@dimen/content_padding_plus2"
            android:paddingRight="@dimen/content_padding_x1_5"
            android:paddingBottom="@dimen/content_padding_plus2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:animateLayoutChanges="true"
            android:paddingHorizontal="@dimen/content_padding_x1_5"
            android:paddingVertical="@dimen/content_padding_plus2">
            <TextView
                android:textSize="12sp"
                android:textColor="?android:attr/textColorPrimary"
                android:id="@+id/tv_head_tips"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/content_padding_half"
                android:text="@string/recommend_huawei_pro_bind_to_account"/>
            <LinearLayout
                android:gravity="end"
                android:orientation="horizontal"
                android:id="@+id/head_tips_buttons_container"
                android:paddingBottom="@dimen/content_padding"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <com.google.android.material.button.MaterialButton
                    android:textSize="12sp"
                    android:id="@+id/btn_tips_register"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="@string/create_account"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:textAllCaps="false"
                    style="@style/Widget.MaterialComponents.Button.TextButton"/>
                <com.google.android.material.button.MaterialButton
                    android:textSize="12sp"
                    android:id="@+id/btn_tips_login"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="@string/login"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:textAllCaps="false"
                    android:layout_marginStart="@dimen/content_padding_half"
                    style="@style/Widget.MaterialComponents.Button.TextButton"/>
                <com.google.android.material.button.MaterialButton
                    android:textSize="12sp"
                    android:id="@+id/btn_tips_bind"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="@string/bind_to_current_account"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:textAllCaps="false"
                    android:layout_marginStart="@dimen/content_padding_half"
                    style="@style/Widget.MaterialComponents.Button.TextButton"/>
                <com.google.android.material.button.MaterialButton
                    android:textSize="12sp"
                    android:id="@+id/btn_tips_restore"
                    android:layout_width="wrap_content"
                    android:layout_height="30dp"
                    android:text="@string/restore"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:textAllCaps="false"
                    android:layout_marginStart="@dimen/content_padding_half"
                    style="@style/Widget.MaterialComponents.Button.TextButton"/>
            </LinearLayout>
            <androidx.cardview.widget.CardView
                android:id="@+id/head_card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/content_padding"
                app:cardBackgroundColor="@color/account_pro_head_bg_color"
                style="@style/CommonCardViewStyle">
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:clipToPadding="false"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:paddingStart="@dimen/content_padding_x1_5"
                    android:paddingEnd="0dp">
                    <ImageView
                        android:id="@+id/iv_bg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:src="@drawable/img_filepro"
                        android:scaleType="centerInside"
                        android:adjustViewBounds="true"
                        android:contentDescription="@null"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"/>
                    <com.liuzh.deviceinfo.view.CircleImageView
                        android:id="@+id/iv_avatar"
                        android:layout_marginTop="@dimen/content_padding_x1_5"
                        android:src="@drawable/ic_avatar_default"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        style="@style/AvatarImage"/>
                    <LinearLayout
                        android:gravity="center_vertical"
                        android:orientation="horizontal"
                        android:id="@+id/nickname_container"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/content_padding"
                        app:layout_constraintEnd_toStartOf="@+id/iv_bg"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/iv_avatar">
                        <TextView
                            android:textSize="16sp"
                            android:textColor="@color/pro_title_text_color"
                            android:id="@+id/tv_nickname"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:singleLine="true"
                            android:includeFontPadding="false"
                            android:paddingStart="0dp"
                            android:paddingEnd="34dp"
                            android:textFontWeight="500"/>
                        <TextView
                            android:id="@+id/tag_user_pro"
                            android:visibility="gone"
                            android:translationX="-30dp"
                            style="@style/ProTag"/>
                    </LinearLayout>
                    <TextView
                        android:textSize="16sp"
                        android:textColor="@color/pro_title_text_color"
                        android:id="@+id/btn_login_now"
                        android:background="@drawable/bg_common_card_ripple_radius_nocolor"
                        android:paddingLeft="@dimen/content_padding"
                        android:paddingTop="@dimen/content_padding_half"
                        android:paddingRight="@dimen/content_padding"
                        android:paddingBottom="@dimen/content_padding_half"
                        android:visibility="gone"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/content_padding"
                        android:text="@string/login_now"
                        android:singleLine="true"
                        android:includeFontPadding="false"
                        android:translationX="@dimen/content_padding_negative"
                        android:fontFamily="sans-serif-medium"
                        android:paddingHorizontal="@dimen/content_padding"
                        android:paddingVertical="@dimen/content_padding_half"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/iv_avatar"/>
                    <TextView
                        android:textSize="12sp"
                        android:textColor="@color/pro_title_text_color"
                        android:id="@+id/tv_user_info"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/content_padding_half"
                        android:layout_marginBottom="7dp"
                        android:includeFontPadding="false"
                        android:alpha="0.75"
                        app:layout_constraintEnd_toStartOf="@+id/iv_bg"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toBottomOf="@+id/nickname_container"/>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.cardview.widget.CardView>
            <androidx.appcompat.widget.AppCompatTextView
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/pro_title_text_color"
                android:ellipsize="end"
                android:id="@+id/title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_padding_x1_5"
                android:text="@string/premium_benefits"
                android:singleLine="true"
                android:includeFontPadding="false"
                app:autoSizeMaxTextSize="24sp"
                app:autoSizeMinTextSize="14sp"
                app:autoSizeStepGranularity="1sp"
                app:autoSizeTextType="uniform"/>
            <LinearLayout
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="@dimen/content_padding_double">
                <TextView
                    android:id="@+id/feature_multi_platform"
                    android:text="@string/feature_multi_platform"
                    android:layout_marginEnd="@dimen/content_padding"
                    app:drawableStartCompat="@drawable/ic_pro_multi_platform_colored"
                    style="@style/ProFeatureIconWithText"/>
                <TextView
                    android:id="@+id/feature_ads"
                    android:text="@string/noads"
                    app:drawableStartCompat="@drawable/ic_pro_no_ad_colored"
                    style="@style/ProFeatureIconWithText"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="@dimen/content_padding">
                <TextView
                    android:id="@+id/feature_themes"
                    android:text="@string/custom_theme"
                    android:layout_marginEnd="@dimen/content_padding"
                    app:drawableStartCompat="@drawable/ic_pro_theme_color_colored"
                    style="@style/ProFeatureIconWithText"/>
                <TextView
                    android:id="@+id/feature_smart_selection"
                    android:text="@string/select_dup_files"
                    app:drawableStartCompat="@drawable/ic_pro_smart_selection_colored"
                    style="@style/ProFeatureIconWithText"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="@dimen/content_padding">
                <TextView
                    android:id="@+id/feature_custom_monitor"
                    android:text="@string/custom_monitor"
                    android:layout_marginEnd="@dimen/content_padding"
                    app:drawableStartCompat="@drawable/ic_pro_custom_monitor_colored"
                    style="@style/ProFeatureIconWithText"/>
            </LinearLayout>
            <com.google.android.material.button.MaterialButton
                android:textSize="12sp"
                android:layout_gravity="center"
                android:id="@+id/btn_restore"
                android:paddingTop="@dimen/content_padding"
                android:paddingBottom="@dimen/content_padding"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_padding_x1_5"
                android:minHeight="0dp"
                android:text="@string/restore"
                android:includeFontPadding="false"
                android:insetTop="0dp"
                android:insetBottom="0dp"
                android:textAllCaps="false"
                android:fontFamily="sans-serif-medium"
                android:paddingVertical="@dimen/content_padding"
                style="@style/Widget.MaterialComponents.Button.TextButton"/>
            <TextView
                android:textSize="14sp"
                android:textColor="?android:attr/textColorPrimary"
                android:id="@+id/tv_pay_method"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_padding_double"
                android:text="@string/purchase_method"
                android:fontFamily="sans-serif-medium"/>
            <LinearLayout
                android:orientation="horizontal"
                android:id="@+id/pay_method_container"
                android:layout_width="match_parent"
                android:layout_height="40dp"
                android:layout_marginTop="@dimen/content_padding">
                <TextView
                    android:textSize="14sp"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:id="@+id/pay_method_huawei"
                    android:background="@drawable/bg_pay_method"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:focusable="true"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="@string/purchase_method_huawei"
                    android:lines="2"
                    android:drawablePadding="10dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/content_padding"
                    android:paddingHorizontal="10dp"
                    app:autoSizeMaxTextSize="14sp"
                    app:autoSizeMinTextSize="10sp"
                    app:autoSizeTextType="uniform"
                    app:drawableStartCompat="@drawable/ic_huawei_pay"/>
                <TextView
                    android:textSize="14sp"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:id="@+id/pay_method_wechat"
                    android:background="@drawable/bg_pay_method"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:focusable="true"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="@string/purchase_method_wechat"
                    android:lines="2"
                    android:drawablePadding="10dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/content_padding"
                    android:paddingHorizontal="10dp"
                    app:autoSizeMaxTextSize="14sp"
                    app:autoSizeMinTextSize="10sp"
                    app:autoSizeTextType="uniform"
                    app:drawableStartCompat="@drawable/ic_wechat_pay"/>
                <TextView
                    android:textSize="14sp"
                    android:ellipsize="end"
                    android:gravity="center_vertical"
                    android:id="@+id/pay_method_alipay"
                    android:background="@drawable/bg_pay_method"
                    android:paddingLeft="10dp"
                    android:paddingRight="10dp"
                    android:focusable="true"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:text="@string/purchase_method_alipay"
                    android:lines="2"
                    android:drawablePadding="10dp"
                    android:layout_weight="1"
                    android:paddingHorizontal="10dp"
                    app:autoSizeMaxTextSize="14sp"
                    app:autoSizeMinTextSize="10sp"
                    app:autoSizeTextType="uniform"
                    app:drawableStartCompat="@drawable/ic_alipay"/>
            </LinearLayout>
            <TextView
                android:textSize="14sp"
                android:textColor="?android:attr/textColorPrimary"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/content_padding_x2_5"
                android:text="@string/purchase_notes"
                android:fontFamily="sans-serif-medium"/>
            <TextView
                android:textSize="12sp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:text="@string/purchase_notes_content"/>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:paddingLeft="14dp"
                android:paddingTop="32dp"
                android:paddingRight="14dp"
                android:paddingBottom="140dp"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingHorizontal="14dp">
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/text_link"
                    android:id="@+id/privacy_policy"
                    android:background="?attr/selectableItemBackground"
                    android:paddingLeft="6dp"
                    android:paddingTop="4dp"
                    android:paddingRight="6dp"
                    android:paddingBottom="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/privacy_policy"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginEnd="8dp"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="4dp"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="@color/text_link"
                    android:id="@+id/term_of_service"
                    android:background="?attr/selectableItemBackground"
                    android:paddingLeft="6dp"
                    android:paddingTop="4dp"
                    android:paddingRight="6dp"
                    android:paddingBottom="4dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/term_of_service"
                    android:fontFamily="sans-serif-medium"
                    android:layout_marginStart="8dp"
                    android:paddingHorizontal="6dp"
                    android:paddingVertical="4dp"/>
            </LinearLayout>
        </LinearLayout>
    </ScrollView>
    <Button
        android:ellipsize="end"
        android:layout_gravity="bottom"
        android:id="@+id/btn_purchase"
        android:paddingTop="2dp"
        android:paddingBottom="2dp"
        android:layout_width="match_parent"
        android:layout_height="54dp"
        android:layout_margin="@dimen/content_padding_x1_5"
        android:lines="2"
        android:includeFontPadding="false"
        android:lineSpacingExtra="2dp"
        android:textAllCaps="false"
        style="@style/PrimaryButton.Rounded"/>
    <ProgressBar
        android:layout_gravity="bottom|center_horizontal"
        android:id="@+id/purchase_loading"
        android:padding="10dp"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="54dp"
        android:layout_margin="@dimen/content_padding_x1_5"
        android:translationZ="20dp"
        android:indeterminateTint="@color/white"/>
</FrameLayout>
