<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_gravity="center"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:paddingStart="@dimen/noti_overview_content_padding_start"
    android:paddingEnd="6dp">
    <LinearLayout
        android:gravity="center"
        android:layout_gravity="center"
        android:orientation="horizontal"
        android:paddingTop="4dp"
        android:paddingBottom="4dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:paddingVertical="4dp">
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/ram_arc"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:scaleType="fitXY"
                android:adjustViewBounds="true"
                android:maxWidth="58dp"
                android:maxHeight="58dp"
                android:layout_centerVertical="true"
                android:contentDescription="@null"
                android:layout_marginStart="@dimen/noti_overview_ramarc_margin_start"
                android:layout_marginEnd="16dp"/>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:paddingBottom="6dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_alignTop="@+id/ram_arc"
                android:layout_alignBottom="@+id/ram_arc"
                android:layout_alignStart="@+id/ram_arc"
                android:layout_alignEnd="@+id/ram_arc">
                <TextView
                    android:textSize="10sp"
                    android:id="@+id/ram_percent"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0%"
                    style="@style/TextAppearance.Compat.Notification"/>
                <TextView
                    android:textSize="7sp"
                    android:id="@+id/ram_usage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0.0MB/0.0MB"
                    style="@style/TextAppearance.Compat.Notification"/>
            </LinearLayout>
        </RelativeLayout>
        <RelativeLayout
            android:layout_width="wrap_content"
            android:layout_height="match_parent"
            android:translationY="-1dp"
            android:paddingStart="0dp"
            android:paddingEnd="@dimen/noti_overview_content_padding_end">
            <TextView
                android:id="@+id/guide_line"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_centerVertical="true"
                style="@style/TextAppearance.Compat.Notification"/>
            <TextView
                android:textSize="10sp"
                android:id="@+id/storage_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/storage"
                android:layout_above="@+id/storage_progress"
                style="@style/TextAppearance.Compat.Notification"/>
            <ProgressBar
                android:id="@+id/storage_progress"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2.5dp"
                android:max="100"
                android:progressDrawable="@drawable/bg_notification_progress"
                android:minHeight="0dp"
                android:layout_above="@+id/guide_line"
                android:layout_toStartOf="@+id/storage_percent"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"/>
            <TextView
                android:textSize="9sp"
                android:gravity="end"
                android:id="@+id/storage_percent"
                android:layout_width="30dp"
                android:layout_height="16dp"
                android:layout_alignTop="@+id/storage_progress"
                android:translationY="-5dp"
                android:layout_alignParentEnd="true"
                style="@style/TextAppearance.Compat.Notification"/>
            <TextView
                android:textSize="8sp"
                android:id="@+id/storage_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_above="@+id/storage_progress"
                android:layout_alignEnd="@+id/storage_progress"
                style="@style/TextAppearance.Compat.Notification"/>
            <TextView
                android:textSize="10sp"
                android:id="@+id/battery_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:text="@string/battery"
                android:layout_below="@+id/guide_line"
                style="@style/TextAppearance.Compat.Notification"/>
            <ProgressBar
                android:id="@+id/battery_progress"
                android:layout_width="match_parent"
                android:layout_height="3dp"
                android:layout_marginTop="2dp"
                android:layout_marginBottom="2dp"
                android:max="100"
                android:progressDrawable="@drawable/bg_notification_progress"
                android:minHeight="0dp"
                android:layout_below="@+id/battery_title"
                android:layout_toStartOf="@+id/battery_percent"
                android:layout_marginVertical="2dp"
                style="@style/Widget.AppCompat.ProgressBar.Horizontal"/>
            <TextView
                android:textSize="9sp"
                android:gravity="end|center_vertical"
                android:id="@+id/battery_percent"
                android:layout_width="30dp"
                android:layout_height="16dp"
                android:layout_above="@+id/battery_progress"
                android:translationY="11dp"
                android:layout_alignParentEnd="true"
                style="@style/TextAppearance.Compat.Notification"/>
            <TextView
                android:textSize="8sp"
                android:id="@+id/battery_message"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_above="@+id/battery_progress"
                android:layout_alignEnd="@+id/battery_progress"
                style="@style/TextAppearance.Compat.Notification"/>
        </RelativeLayout>
    </LinearLayout>
    <LinearLayout
        android:layout_gravity="end"
        android:orientation="horizontal"
        android:id="@+id/logo_layout"
        android:padding="1dp"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <ImageView
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:src="@drawable/ic_small_logo"/>
        <TextView
            android:textSize="7sp"
            android:gravity="center"
            android:layout_gravity="center"
            android:padding="0dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="1dp"
            android:layout_marginRight="1dp"
            android:text="@string/pure_app_name"
            android:layout_marginHorizontal="1dp"
            style="@style/TextAppearance.Compat.Notification"/>
    </LinearLayout>
</FrameLayout>
