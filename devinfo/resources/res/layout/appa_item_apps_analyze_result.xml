<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/analyze_item"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginLeft="?attr/appa_content_padding"
    android:layout_marginTop="?attr/appa_content_padding_half"
    android:layout_marginRight="?attr/appa_content_padding"
    android:layout_marginBottom="?attr/appa_content_padding_half"
    android:foreground="?android:attr/selectableItemBackground"
    android:layout_marginHorizontal="?attr/appa_content_padding"
    android:layout_marginVertical="?attr/appa_content_padding_half"
    app:cardBackgroundColor="?attr/appa_card_color"
    app:cardCornerRadius="?attr/appa_card_radius"
    app:cardElevation="?attr/appa_card_elevation">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:orientation="vertical"
        android:padding="?attr/appa_card_inner_padding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="14sp"
            android:textColor="?android:attr/textColorPrimary"
            android:id="@+id/tv_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fontFamily="sans-serif-medium"
            android:textAlignment="viewStart"
            app:layout_constraintBottom_toTopOf="@+id/tv_summary"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintVertical_chainStyle="packed"/>
        <TextView
            android:textSize="14sp"
            android:id="@+id/tv_summary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            app:layout_constraintBottom_toTopOf="@+id/line_item1"
            app:layout_constraintTop_toBottomOf="@+id/tv_title"/>
        <include
            android:id="@+id/line_item1"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            app:layout_constraintBottom_toTopOf="@+id/line_item2"
            app:layout_constraintTop_toBottomOf="@+id/tv_summary"
            layout="@layout/appa_item_apps_analyze_result_line"/>
        <include
            android:id="@+id/line_item2"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toTopOf="@+id/more_detail"
            app:layout_constraintTop_toBottomOf="@+id/line_item1"
            layout="@layout/appa_item_apps_analyze_result_line"/>
        <TextView
            android:textSize="14sp"
            android:textColor="?android:attr/textColorSecondary"
            android:gravity="center"
            android:layout_gravity="center"
            android:id="@+id/more_detail"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="@string/appa_string_detail"
            android:fontFamily="sans-serif-medium"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/line_item2"/>
        <ImageView
            android:layout_width="18dp"
            android:layout_height="18dp"
            android:src="@drawable/appa_ic_arrow_forward"
            android:contentDescription="@null"
            android:alpha="0.6"
            android:rotation="@integer/appa_rtl_rotation_compat"
            android:layout_marginStart="4dp"
            app:layout_constraintBottom_toBottomOf="@+id/more_detail"
            app:layout_constraintStart_toEndOf="@+id/more_detail"
            app:layout_constraintTop_toTopOf="@+id/more_detail"
            app:tint="?android:attr/textColorPrimary"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.cardview.widget.CardView>
