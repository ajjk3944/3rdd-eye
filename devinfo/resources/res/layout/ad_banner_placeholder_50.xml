<?xml version="1.0" encoding="utf-8"?>
<com.facebook.shimmer.ShimmerFrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="50dp"
    style="@style/AdPlaceholderShimmer">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:padding="6dp"
        android:layout_width="match_parent"
        android:layout_height="50dp">
        <ImageView
            android:id="@+id/ad_icon"
            android:background="@color/ad_placeholder_color"
            android:layout_width="38dp"
            android:layout_height="38dp"
            android:contentDescription="@null"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="12sp"
            android:textStyle="bold"
            android:textColor="?android:attr/textColorSecondary"
            android:id="@+id/ad_title"
            android:background="@color/ad_placeholder_color"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:singleLine="true"
            android:textAlignment="viewStart"
            android:layout_marginStart="2dp"
            android:layout_marginEnd="6dp"
            app:layout_constraintBottom_toTopOf="@+id/ad_description"
            app:layout_constraintEnd_toStartOf="@+id/ad_button"
            app:layout_constraintStart_toEndOf="@+id/ad_tips"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="10sp"
            android:textColor="?android:attr/textColorSecondary"
            android:id="@+id/ad_description"
            android:background="@color/ad_placeholder_color"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="6dp"
            android:layout_marginRight="6dp"
            android:maxLines="4"
            android:lines="1"
            android:fontFamily="sans-serif-condensed-medium"
            android:textAlignment="viewStart"
            android:layout_marginHorizontal="6dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/ad_button"
            app:layout_constraintStart_toEndOf="@+id/ad_icon"
            app:layout_constraintTop_toBottomOf="@+id/ad_title"/>
        <TextView
            android:textSize="10sp"
            android:textColor="@android:color/white"
            android:gravity="center"
            android:id="@+id/ad_tips"
            android:background="@drawable/bg_ad_choice"
            android:paddingLeft="3dp"
            android:paddingTop="1dp"
            android:paddingRight="3dp"
            android:paddingBottom="1dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="AD"
            android:fontFamily="sans-serif-medium"
            android:layout_marginStart="6dp"
            app:layout_constraintBottom_toBottomOf="@+id/ad_title"
            app:layout_constraintStart_toEndOf="@+id/ad_icon"
            app:layout_constraintTop_toTopOf="@+id/ad_title"/>
        <Button
            android:textSize="12sp"
            android:id="@+id/ad_button"
            android:background="@color/ad_placeholder_color"
            android:paddingLeft="8dp"
            android:paddingRight="8dp"
            android:layout_width="wrap_content"
            android:layout_height="26dp"
            android:maxWidth="100dp"
            android:minWidth="60dp"
            android:paddingHorizontal="8dp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.facebook.shimmer.ShimmerFrameLayout>
