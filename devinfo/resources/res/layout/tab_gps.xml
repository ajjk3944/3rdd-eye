<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scrollView"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/content_container"
        android:padding="@dimen/content_padding"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:animateLayoutChanges="true">
        <FrameLayout
            android:id="@+id/permission_card"
            android:background="@drawable/bg_common_card"
            android:padding="@dimen/content_padding"
            android:visibility="gone"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/content_padding">
            <TextView
                android:gravity="center_vertical"
                android:layout_gravity="center_vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/tab_gps_permission_summary"
                android:paddingStart="0dp"
                android:paddingEnd="@dimen/content_padding_half"
                android:layout_marginEnd="100dp"/>
            <Button
                android:ellipsize="end"
                android:layout_gravity="end|center_vertical"
                android:id="@+id/action_grant_permission"
                android:paddingLeft="6dp"
                android:paddingRight="6dp"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="@string/grant"
                android:maxLines="1"
                android:paddingHorizontal="6dp"
                app:autoSizeMaxTextSize="14sp"
                app:autoSizeMinTextSize="10sp"
                app:autoSizeTextType="uniform"/>
        </FrameLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/satellite_container"
            android:background="@drawable/bg_common_card"
            android:paddingLeft="16dp"
            android:paddingTop="10dp"
            android:paddingRight="16dp"
            android:paddingBottom="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:elevation="@dimen/common_card_elevation"/>
        <FrameLayout
            android:id="@+id/details_card"
            android:background="@drawable/bg_common_card"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_padding"
            android:elevation="@dimen/common_card_elevation"
            app:layout_constraintTop_toTopOf="parent"/>
        <androidx.cardview.widget.CardView
            android:id="@+id/procard_container"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_padding"
            style="@style/CommonCardViewStyle"/>
    </LinearLayout>
</ScrollView>
