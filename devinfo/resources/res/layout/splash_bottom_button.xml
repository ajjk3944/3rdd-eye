<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="bottom"
    android:layout_gravity="bottom"
    android:orientation="vertical"
    android:paddingLeft="@dimen/splash_bottom_padding_hori"
    android:paddingRight="@dimen/splash_bottom_padding_hori"
    android:paddingBottom="4dp"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:paddingHorizontal="@dimen/splash_bottom_padding_hori">
    <TextView
        android:textSize="13sp"
        android:id="@+id/agree_privacy"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/splash_agree_title"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp">
        <ImageView
            android:layout_width="14dp"
            android:layout_height="19dp"
            android:src="@drawable/bg_dot"
            android:scaleType="center"
            android:contentDescription="@null"
            app:tint="?android:attr/textColorHint"/>
        <TextView
            android:textSize="13sp"
            android:textColor="@color/md_blue_600"
            android:gravity="center_vertical"
            android:id="@+id/privacy_policy"
            android:background="?android:attr/selectableItemBackground"
            android:focusable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="19dp"
            android:text="@string/privacy_policy"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"/>
        <TextView
            android:textSize="13sp"
            android:gravity="center"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="19dp"
            android:text="&amp;"/>
        <TextView
            android:textSize="13sp"
            android:textColor="@color/md_blue_600"
            android:gravity="center_vertical"
            android:id="@+id/term_of_service"
            android:background="?android:attr/selectableItemBackground"
            android:focusable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:minHeight="19dp"
            android:text="@string/term_of_service"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp">
        <ImageView
            android:layout_width="14dp"
            android:layout_height="17dp"
            android:src="@drawable/bg_dot"
            android:scaleType="center"
            android:contentDescription="@null"
            app:tint="?android:attr/textColorHint"/>
        <TextView
            android:textSize="13sp"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/installed_apps"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:minHeight="19dp"
            android:text="@string/splash_agree_get_installed_apps"
            android:maxLines="3"
            android:includeFontPadding="false"
            android:layout_weight="1"
            android:paddingStart="8dp"
            android:paddingEnd="0dp"
            app:layout_constraintTop_toBottomOf="@+id/privacy_policy"/>
    </LinearLayout>
    <com.google.android.material.button.MaterialButton
        android:textSize="14sp"
        android:textColor="@android:color/white"
        android:id="@+id/button"
        android:paddingTop="0dp"
        android:paddingBottom="0dp"
        android:layout_width="match_parent"
        android:layout_height="50dp"
        android:layout_marginTop="20dp"
        android:text="@string/agree_and_continue"
        android:textAllCaps="false"
        android:paddingVertical="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/installed_apps"/>
    <Button
        android:textSize="13sp"
        android:layout_gravity="center"
        android:id="@+id/action_exit"
        android:paddingLeft="28dp"
        android:paddingTop="6dp"
        android:paddingRight="28dp"
        android:paddingBottom="6dp"
        android:focusable="true"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="2dp"
        android:minHeight="0dp"
        android:text="@string/exit"
        android:paddingHorizontal="28dp"
        android:paddingVertical="6dp"
        style="@style/Widget.MaterialComponents.Button.TextButton"/>
</LinearLayout>
