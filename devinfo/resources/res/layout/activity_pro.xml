<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scroll_view"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="vertical"
        android:clipChildren="false"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <FrameLayout
            android:id="@+id/header"
            android:background="@color/account_pro_head_bg_color"
            android:layout_width="match_parent"
            android:layout_height="160dp">
            <ImageView
                android:layout_gravity="bottom|center_horizontal"
                android:layout_width="wrap_content"
                android:layout_height="180dp"
                android:src="@drawable/img_filepro"
                android:scaleType="fitXY"
                android:adjustViewBounds="true"
                android:contentDescription="@null"
                android:layout_marginEnd="12dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>
            <ImageView
                android:layout_gravity="end"
                android:id="@+id/close"
                android:background="?attr/actionBarItemBackground"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:src="@drawable/ic_close_fill"
                android:scaleType="center"
                android:contentDescription="@string/close"
                android:alpha="0.4"
                app:tint="@color/black_white"/>
        </FrameLayout>
        <androidx.appcompat.widget.AppCompatTextView
            android:textSize="24sp"
            android:textStyle="bold"
            android:textColor="@color/pro_title_text_color"
            android:ellipsize="end"
            android:id="@+id/title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/content_padding_double"
            android:layout_marginTop="@dimen/content_padding_x1_5"
            android:layout_marginRight="@dimen/content_padding_double"
            android:text="@string/upgrade_to_pro_version"
            android:singleLine="true"
            android:includeFontPadding="false"
            android:paddingStart="0dp"
            android:paddingEnd="@dimen/content_padding"
            android:layout_marginHorizontal="@dimen/content_padding_double"
            app:autoSizeMaxTextSize="24sp"
            app:autoSizeMinTextSize="14sp"
            app:autoSizeStepGranularity="1sp"
            app:autoSizeTextType="uniform"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/pro_feature_text_color"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/feature_ads"
            android:paddingLeft="@dimen/content_padding_double"
            android:paddingRight="@dimen/content_padding_double"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_padding_x1_5"
            android:text="@string/feature_remove_all_ads"
            android:singleLine="true"
            android:drawablePadding="@dimen/content_padding"
            android:paddingHorizontal="@dimen/content_padding_double"
            app:drawableStartCompat="@drawable/ic_pro_no_ad_colored"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/pro_feature_text_color"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/feature_themes"
            android:paddingLeft="@dimen/content_padding_double"
            android:paddingRight="@dimen/content_padding_double"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_padding_x1_5"
            android:text="@string/feature_themes"
            android:singleLine="true"
            android:drawablePadding="@dimen/content_padding"
            android:paddingHorizontal="@dimen/content_padding_double"
            app:drawableStartCompat="@drawable/ic_pro_theme_color_colored"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/pro_feature_text_color"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/feature_custom_monitor"
            android:paddingLeft="@dimen/content_padding_double"
            android:paddingRight="@dimen/content_padding_double"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_padding_x1_5"
            android:text="@string/custom_monitor"
            android:singleLine="true"
            android:drawablePadding="@dimen/content_padding"
            android:paddingHorizontal="@dimen/content_padding_double"
            app:drawableStartCompat="@drawable/ic_pro_custom_monitor_colored"/>
        <TextView
            android:textSize="14sp"
            android:textColor="@color/pro_feature_text_color"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/feature_smart_selection"
            android:paddingLeft="@dimen/content_padding_double"
            android:paddingRight="@dimen/content_padding_double"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_padding_x1_5"
            android:text="@string/feature_smart_selection"
            android:singleLine="true"
            android:drawablePadding="@dimen/content_padding"
            android:paddingHorizontal="@dimen/content_padding_double"
            app:drawableStartCompat="@drawable/ic_pro_smart_selection_colored"/>
        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/bottom_container"
            android:paddingLeft="@dimen/content_padding_x1_5"
            android:paddingTop="12dp"
            android:paddingRight="@dimen/content_padding_x1_5"
            android:paddingBottom="4dp"
            android:clipChildren="false"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/content_padding_x2_5"
            android:minHeight="80dp"
            android:paddingHorizontal="@dimen/content_padding_x1_5">
            <TextView
                android:textSize="18sp"
                android:textColor="@color/colorPrimary"
                android:gravity="center"
                android:id="@+id/unlocked_pro"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/content_padding_double"
                android:text="@string/unlocked_pro"
                android:drawablePadding="8dp"
                android:fontFamily="sans-serif-medium"
                app:drawableStartCompat="@drawable/ic_pro"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <LinearLayout
                android:gravity="center"
                android:orientation="vertical"
                android:id="@+id/sku_item"
                android:background="@drawable/bg_sku"
                android:paddingLeft="8dp"
                android:paddingTop="14dp"
                android:paddingRight="8dp"
                android:paddingBottom="14dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minWidth="90dp"
                android:minHeight="105dp"
                android:paddingHorizontal="8dp"
                android:paddingVertical="14dp"
                app:layout_constraintBottom_toTopOf="@+id/btn_pay_container"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent">
                <TextView
                    android:textSize="14sp"
                    android:textColor="@color/black_white"
                    android:id="@+id/sku_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.7"
                    android:fontFamily="sans-serif-medium"/>
                <TextView
                    android:textSize="15sp"
                    android:textColor="@color/black_white"
                    android:id="@+id/price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:layout_marginBottom="4dp"
                    android:alpha="0.7"/>
                <TextView
                    android:textSize="11sp"
                    android:textColor="@color/black_white"
                    android:id="@+id/ori_price"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:alpha="0.5"/>
            </LinearLayout>
            <TextView
                android:textSize="10sp"
                android:textColor="@color/white"
                android:id="@+id/flag"
                android:background="@drawable/bg_limited_offer"
                android:paddingTop="2dp"
                android:paddingBottom="2dp"
                android:visibility="invisible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/limited_offer"
                android:paddingStart="6dp"
                android:paddingEnd="6dp"
                app:layout_constraintBottom_toTopOf="@+id/sku_item"
                app:layout_constraintEnd_toEndOf="@+id/sku_item"
                app:layout_constraintTop_toTopOf="@+id/sku_item"/>
            <ProgressBar
                android:id="@+id/progressBar"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:indeterminateTint="@color/colorPrimary"
                app:layout_constraintBottom_toBottomOf="@+id/sku_item"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/sku_item"/>
            <com.liuzh.deviceinfo.view.SimpleShimmerLayout
                android:id="@+id/btn_pay_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                app:layout_constraintTop_toBottomOf="@+id/sku_item">
                <Button
                    android:id="@+id/btn_pay"
                    android:background="@drawable/btn_pay"
                    android:layout_width="match_parent"
                    android:layout_height="46dp"
                    android:text="@string/pay_now"
                    style="@style/AlphaButtonStyle"/>
            </com.liuzh.deviceinfo.view.SimpleShimmerLayout>
        </androidx.constraintlayout.widget.ConstraintLayout>
        <TextView
            android:textSize="14sp"
            android:layout_gravity="center"
            android:id="@+id/restore"
            android:background="?android:attr/selectableItemBackground"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="14dp"
            android:text="@string/restore"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingVertical="10dp"/>
        <TextView
            android:textSize="14sp"
            android:textColor="?android:attr/textColorPrimary"
            android:id="@+id/pay_notice_title"
            android:paddingTop="6dp"
            android:paddingBottom="6dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pay_notice_title"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"
            android:paddingVertical="6dp"/>
        <TextView
            android:textSize="14sp"
            android:id="@+id/pay_notice"
            android:paddingTop="10dp"
            android:paddingBottom="10dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/pay_notice_msg_google"
            android:paddingStart="24dp"
            android:paddingEnd="24dp"/>
    </LinearLayout>
</ScrollView>
