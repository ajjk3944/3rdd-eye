<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        app:title="@string/custom_monitor"
        style="@style/ToolbarStyle.Perspective"/>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/content_container"
        android:paddingTop="@dimen/toolbar_height"
        android:clipToPadding="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/pro_tips_card"
            android:background="@drawable/bg_common_card"
            android:padding="@dimen/content_padding_half"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/content_padding"
            android:layout_marginRight="@dimen/content_padding"
            android:layout_marginHorizontal="@dimen/content_padding">
            <TextView
                android:textSize="14sp"
                android:textColor="?android:attr/textColorPrimary"
                android:id="@+id/pro_summary"
                android:padding="@dimen/content_padding_half"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="@string/custom_floating_monitor_pro_summary"/>
            <TextView
                android:textSize="14sp"
                android:textColor="?attr/colorPrimary"
                android:layout_gravity="end"
                android:id="@+id/btn_active_pro"
                android:background="?attr/selectableItemBackground"
                android:paddingLeft="6dp"
                android:paddingTop="4dp"
                android:paddingRight="6dp"
                android:paddingBottom="4dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:minHeight="0dp"
                android:text="@string/buy_pro_version"
                android:textAllCaps="false"
                android:fontFamily="sans-serif-medium"
                android:paddingHorizontal="6dp"
                android:paddingVertical="4dp"/>
        </LinearLayout>
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/recyclerview"
            android:background="@drawable/bg_common_card"
            android:paddingTop="@dimen/content_padding_half"
            android:paddingBottom="@dimen/content_padding_half"
            android:clipToPadding="false"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginLeft="@dimen/content_padding"
            android:layout_marginTop="@dimen/content_padding"
            android:layout_marginRight="@dimen/content_padding"
            android:layout_weight="1"
            android:layout_marginHorizontal="@dimen/content_padding"
            android:paddingVertical="@dimen/content_padding_half"
            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"/>
        <Button
            android:layout_gravity="bottom|center_horizontal"
            android:id="@+id/btn_add_monitor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/content_padding"
            android:text="@string/menu_add"/>
    </LinearLayout>
    <TextView
        android:layout_gravity="center"
        android:id="@+id/empty_view"
        android:padding="@dimen/content_padding"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/content_padding_double"
        android:text="@string/click_to_add_custom_monitor"/>
</FrameLayout>
