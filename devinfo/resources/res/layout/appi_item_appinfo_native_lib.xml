<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardBackgroundColor="?attr/appi_card_color"
    app:cardCornerRadius="?attr/appi_card_radius"
    app:cardElevation="?attr/appi_card_elevation">
    <LinearLayout
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/head_container"
            android:background="?android:attr/selectableItemBackground"
            android:focusable="true"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="13sp"
                android:gravity="start|center_vertical"
                android:id="@+id/name"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:minHeight="36dp"
                android:layout_weight="1"
                android:textAlignment="viewStart"
                android:paddingStart="14dp"
                android:paddingEnd="14dp"/>
            <TextView
                android:textSize="12sp"
                android:ellipsize="end"
                android:gravity="center"
                android:id="@+id/tag_lib"
                android:background="@drawable/appi_bg_tag"
                android:paddingLeft="6dp"
                android:paddingTop="4dp"
                android:paddingRight="6dp"
                android:paddingBottom="4dp"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxWidth="110dp"
                android:singleLine="true"
                android:includeFontPadding="false"
                android:paddingHorizontal="6dp"
                android:paddingVertical="4dp"/>
            <ImageView
                android:layout_gravity="end|center_vertical"
                android:id="@+id/arrow"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:src="@drawable/appi_ic_arrow_drop_down"
                android:scaleType="center"
                android:contentDescription="@null"
                app:tint="#ff999999"/>
        </LinearLayout>
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/details_container"
            android:visibility="gone"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:divider="@drawable/appi_divider_appinfo"
            android:showDividers="middle">
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:background="?android:attr/selectableItemBackground"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:focusable="true"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="34dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">
                <TextView
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:gravity="start|center_vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/appi_label"
                    android:layout_weight="1"
                    android:textAlignment="viewStart"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:gravity="end|center_vertical"
                    android:id="@+id/label"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:textAlignment="viewEnd"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:background="?android:attr/selectableItemBackground"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:focusable="true"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="34dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">
                <TextView
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:gravity="start|center_vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/appi_size"
                    android:layout_weight="1"
                    android:textAlignment="viewStart"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:gravity="end|center_vertical"
                    android:id="@+id/size"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:textAlignment="viewEnd"/>
            </LinearLayout>
            <LinearLayout
                android:gravity="center"
                android:orientation="horizontal"
                android:id="@+id/website_container"
                android:background="?android:attr/selectableItemBackground"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:focusable="true"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:minHeight="34dp"
                android:paddingStart="14dp"
                android:paddingEnd="14dp">
                <TextView
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:gravity="start|center_vertical"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/appi_website"
                    android:layout_weight="1"
                    android:textAlignment="viewStart"/>
                <TextView
                    android:textSize="12sp"
                    android:textColor="?android:attr/textColorPrimary"
                    android:gravity="end|center_vertical"
                    android:id="@+id/website"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="2"
                    android:textAlignment="viewEnd"/>
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
