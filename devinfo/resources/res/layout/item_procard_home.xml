<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/procard_container"
    android:background="?android:attr/selectableItemBackground"
    android:padding="@dimen/content_padding"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <ImageView
        android:id="@+id/icon"
        android:padding="2dp"
        android:layout_width="24dp"
        android:layout_height="24dp"
        android:src="@drawable/ic_pro"
        android:contentDescription="@null"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:textSize="13sp"
        android:textColor="@color/pro_title_text_color"
        android:gravity="center_vertical"
        android:id="@+id/title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/pro_version"
        android:layout_marginStart="@dimen/content_padding_half"
        android:textFontWeight="500"
        app:layout_constraintBottom_toBottomOf="@+id/icon"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/icon"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"/>
    <TextView
        android:textSize="12sp"
        android:id="@+id/summary"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="@string/active_pro_for_noads_summary"
        android:maxLines="4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/title"
        app:layout_constraintTop_toBottomOf="@+id/icon"/>
    <ImageView
        android:id="@+id/iv_arrow"
        android:padding="6dp"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_right_arrow"
        android:contentDescription="@null"
        android:alpha="0.32"
        android:translationX="10dp"
        android:translationY="-8dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/black_white"/>
    <ImageView
        android:id="@+id/iv_close"
        android:background="?attr/actionBarItemBackground"
        android:padding="8dp"
        android:layout_width="32dp"
        android:layout_height="32dp"
        android:src="@drawable/ic_close"
        android:contentDescription="@null"
        android:alpha="0.32"
        android:translationX="6dp"
        android:translationY="-8dp"
        app:layout_constraintEnd_toStartOf="@+id/iv_arrow"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/black_white"/>
    <LinearLayout
        android:gravity="center"
        android:orientation="horizontal"
        android:paddingTop="2dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/content_padding_half"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/summary">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_pro_no_ad_colored"
            android:contentDescription="@null"
            android:layout_marginEnd="6dp"/>
        <TextView
            android:textSize="11sp"
            android:gravity="center_vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/noads"
            android:singleLine="true"
            android:layout_weight="1"
            android:contentDescription="@null"
            android:layout_marginEnd="12dp"/>
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_pro_theme_color_colored"
            android:contentDescription="@null"
            android:layout_marginEnd="6dp"/>
        <TextView
            android:textSize="11sp"
            android:gravity="center_vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/custom_theme"
            android:singleLine="true"
            android:layout_weight="1"
            android:contentDescription="@null"
            android:layout_marginEnd="12dp"/>
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_pro_smart_selection_colored"
            android:contentDescription="@null"
            android:layout_marginEnd="6dp"/>
        <TextView
            android:textSize="11sp"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/select_dup_files"
            android:lines="2"
            android:layout_weight="1.15"
            android:contentDescription="@null"
            app:autoSizeMaxTextSize="11sp"
            app:autoSizeMinTextSize="8sp"
            app:autoSizeStepGranularity="0.5sp"
            app:autoSizeTextType="uniform"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
