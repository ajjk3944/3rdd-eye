<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/scanning_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@+id/guide_line_center_vertical"
        android:layout_width="wrap_content"
        android:layout_height="match_parent"
        app:layout_constraintGuide_percent="0.5"/>
    <TextView
        android:textSize="14sp"
        android:id="@+id/tv_trash_app_cache"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/application_cache"
        android:layout_marginEnd="12dp"
        app:layout_constraintBottom_toTopOf="@+id/tv_trash_apk_file"
        app:layout_constraintRight_toRightOf="@+id/guide_line_center_vertical"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed"/>
    <ProgressBar
        android:id="@+id/progress_app_cache"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_marginStart="12dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_trash_app_cache"
        app:layout_constraintLeft_toLeftOf="@+id/guide_line_center_vertical"
        app:layout_constraintTop_toTopOf="@+id/tv_trash_app_cache"/>
    <TextView
        android:textSize="14sp"
        android:id="@+id/tv_size_app_cache"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_trash_app_cache"
        app:layout_constraintLeft_toRightOf="@+id/progress_app_cache"
        app:layout_constraintTop_toTopOf="@+id/tv_trash_app_cache"/>
    <TextView
        android:textSize="14sp"
        android:id="@+id/tv_trash_apk_file"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/apk_file"
        android:layout_marginEnd="12dp"
        app:layout_constraintBottom_toTopOf="@+id/tv_trash_temp_file"
        app:layout_constraintRight_toRightOf="@+id/guide_line_center_vertical"
        app:layout_constraintTop_toBottomOf="@+id/tv_trash_app_cache"/>
    <ProgressBar
        android:id="@+id/progress_apk_file"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_marginStart="12dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_trash_apk_file"
        app:layout_constraintLeft_toLeftOf="@+id/guide_line_center_vertical"
        app:layout_constraintTop_toTopOf="@+id/tv_trash_apk_file"/>
    <TextView
        android:textSize="14sp"
        android:id="@+id/tv_size_apk_file"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_trash_apk_file"
        app:layout_constraintLeft_toRightOf="@+id/progress_apk_file"
        app:layout_constraintTop_toTopOf="@+id/tv_trash_apk_file"/>
    <TextView
        android:textSize="14sp"
        android:id="@+id/tv_trash_temp_file"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/temporary_files"
        android:layout_marginEnd="12dp"
        app:layout_constraintBottom_toTopOf="@+id/tv_trash_empty_folder"
        app:layout_constraintRight_toRightOf="@+id/guide_line_center_vertical"
        app:layout_constraintTop_toBottomOf="@+id/tv_trash_apk_file"/>
    <ProgressBar
        android:id="@+id/progress_temp_file"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_marginStart="12dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_trash_temp_file"
        app:layout_constraintLeft_toLeftOf="@+id/guide_line_center_vertical"
        app:layout_constraintTop_toTopOf="@+id/tv_trash_temp_file"/>
    <TextView
        android:textSize="14sp"
        android:id="@+id/tv_size_temp_file"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_trash_temp_file"
        app:layout_constraintLeft_toRightOf="@+id/progress_temp_file"
        app:layout_constraintTop_toTopOf="@+id/tv_trash_temp_file"/>
    <TextView
        android:textSize="14sp"
        android:id="@+id/tv_trash_empty_folder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/empty_files_and_folders"
        android:layout_marginEnd="12dp"
        app:layout_constraintBottom_toTopOf="@+id/tv_trash_log_file"
        app:layout_constraintRight_toRightOf="@+id/guide_line_center_vertical"
        app:layout_constraintTop_toBottomOf="@+id/tv_trash_temp_file"/>
    <ProgressBar
        android:id="@+id/progress_empty_folder"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_marginStart="12dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_trash_empty_folder"
        app:layout_constraintLeft_toLeftOf="@+id/guide_line_center_vertical"
        app:layout_constraintTop_toTopOf="@+id/tv_trash_empty_folder"/>
    <TextView
        android:textSize="14sp"
        android:id="@+id/tv_size_empty_folder"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_trash_empty_folder"
        app:layout_constraintLeft_toRightOf="@+id/progress_empty_folder"
        app:layout_constraintTop_toTopOf="@+id/tv_trash_empty_folder"/>
    <TextView
        android:textSize="14sp"
        android:id="@+id/tv_trash_log_file"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="@string/log_file"
        android:layout_marginEnd="12dp"
        app:layout_constraintBottom_toTopOf="@+id/lottie_animation_scanning"
        app:layout_constraintRight_toRightOf="@+id/guide_line_center_vertical"
        app:layout_constraintTop_toBottomOf="@+id/tv_trash_empty_folder"/>
    <ProgressBar
        android:id="@+id/progress_log_file"
        android:layout_width="14dp"
        android:layout_height="14dp"
        android:layout_marginStart="12dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_trash_log_file"
        app:layout_constraintLeft_toLeftOf="@+id/guide_line_center_vertical"
        app:layout_constraintTop_toTopOf="@+id/tv_trash_log_file"/>
    <TextView
        android:textSize="14sp"
        android:id="@+id/tv_size_log_file"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        app:layout_constraintBottom_toBottomOf="@+id/tv_trash_log_file"
        app:layout_constraintLeft_toRightOf="@+id/progress_log_file"
        app:layout_constraintTop_toTopOf="@+id/tv_trash_log_file"/>
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottie_animation_scanning"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginLeft="32dp"
        android:layout_marginRight="32dp"
        android:scaleX="1.1"
        android:scaleY="1.1"
        android:layout_marginHorizontal="32dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHeight_percent="0.6"
        app:lottie_autoPlay="true"
        app:lottie_fileName="lottie/storage_clean_scanning.json"
        app:lottie_loop="true"/>
</androidx.constraintlayout.widget.ConstraintLayout>
