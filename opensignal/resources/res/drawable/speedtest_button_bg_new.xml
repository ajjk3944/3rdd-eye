<?xml version="1.0" encoding="utf-8"?>
<ripple xmlns:android="http://schemas.android.com/apk/res/android" android:color="@color/complementary_2_pressed">
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/complementary_2_light"/>
        </shape>
    </item>
    <item android:bottom="4dp">
        <shape android:shape="oval">
            <solid android:color="@color/complementary_2_alt"/>
        </shape>
    </item>
    <item
        android:id="@android:id/mask"
        android:bottom="4dp">
        <shape android:shape="oval">
            <solid android:color="@android:color/white"/>
        </shape>
    </item>
</ripple>
