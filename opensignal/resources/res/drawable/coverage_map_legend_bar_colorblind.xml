<?xml version="1.0" encoding="utf-8"?>
<shape xmlns:android="http://schemas.android.com/apk/res/android" android:shape="rectangle">
    <size
        android:height="@dimen/coverage_map_legend_height"
        android:width="@dimen/coverage_map_legend_width"/>
    <gradient
        android:startColor="@color/coverage_map_legend_colorblind_start"
        android:endColor="@color/coverage_map_legend_colorblind_end"
        android:angle="270"
        android:type="linear"/>
    <corners android:radius="@dimen/coverage_map_legend_corner_radius"/>
    <stroke
        android:width="@dimen/coverage_map_legend_stroke_width"
        android:color="@color/white"/>
</shape>
