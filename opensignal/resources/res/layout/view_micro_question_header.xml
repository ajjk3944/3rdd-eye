<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/view_micro_question_header_root"
    android:clipToPadding="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.survicate.surveys.presentation.widget.MicroSurveyPointImage
        android:id="@+id/view_micro_question_header_image"
        android:visibility="gone"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <TextView
        android:id="@+id/view_micro_question_header_introduction"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/survicate_micro_space_md"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/view_micro_question_header_image"
        style="@style/Widget.Survicate.QuestionIntro.Micro"/>
    <TextView
        android:id="@+id/view_micro_question_header_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/survicate_micro_question_title_top_margin"
        app:layout_constraintBottom_toTopOf="@+id/view_micro_question_header_answer_required_label"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/view_micro_question_header_introduction"
        app:layout_goneMarginBottom="@dimen/survicate_micro_space_md"
        app:layout_goneMarginTop="@dimen/survicate_micro_space_md"
        style="@style/Widget.Survicate.QuestionTitle.Micro"/>
    <TextView
        android:id="@+id/view_micro_question_header_answer_required_label"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/survicate_micro_answer_required_label_top_margin"
        android:layout_marginBottom="@dimen/survicate_micro_space_xs"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/view_micro_question_header_title"
        app:layout_goneMarginTop="@dimen/survicate_micro_space_md"
        style="@style/Widget.Survicate.AnswerRequiredLabel.Micro"/>
</androidx.constraintlayout.widget.ConstraintLayout>
