<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:focusable="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/survicate_micro_space_xs">
    <LinearLayout
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:minHeight="@dimen/survicate_micro_question_multiple_min_height">
        <CheckBox
            android:id="@+id/item_micro_multiple_checkbox"
            android:focusable="false"
            android:clickable="false"
            android:layout_width="@dimen/survicate_micro_question_checkbox_size"
            android:layout_height="@dimen/survicate_micro_question_checkbox_size"
            android:layout_marginTop="@dimen/survicate_micro_space_xxs"
            android:layout_marginBottom="@dimen/survicate_micro_space_xxs"
            android:button="@null"
            android:layout_marginStart="@dimen/survicate_micro_space_xs"/>
        <TextView
            android:textAppearance="@style/Widget.Survicate.QuestionOption.Text.Micro"
            android:id="@+id/item_micro_multiple_answer_text"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/survicate_micro_space_s"
            android:layout_marginBottom="@dimen/survicate_micro_space_s"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/survicate_micro_space_xxs"
            android:layout_marginEnd="@dimen/survicate_micro_space_md"
            android:labelFor="@+id/item_micro_multiple_checkbox"/>
    </LinearLayout>
    <com.survicate.surveys.presentation.widget.MicroSurvicateCommentField
        android:id="@+id/item_micro_multiple_comment_field"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:accessibilityLiveRegion="polite"
        app:survicateCommentFieldStyle="nested"/>
</LinearLayout>
