    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.survicate.surveys.presentation.widget.MicroQuestionHeader
        android:id="@+id/item_micro_text_header"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
