<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center"
    android:orientation="vertical"
    android:id="@+id/spinnerLayout"
    android:background="@color/osm_darkerblue_trans"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <TextView
        android:layout_gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="@dimen/standard_margin"
        android:text="@string/loading_speedtest"
        style="@style/Headers.h1"/>
    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/spinner_animation_view"
        android:layout_width="@dimen/speedtest_loading_spinner"
        android:layout_height="@dimen/speedtest_loading_spinner"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/spinner_lottie"/>
</LinearLayout>
