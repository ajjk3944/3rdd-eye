<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.percentlayout.widget.PercentRelativeLayout
        android:id="@+id/rlFirstHeader"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="10dp"
        android:layout_marginRight="20dp"
        android:layout_marginBottom="10dp">
        <TextView
            android:textSize="15dp"
            android:textStyle="normal"
            android:textColor="@color/network_rank_headers"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:id="@+id/tvOperatorHeader"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:text="@string/operator"
            android:lines="1"
            android:singleLine="true"
            android:layout_centerVertical="true"
            app:layout_widthPercent="34%"/>
        <RelativeLayout
            android:gravity="end|center_vertical"
            android:id="@+id/rlDownload"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_toRightOf="@+id/tvOperatorHeader"
            app:layout_widthPercent="32%">
            <ImageView
                android:id="@+id/ivSortArrowDownload"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="10dp"
                android:layout_centerVertical="true"/>
            <TextView
                android:textSize="14dp"
                android:textStyle="normal"
                android:textColor="@color/network_rank_headers"
                android:ellipsize="end"
                android:id="@+id/tvDownloadHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/download"
                android:lines="1"
                android:singleLine="false"
                android:layout_toRightOf="@+id/ivSortArrowDownload"/>
            <TextView
                android:textSize="10dp"
                android:textStyle="normal"
                android:textColor="@color/network_rank_headers"
                android:ellipsize="end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="(Mbps)"
                android:lines="1"
                android:singleLine="false"
                android:layout_below="@+id/tvDownloadHeader"
                android:layout_alignRight="@+id/tvDownloadHeader"/>
        </RelativeLayout>
        <RelativeLayout
            android:gravity="end|center_vertical"
            android:id="@+id/rlUpload"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:clickable="true"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_toRightOf="@+id/rlDownload"
            app:layout_widthPercent="34%">
            <ImageView
                android:id="@+id/ivSortArrowUpload"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="10dp"
                android:layout_centerVertical="true"/>
            <TextView
                android:textSize="14dp"
                android:textStyle="normal"
                android:textColor="@color/network_rank_headers"
                android:ellipsize="end"
                android:id="@+id/tvUploadHeader"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/upload"
                android:lines="1"
                android:singleLine="false"
                android:layout_toRightOf="@+id/ivSortArrowUpload"/>
            <TextView
                android:textSize="10dp"
                android:textStyle="normal"
                android:textColor="@color/network_rank_headers"
                android:ellipsize="end"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="(Mbps)"
                android:lines="1"
                android:singleLine="false"
                android:layout_below="@+id/tvUploadHeader"
                android:layout_alignRight="@+id/tvUploadHeader"/>
        </RelativeLayout>
    </androidx.percentlayout.widget.PercentRelativeLayout>
    <LinearLayout
        android:gravity="center"
        android:id="@+id/llFilterHeader"
        android:background="#ffb733"
        android:layout_width="match_parent"
        android:layout_height="34dp"
        android:weightSum="10"
        android:layout_below="@+id/rlFirstHeader">
        <TextView
            android:textSize="16dp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:ellipsize="end"
            android:gravity="right"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginRight="8dp"
            android:text="@string/network_rank_showing_data_only_for"
            android:lines="1"
            android:singleLine="true"
            android:layout_weight="6"/>
        <TextView
            android:textSize="16dp"
            android:textStyle="bold"
            android:textColor="@color/white"
            android:ellipsize="end"
            android:id="@+id/tvSelectedNetworkTypes"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="2G/3G/4G"
            android:lines="1"
            android:singleLine="true"
            android:layout_weight="3"/>
    </LinearLayout>
    <ListView
        android:id="@+id/lvNetworkRankPage1"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:listSelector="@android:color/transparent"
        android:layout_below="@+id/llFilterHeader"/>
</RelativeLayout>
