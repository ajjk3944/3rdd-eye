<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:clipChildren="false"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <View
        android:id="@+id/view_micro_submit_divider"
        android:layout_width="0dp"
        android:layout_height="@dimen/survicate_micro_divider_height"
        android:layout_marginStart="@dimen/survicate_micro_space_xl"
        android:layout_marginEnd="@dimen/survicate_micro_space_xl"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <LinearLayout
        android:gravity="end"
        android:orientation="horizontal"
        android:clipChildren="false"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/view_micro_submit_divider">
        <com.survicate.surveys.presentation.widget.MicroNavigationButtonBack
            android:id="@+id/view_micro_submit_button_back"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/survicate_micro_space_xl"
            android:layout_marginBottom="@dimen/survicate_micro_space_xl"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/survicate_micro_space_xl"
            android:layout_marginVertical="@dimen/survicate_micro_space_xl"/>
        <Button
            android:id="@+id/view_micro_submit_button_submit"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/survicate_micro_space_xl"
            android:layout_marginBottom="@dimen/survicate_micro_space_xl"
            android:text="@string/survicate_button_submit"
            android:layout_weight="1"
            android:layout_marginStart="@dimen/survicate_micro_space_xl"
            android:layout_marginEnd="@dimen/survicate_micro_space_xl"
            android:layout_marginVertical="@dimen/survicate_micro_space_xl"
            style="@style/Widget.Survicate.Button.Micro"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>
