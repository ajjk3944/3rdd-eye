<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <Space
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"/>
    <TextView
        android:textAppearance="@style/TextAppearance.Survicate.DateComponent.Micro"
        android:id="@+id/view_micro_survey_point_date_content_selected_year"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:importantForAccessibility="no"/>
    <Space
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.75"/>
    <TextView
        android:textAppearance="@style/TextAppearance.Survicate.DateComponent.Micro.Divider"
        android:id="@+id/view_micro_survey_point_date_content_year_month_divider"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="/"
        android:importantForAccessibility="no"/>
    <Space
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.75"/>
    <TextView
        android:textAppearance="@style/TextAppearance.Survicate.DateComponent.Micro"
        android:id="@+id/view_micro_survey_point_date_content_selected_month"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:importantForAccessibility="no"/>
    <Space
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.75"/>
    <TextView
        android:textAppearance="@style/TextAppearance.Survicate.DateComponent.Micro.Divider"
        android:id="@+id/view_micro_survey_point_date_content_month_day_divider"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="/"
        android:importantForAccessibility="no"/>
    <Space
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="0.75"/>
    <TextView
        android:textAppearance="@style/TextAppearance.Survicate.DateComponent.Micro"
        android:id="@+id/view_micro_survey_point_date_content_selected_day"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:importantForAccessibility="no"/>
    <Space
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"/>
</LinearLayout>
