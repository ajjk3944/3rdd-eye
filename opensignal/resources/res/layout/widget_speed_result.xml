<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.staircase3.opensignal.goldstar.widget.NetworkInfoView
        android:id="@+id/networkInfoView"
        android:paddingTop="@dimen/standard_margin"
        android:paddingBottom="@dimen/standard_margin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toStartOf="@+id/guidelineLatency"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.staircase3.opensignal.goldstar.widget.DateTimeView
        android:id="@+id/dateTimeView"
        android:paddingTop="@dimen/standard_margin"
        android:paddingBottom="@dimen/standard_margin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@+id/networkInfoView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/guidelineLatency"
        app:layout_constraintTop_toTopOf="@+id/networkInfoView"/>
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@+id/guidelineLatency"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="0.5"/>
    <View
        android:id="@+id/DataCollectionSeparator"
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:layout_marginBottom="@dimen/standard_margin"
        app:layout_constraintTop_toBottomOf="@+id/networkInfoView"
        style="@style/Divider.dark"/>
    <com.staircase3.opensignal.goldstar.widget.TestStatusView
        android:id="@+id/testStatusView"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toStartOf="@+id/guidelineLatency"
        app:layout_constraintTop_toBottomOf="@+id/DataCollectionSeparator"/>
    <TextView
        android:id="@+id/downloadLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/standard_margin"
        android:layout_marginTop="@dimen/standard_margin"
        android:text="@string/download"
        android:layout_marginStart="@dimen/standard_margin"
        app:layout_constraintEnd_toStartOf="@+id/guideline35"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/testStatusView"
        style="@style/SpeedResult.Label"/>
    <TextView
        android:id="@+id/uploadLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/upload"
        app:layout_constraintEnd_toStartOf="@+id/guideline70"
        app:layout_constraintStart_toStartOf="@+id/guideline35"
        app:layout_constraintTop_toTopOf="@+id/downloadLabel"
        style="@style/SpeedResult.Label"/>
    <TextView
        android:id="@+id/latencyLabel"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/latency"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="@+id/guideline70"
        app:layout_constraintTop_toTopOf="@+id/downloadLabel"
        style="@style/SpeedResult.Label"/>
    <TextView
        android:id="@+id/downloadValueView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toStartOf="@+id/guideline35"
        app:layout_constraintStart_toStartOf="@+id/downloadLabel"
        app:layout_constraintTop_toBottomOf="@+id/downloadLabel"
        style="@style/SpeedResult.Value"/>
    <TextView
        android:id="@+id/uploadValueView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toStartOf="@+id/guideline70"
        app:layout_constraintStart_toStartOf="@+id/guideline35"
        app:layout_constraintTop_toTopOf="@+id/downloadValueView"
        style="@style/SpeedResult.Value"/>
    <TextView
        android:id="@+id/latencyValueView"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="@+id/latencyLabel"
        app:layout_constraintStart_toStartOf="@+id/guideline70"
        app:layout_constraintTop_toTopOf="@+id/downloadValueView"
        style="@style/SpeedResult.Value"/>
    <TextView
        android:id="@+id/downloadUnitView"
        android:paddingBottom="@dimen/small_margin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/mbps"
        app:layout_constraintEnd_toStartOf="@+id/guideline35"
        app:layout_constraintStart_toStartOf="@+id/downloadLabel"
        app:layout_constraintTop_toBottomOf="@+id/downloadValueView"
        style="@style/SpeedResult.Unit"/>
    <TextView
        android:id="@+id/uploadUnitView"
        android:paddingBottom="@dimen/small_margin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/mbps"
        app:layout_constraintEnd_toStartOf="@+id/guideline70"
        app:layout_constraintStart_toStartOf="@+id/guideline35"
        app:layout_constraintTop_toTopOf="@+id/downloadUnitView"
        style="@style/SpeedResult.Unit"/>
    <TextView
        android:paddingBottom="@dimen/small_margin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/ms"
        app:layout_constraintEnd_toEndOf="@+id/latencyValueView"
        app:layout_constraintStart_toStartOf="@+id/guideline70"
        app:layout_constraintTop_toTopOf="@+id/downloadUnitView"
        style="@style/SpeedResult.Unit"/>
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@+id/guideline35"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="0.35"/>
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@+id/guideline70"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="0.7"/>
</androidx.constraintlayout.widget.ConstraintLayout>
