<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/dialog_background"
    android:padding="@dimen/padding_large"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:id="@+id/locationServicesDisabledTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/standard_margin"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        style="@style/TextTypography.TypeH2M"/>
    <TextView
        android:gravity="center_horizontal"
        android:id="@+id/locationServicesDisabledText"
        android:paddingLeft="@dimen/padding_xlarge"
        android:paddingRight="@dimen/padding_xlarge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/large_margin"
        app:layout_constraintEnd_toEndOf="@+id/takeMeToSettingsButton"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="@+id/takeMeToSettingsButton"
        app:layout_constraintTop_toBottomOf="@+id/locationServicesDisabledTitle"
        style="@style/TextTypography.TypeP1R"/>
    <Button
        android:textAppearance="@style/MaterialButtonStyle"
        android:id="@+id/takeMeToSettingsButton"
        android:layout_width="0dp"
        android:layout_height="@dimen/coverage_message_button_height"
        android:layout_margin="@dimen/standard_margin"
        android:text="@string/coverage_location_disabled_button"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.5"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/locationServicesDisabledText"
        style="@style/MaterialButtonStyle"/>
</androidx.constraintlayout.widget.ConstraintLayout>
