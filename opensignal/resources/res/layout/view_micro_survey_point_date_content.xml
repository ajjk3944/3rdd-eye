<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.survicate.surveys.presentation.widget.MicroQuestionHeader
        android:id="@+id/view_micro_survey_point_date_content_header"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <include
        android:id="@+id/view_micro_survey_point_date_content_selected_date_container"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHeight_min="@dimen/survicate_micro_question_date_input_min_height"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/view_micro_survey_point_date_content_header"
        app:layout_constraintWidth_max="@dimen/survicate_micro_question_date_input_max_width"
        layout="@layout/view_micro_selected_date_container"/>
    <com.survicate.surveys.presentation.widget.MicroSurvicateCommentField
        android:id="@+id/view_micro_survey_point_date_content_comment"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/survicate_micro_space_md"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/view_micro_survey_point_date_content_selected_date_container"
        app:survicateCommentFieldStyle="standalone"/>
</androidx.constraintlayout.widget.ConstraintLayout>
