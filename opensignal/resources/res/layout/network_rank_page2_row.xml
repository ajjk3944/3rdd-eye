<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingTop="8dp"
    android:paddingBottom="8dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.percentlayout.widget.PercentRelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginRight="20dp">
        <RelativeLayout
            android:id="@+id/operatorLogoBackground"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"
            android:layout_centerVertical="true"
            app:layout_widthPercent="15%">
            <ImageView
                android:id="@+id/ivOperatorLogoBackground"
                android:background="@drawable/ic_blue_background_circle_transparent"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:scaleType="centerCrop"/>
            <ImageView
                android:id="@+id/operatorLogo"
                android:layout_width="25dp"
                android:layout_height="25dp"
                android:layout_marginLeft="7.5dp"
                android:src="@drawable/ic_logo_placeholder"
                android:scaleType="centerCrop"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
        <TextView
            android:textColor="@color/black"
            android:ellipsize="end"
            android:gravity="end|center_vertical"
            android:id="@+id/tvLatency"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="22"
            android:lines="1"
            android:singleLine="true"
            android:layout_toRightOf="@+id/operatorLogoBackground"
            android:layout_centerVertical="true"
            app:layout_widthPercent="32%"/>
        <LinearLayout
            android:gravity="end|center_vertical"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"
            android:layout_toRightOf="@+id/tvLatency"
            app:layout_widthPercent="32%">
            <com.staircase3.opensignal.ui.views.CustBarsViewNetworkRank
                android:id="@+id/networkRankBars"
                android:background="@color/white"
                android:layout_width="60dp"
                android:layout_height="35dp"
                app:cellsNotWifi="true"/>
        </LinearLayout>
    </androidx.percentlayout.widget.PercentRelativeLayout>
</RelativeLayout>
