<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:orientation="horizontal"
        android:id="@+id/rlToolbar"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:weightSum="10">
        <LinearLayout
            android:gravity="center_vertical"
            android:background="@color/primary_3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="5">
            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="4dp"
                android:layout_toRightOf="@+id/tvType"
                android:layout_centerVertical="true">
                <ImageView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_centerInParent="true"/>
                <ImageView
                    android:id="@+id/vBackArrowFiltersDialog"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginLeft="4dp"
                    android:layout_marginTop="2dp"
                    app:srcCompat="@drawable/ic_arrow_back_white_36dp"/>
            </RelativeLayout>
            <TextView
                android:layout_marginLeft="10dp"
                android:text="@string/operator"
                android:layout_centerVertical="true"
                style="@style/NetworkFilterHeader"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_vertical"
            android:background="@color/primary_3"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="5">
            <TextView
                android:id="@+id/tvType"
                android:layout_margin="12dp"
                android:text="@string/network_filter_type"
                android:layout_centerVertical="true"
                style="@style/NetworkFilterHeader"/>
            <RelativeLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="1dp"
                android:layout_toRightOf="@+id/tvType">
                <ImageView
                    android:background="@drawable/ic_info_network_rank"
                    android:layout_width="18dp"
                    android:layout_height="18dp"
                    android:layout_centerInParent="true"/>
                <View
                    android:id="@+id/vShowNetworkTypesInfo"
                    android:background="?attr/selectableItemBackgroundBorderless"
                    android:layout_width="36dp"
                    android:layout_height="36dp"/>
            </RelativeLayout>
        </LinearLayout>
    </LinearLayout>
    <View
        android:background="@color/osm_grey"
        android:layout_width="match_parent"
        android:layout_height="0.5dp"
        android:layout_below="@+id/rlToolbar"/>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:weightSum="10"
        android:layout_below="@+id/rlToolbar">
        <ScrollView
            android:scrollbarAlwaysDrawVerticalTrack="true"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_weight="5"
            android:layout_below="@+id/rlToolbar">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <RadioGroup
                    android:textColor="@drawable/radio_button_text_color"
                    android:id="@+id/rgOperators"
                    android:paddingRight="20dp"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:layout_marginLeft="10dp"/>
            </LinearLayout>
        </ScrollView>
        <View
            android:background="@color/osm_grey"
            android:layout_width="0.5dp"
            android:layout_height="match_parent"/>
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <CheckBox
                android:theme="@style/FilterStyledCheckBox"
                android:id="@+id/cb2G3G"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:layout_marginTop="8dp"
                android:layout_marginRight="5dp"
                android:layout_marginBottom="5dp"
                android:checked="true"
                android:text="2G / 3G"/>
            <CheckBox
                android:theme="@style/FilterStyledCheckBox"
                android:id="@+id/cb4G"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:layout_marginTop="12dp"
                android:layout_marginRight="5dp"
                android:layout_marginBottom="5dp"
                android:checked="true"
                android:text="4G"/>
            <CheckBox
                android:theme="@style/FilterStyledCheckBox"
                android:id="@+id/cb5G"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:layout_marginTop="12dp"
                android:layout_marginRight="5dp"
                android:layout_marginBottom="5dp"
                android:checked="true"
                android:text="5G"/>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
