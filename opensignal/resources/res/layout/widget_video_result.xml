<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <com.staircase3.opensignal.goldstar.widget.NetworkInfoView
        android:id="@+id/networkInfoView"
        android:paddingTop="@dimen/standard_margin"
        android:paddingBottom="@dimen/standard_margin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintEnd_toStartOf="@+id/guidelineLatency"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>
    <com.staircase3.opensignal.goldstar.widget.DateTimeView
        android:id="@+id/dateTimeView"
        android:paddingTop="@dimen/standard_margin"
        android:paddingBottom="@dimen/standard_margin"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="@+id/networkInfoView"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/guidelineLatency"
        app:layout_constraintTop_toTopOf="@+id/networkInfoView"/>
    <androidx.constraintlayout.widget.Guideline
        android:orientation="vertical"
        android:id="@+id/guidelineLatency"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintGuide_percent="0.5"/>
    <View
        android:id="@+id/DataCollectionSeparator"
        android:layout_marginTop="@dimen/standard_margin"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/dateTimeView"
        style="@style/Divider.dark"/>
    <TextView
        android:textSize="@dimen/video_result_text"
        android:textColor="@color/secondary_2"
        android:id="@+id/resolutionLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/standard_margin"
        android:layout_marginTop="@dimen/standard_margin"
        android:layout_marginRight="@dimen/small_margin"
        android:text="@string/resolution"
        android:layout_marginStart="@dimen/standard_margin"
        android:layout_marginEnd="@dimen/small_margin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/DataCollectionSeparator"/>
    <TextView
        android:id="@+id/resolutionTextView"
        android:layout_marginLeft="@dimen/standard_margin"
        android:layout_marginTop="@dimen/small_margin"
        android:layout_marginStart="@dimen/standard_margin"
        android:layout_marginEnd="@dimen/small_margin"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/resolutionLabel"
        style="@style/LabelTypography.MagentaRectangle"/>
    <TextView
        android:textSize="@dimen/video_result_text"
        android:textColor="@color/secondary_2"
        android:id="@+id/testDurationTextView"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/test_duration"
        app:layout_constraintEnd_toStartOf="@+id/guidelineLatency"
        app:layout_constraintStart_toEndOf="@+id/resolutionLabel"
        app:layout_constraintTop_toTopOf="@+id/resolutionLabel"/>
    <TextView
        android:id="@+id/durationTextView"
        android:layout_width="wrap_content"
        android:layout_marginTop="@dimen/small_margin"
        app:layout_constraintEnd_toStartOf="@+id/guidelineLatency"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toStartOf="@+id/testDurationTextView"
        app:layout_constraintTop_toBottomOf="@+id/testDurationTextView"
        style="@style/LabelTypography.MagentaRectangle"/>
    <ImageView
        android:id="@+id/loadTimeImageView"
        android:layout_width="@dimen/event_image_size_in_result"
        android:layout_height="@dimen/event_image_size_in_result"
        android:layout_marginTop="@dimen/large_margin"
        android:scaleType="fitCenter"
        app:layout_constraintEnd_toStartOf="@+id/bufferingTimeImageView"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/resolutionTextView"
        app:srcCompat="@drawable/video_initialisation_icon"/>
    <TextView
        android:textSize="18sp"
        android:textColor="@color/white"
        android:id="@+id/loadTimeLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/small_margin"
        android:text="@string/loading_label"
        app:layout_constraintEnd_toEndOf="@+id/loadTimeImageView"
        app:layout_constraintStart_toStartOf="@+id/loadTimeImageView"
        app:layout_constraintTop_toBottomOf="@+id/loadTimeImageView"/>
    <TextView
        android:id="@+id/loadTimeTextView"
        android:layout_marginTop="@dimen/small_margin"
        app:layout_constraintEnd_toEndOf="@+id/loadTimeImageView"
        app:layout_constraintStart_toStartOf="@+id/loadTimeImageView"
        app:layout_constraintTop_toBottomOf="@+id/loadTimeLabel"
        style="@style/LabelTypography.MagentaRectangle"/>
    <ImageView
        android:id="@+id/bufferingTimeImageView"
        android:layout_width="@dimen/event_image_size_in_result"
        android:layout_height="@dimen/event_image_size_in_result"
        android:scaleType="fitCenter"
        android:layout_marginStart="@dimen/small_margin"
        android:layout_marginEnd="@dimen/small_margin"
        app:layout_constraintEnd_toStartOf="@+id/playbackTimeImageView"
        app:layout_constraintStart_toEndOf="@+id/loadTimeImageView"
        app:layout_constraintTop_toTopOf="@+id/loadTimeImageView"
        app:srcCompat="@drawable/ic_stalling_buffering"/>
    <TextView
        android:textSize="18sp"
        android:textColor="@color/white"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/buffering_label"
        app:layout_constraintEnd_toEndOf="@+id/bufferingTimeImageView"
        app:layout_constraintStart_toStartOf="@+id/bufferingTimeImageView"
        app:layout_constraintTop_toTopOf="@+id/loadTimeLabel"/>
    <TextView
        android:id="@+id/bufferingTimeTextView"
        app:layout_constraintEnd_toEndOf="@+id/bufferingTimeImageView"
        app:layout_constraintStart_toStartOf="@+id/bufferingTimeImageView"
        app:layout_constraintTop_toTopOf="@+id/loadTimeTextView"
        style="@style/LabelTypography.MagentaRectangle"/>
    <ImageView
        android:id="@+id/playbackTimeImageView"
        android:layout_width="@dimen/event_image_size_in_result"
        android:layout_height="@dimen/event_image_size_in_result"
        android:scaleType="fitCenter"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@+id/bufferingTimeImageView"
        app:layout_constraintTop_toTopOf="@+id/loadTimeImageView"
        app:srcCompat="@drawable/video_playback_icon"/>
    <TextView
        android:textSize="18sp"
        android:textColor="@color/white"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/playback_label"
        app:layout_constraintEnd_toEndOf="@+id/playbackTimeImageView"
        app:layout_constraintStart_toStartOf="@+id/playbackTimeImageView"
        app:layout_constraintTop_toTopOf="@+id/loadTimeLabel"/>
    <TextView
        android:id="@+id/playbackTimeTextView"
        app:layout_constraintEnd_toEndOf="@+id/playbackTimeImageView"
        app:layout_constraintStart_toStartOf="@+id/playbackTimeImageView"
        app:layout_constraintTop_toTopOf="@+id/loadTimeTextView"
        style="@style/LabelTypography.MagentaRectangle"/>
    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/standard_margin"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/loadTimeTextView"/>
</androidx.constraintlayout.widget.ConstraintLayout>
