<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="@dimen/big_pin_width"
    android:layout_height="@dimen/big_pin_height">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/pinBackground"
        android:layout_width="@dimen/big_pin_width"
        android:layout_height="@dimen/big_pin_height"
        android:layout_centerInParent="true"
        app:srcCompat="@drawable/ic_pin_shape"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/pinIcon"
        android:layout_width="@dimen/big_pin_icon_size"
        android:layout_height="@dimen/big_pin_icon_size"
        android:layout_marginTop="@dimen/big_pin_icon_margin_top"
        android:layout_alignTop="@+id/pinBackground"
        android:layout_centerHorizontal="true"/>
</RelativeLayout>
