<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.cardview.widget.CardView
        android:id="@+id/layoutToolbar"
        android:background="@color/os4_blue_main"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardCornerRadius="0dp"
        app:cardElevation="4dp"
        app:contentPadding="-8dp">
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <androidx.appcompat.widget.Toolbar
                android:id="@+id/toolbarSpeedtestList"
                android:background="@color/primary_3"
                android:layout_width="match_parent"
                android:layout_height="?attr/actionBarSize">
                <TextView
                    android:layout_gravity="center"
                    android:id="@+id/toolbarTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    style="@style/ToolbarGoldStar"/>
            </androidx.appcompat.widget.Toolbar>
            <View
                android:layout_marginTop="@dimen/keyline_5_6"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/toolbarTowers"
                style="@style/Divider.dark"/>
            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/ivSpeedtestListMap"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="36dp"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:elevation="5dp"
                app:srcCompat="@drawable/ic_map"
                app:tint="@color/neutral_1"/>
        </RelativeLayout>
    </androidx.cardview.widget.CardView>
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/listTowers"
        android:background="@color/primary_3"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/layoutToolbar"/>
</RelativeLayout>
