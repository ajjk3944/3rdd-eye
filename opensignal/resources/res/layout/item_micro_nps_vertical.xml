<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:padding="@dimen/survicate_micro_space_s"
    android:focusable="true"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="@dimen/survicate_micro_space_xs"
    android:minHeight="@dimen/survicate_micro_question_nps_vertical_min_height">
    <TextView
        android:textAppearance="@style/TextAppearance.Survicate.QuestionLegend.Label.Micro"
        android:gravity="center"
        android:id="@+id/item_micro_nps_vertical_label"
