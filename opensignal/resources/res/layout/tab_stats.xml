<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <View
        android:id="@+id/dumb_centre"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_centerInParent="true"/>
    <Spinner
        android:theme="@style/customSpinnerTheme"
        android:id="@+id/stat_type_spinner"
        android:paddingLeft="3dp"
        android:paddingRight="15dp"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_marginLeft="@dimen/stat_spinner_marginleft"
        android:layout_marginTop="0dp"
        android:layout_marginRight="-30dp"
        android:layout_marginBottom="0dp"
        android:minWidth="200dp"
        android:layout_alignRight="@+id/dumb_centre"
        android:layout_alignParentTop="true"/>
    <View
        android:background="@color/os4_blue_accent_bright"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_below="@+id/stat_type_spinner"
        android:layout_alignLeft="@+id/stat_type_spinner"
        android:layout_alignRight="@+id/stat_type_spinner"/>
    <Spinner
        android:theme="@style/customSpinnerTheme"
        android:id="@+id/time_period_spinner"
        android:paddingLeft="-2dp"
        android:paddingRight="16dp"
        android:layout_width="wrap_content"
        android:layout_height="44dp"
        android:layout_marginLeft="@dimen/stat_spinnertwo_marginleft"
        android:layout_marginTop="0dp"
        android:layout_marginRight="@dimen/stat_spinner_marginleft"
        android:layout_marginBottom="0dp"
        android:minWidth="120dp"
        android:layout_alignLeft="@+id/dumb_centre"
        android:layout_alignParentTop="true"/>
    <View
        android:background="@color/os4_blue_accent_bright"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:layout_below="@+id/time_period_spinner"
        android:layout_alignLeft="@+id/time_period_spinner"
        android:layout_alignRight="@+id/time_period_spinner"/>
    <RelativeLayout
        android:id="@+id/stat_graphic"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/keyline_3"
        android:layout_below="@+id/stat_type_spinner"
        android:layout_centerHorizontal="true"/>
    <View
        android:id="@+id/dialogOverlay"
        android:background="@color/dialog_overlay"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_below="@+id/stat_type_spinner"/>
    <RelativeLayout
        android:id="@+id/dialogContainer"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_centerInParent="true">
        <include layout="@layout/tab_stat_mod_partialdialog"/>
    </RelativeLayout>
</RelativeLayout>
