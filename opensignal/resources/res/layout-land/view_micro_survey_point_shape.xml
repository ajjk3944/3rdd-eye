<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <androidx.cardview.widget.CardView
        android:layout_gravity="bottom"
        android:id="@+id/view_micro_survey_point_shape_card"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="@android:color/transparent"
        app:cardCornerRadius="0dp"
        app:cardElevation="0dp"
        app:cardMaxElevation="0dp"
        app:cardPreventCornerOverlap="false"
        app:cardUseCompatPadding="true">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/view_micro_survey_point_shape_container"
            android:background="@drawable/survicate_micro_survey_background_rounded"
            android:layout_width="match_parent"
            android:layout_height="match_parent">
            <com.survicate.surveys.presentation.widget.MicroSurveyHeader
                android:id="@+id/view_micro_survey_point_shape_survey_header"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
            <androidx.core.widget.NestedScrollView
                android:scrollbarThumbVertical="@drawable/survicate_micro_scroll_bar_thumb"
                android:scrollbars="vertical"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/survicate_micro_space_xs"
                android:fillViewport="true"
                android:layout_weight="1"
                android:overScrollMode="ifContentScrolls">
                <LinearLayout
                    android:orientation="vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <FrameLayout
                        android:id="@+id/view_micro_survey_point_shape_wrapper"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1">
                        <LinearLayout
                            android:layout_gravity="center_vertical"
                            android:orientation="vertical"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <com.survicate.surveys.presentation.shape.micro.MicroSurveyPointShapeContentView
                                android:id="@+id/view_micro_survey_point_shape_content"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:layout_marginLeft="@dimen/survicate_micro_page_padding"
                                android:layout_marginRight="@dimen/survicate_micro_page_padding"
                                android:layout_marginBottom="@dimen/survicate_micro_space_xl"
                                android:layout_marginHorizontal="@dimen/survicate_micro_page_padding"/>
                        </LinearLayout>
                    </FrameLayout>
                    <com.survicate.surveys.presentation.widget.MicroDisclaimerView
                        android:id="@+id/view_micro_survey_point_shape_disclaimer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                    <com.survicate.surveys.presentation.widget.MicroSubmitView
                        android:id="@+id/view_micro_survey_point_shape_submit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                    <com.survicate.surveys.presentation.widget.MicroSurveyFooter
                        android:id="@+id/view_micro_survey_point_shape_footer"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"/>
                </LinearLayout>
            </androidx.core.widget.NestedScrollView>
        </LinearLayout>
    </androidx.cardview.widget.CardView>
</FrameLayout>
