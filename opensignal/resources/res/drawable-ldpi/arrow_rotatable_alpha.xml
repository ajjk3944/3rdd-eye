<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <item
        android:height="200dp"
        android:width="200dp"
        android:top="10dp">
        <rotate
            android:drawable="@drawable/signal_arrow_shadow"
            android:fromDegrees="0"
            android:toDegrees="360"
            android:pivotX="50%"
            android:pivotY="50%"/>
    </item>
    <item
        android:height="200dp"
        android:width="200dp">
        <rotate
            android:drawable="@drawable/ic_signal_arrow"
            android:fromDegrees="0"
            android:toDegrees="360"
            android:pivotX="50%"
            android:pivotY="50%"/>
    </item>
</layer-list>
