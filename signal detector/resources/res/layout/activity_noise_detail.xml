<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/noise_detail_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:contentInsetStartWithNavigation="0dp"
            app:title="@string/string_detail"/>
    </com.google.android.material.appbar.AppBarLayout>
    <RelativeLayout
        android:id="@+id/bottom_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.core.widget.NestedScrollView
            android:scrollbars="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@+id/ad_view"
            app:layout_behavior="com.google.android.material.appbar.AppBarLayout$ScrollingViewBehavior">
            <androidx.appcompat.widget.LinearLayoutCompat
                android:orientation="vertical"
                android:padding="@dimen/dp_10"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <com.lefan.signal.ui.noise.NoiseView
                    android:id="@+id/noise_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/dp_10"
                    android:layout_marginEnd="@dimen/dp_10"/>
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_10"
                    app:cardUseCompatPadding="true">
                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:divider="@drawable/divider_ver"
                        app:dividerPadding="@dimen/dp_10"
                        app:showDividers="middle">
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/dp_10"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">
                            <TextView
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:textSize="13sp"
                                android:ellipsize="end"
                                android:id="@+id/min_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:lines="1"/>
                            <TextView
                                android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
                                android:ellipsize="end"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/dp_8"
                                android:text="@string/min"
                                android:lines="1"/>
                        </LinearLayout>
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/dp_10"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">
                            <TextView
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:textSize="13sp"
                                android:ellipsize="end"
                                android:id="@+id/avg_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:lines="1"/>
                            <TextView
                                android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
                                android:ellipsize="end"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/dp_8"
                                android:text="@string/average"
                                android:lines="1"/>
                        </LinearLayout>
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/dp_10"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">
                            <TextView
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:textSize="13sp"
                                android:ellipsize="end"
                                android:id="@+id/max_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:lines="1"/>
                            <TextView
                                android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
                                android:ellipsize="end"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/dp_8"
                                android:text="@string/max"
                                android:lines="1"/>
                        </LinearLayout>
                    </androidx.appcompat.widget.LinearLayoutCompat>
                </com.google.android.material.card.MaterialCardView>
                <com.lefan.signal.ui.noise.NoiseTrendView
                    android:id="@+id/noise_trend"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_14"/>
                <androidx.appcompat.widget.LinearLayoutCompat
                    android:gravity="center_vertical"
                    android:padding="@dimen/dp_10"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/start_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00:00"/>
                    <com.google.android.material.slider.Slider
                        android:enabled="false"
                        android:id="@+id/step_slider"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:stepSize="1"
                        android:layout_weight="1"
                        android:valueFrom="0"/>
                    <androidx.appcompat.widget.AppCompatTextView
                        android:id="@+id/total_time"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="00:00:00"/>
                </androidx.appcompat.widget.LinearLayoutCompat>
                <androidx.appcompat.widget.AppCompatTextView
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                    android:id="@+id/address_text"
                    android:padding="@dimen/dp_10"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
                <androidx.appcompat.widget.AppCompatTextView
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                    android:id="@+id/time_text"
                    android:padding="@dimen/dp_10"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </androidx.core.widget.NestedScrollView>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/start_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_margin="@dimen/dp_10"
            android:layout_above="@+id/ad_view"
            android:layout_alignParentEnd="true"
            app:icon="@drawable/ic_start"
            app:iconSize="60dp"
            app:iconTint="@null"
            style="@style/Widget.Material3.Button.IconButton"/>
        <com.lefan.ads.banner.BannerView
            android:id="@+id/ad_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            app:admob_bannerId="@string/admob_banner2"
            app:groMore_bannerId="@string/groMore_banner"
            app:tencent_bannerId="@string/tencent_banner2"
            app:yandex_bannerId="@string/yandex_banner2"/>
    </RelativeLayout>
</androidx.appcompat.widget.LinearLayoutCompat>
