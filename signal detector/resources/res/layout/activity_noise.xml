<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/noise_toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:contentInsetStartWithNavigation="0dp"
            app:title="@string/noise"/>
    </com.google.android.material.appbar.AppBarLayout>
    <RelativeLayout
        android:id="@+id/bottom_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.core.widget.NestedScrollView
            android:scrollbars="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@+id/ad_view">
            <androidx.appcompat.widget.LinearLayoutCompat
                android:orientation="vertical"
                android:padding="@dimen/dp_10"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <androidx.appcompat.widget.LinearLayoutCompat
                    android:gravity="center_vertical"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content">
                    <com.google.android.material.card.MaterialCardView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="3"
                        app:cardUseCompatPadding="true"
                        app:contentPadding="@dimen/dp_10">
                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:orientation="vertical"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content">
                            <TextView
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:ellipsize="end"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="@string/noise_value"
                                android:lines="1"
                                android:layout_weight="1"/>
                            <com.lefan.signal.ui.noise.NoiseView
                                android:id="@+id/voice_view"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:layout_margin="@dimen/dp_10"/>
                        </androidx.appcompat.widget.LinearLayoutCompat>
                    </com.google.android.material.card.MaterialCardView>
                    <com.google.android.material.card.MaterialCardView
                        android:id="@+id/history_info_card"
                        android:layout_width="0dp"
                        android:layout_height="match_parent"
                        android:layout_weight="2"
                        app:cardUseCompatPadding="true"
                        app:contentPadding="@dimen/dp_10">
                        <androidx.appcompat.widget.LinearLayoutCompat
                            android:orientation="vertical"
                            android:clickable="false"
                            android:layout_width="match_parent"
                            android:layout_height="match_parent">
                            <androidx.appcompat.widget.LinearLayoutCompat
                                android:gravity="center_vertical"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content">
                                <TextView
                                    android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                    android:ellipsize="end"
                                    android:layout_width="0dp"
                                    android:layout_height="wrap_content"
                                    android:text="@string/speed_history_record"
                                    android:lines="1"
                                    android:layout_weight="1"/>
                                <androidx.appcompat.widget.AppCompatImageView
                                    android:layout_width="wrap_content"
                                    android:layout_height="match_parent"
                                    android:src="@drawable/ic_right"/>
                            </androidx.appcompat.widget.LinearLayoutCompat>
                            <TextView
                                android:gravity="center"
                                android:id="@+id/no_history"
                                android:visibility="gone"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                android:text="@string/no_data_str"/>
                            <androidx.appcompat.widget.LinearLayoutCompat
                                android:gravity="center"
                                android:orientation="vertical"
                                android:id="@+id/has_history"
                                android:layout_width="match_parent"
                                android:layout_height="match_parent"
                                app:divider="@drawable/divider"
                                app:dividerPadding="@dimen/dp_10"
                                app:showDividers="middle">
                                <androidx.appcompat.widget.LinearLayoutCompat
                                    android:gravity="center_vertical"
                                    android:orientation="vertical"
                                    android:layout_width="match_parent"
                                    android:layout_height="0dp"
                                    android:layout_weight="1">
                                    <TextView
                                        android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                                        android:gravity="center_horizontal"
                                        android:id="@+id/today_num"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="0"/>
                                    <TextView
                                        android:gravity="center_horizontal"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/dp_6"
                                        android:text="@string/recently"/>
                                </androidx.appcompat.widget.LinearLayoutCompat>
                                <androidx.appcompat.widget.LinearLayoutCompat
                                    android:gravity="center_vertical"
                                    android:orientation="vertical"
                                    android:layout_width="match_parent"
                                    android:layout_height="0dp"
                                    android:layout_weight="1">
                                    <TextView
                                        android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                                        android:gravity="center_horizontal"
                                        android:id="@+id/total_num"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:text="0"/>
                                    <TextView
                                        android:gravity="center_horizontal"
                                        android:layout_width="match_parent"
                                        android:layout_height="wrap_content"
                                        android:layout_marginTop="@dimen/dp_6"
                                        android:text="@string/total"/>
                                </androidx.appcompat.widget.LinearLayoutCompat>
                            </androidx.appcompat.widget.LinearLayoutCompat>
                        </androidx.appcompat.widget.LinearLayoutCompat>
                    </com.google.android.material.card.MaterialCardView>
                </androidx.appcompat.widget.LinearLayoutCompat>
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_10"
                    app:cardUseCompatPadding="true">
                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        app:divider="@drawable/divider_ver"
                        app:dividerPadding="@dimen/dp_10"
                        app:showDividers="middle">
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/dp_10"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">
                            <TextView
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:textSize="13sp"
                                android:ellipsize="end"
                                android:id="@+id/min_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:lines="1"/>
                            <TextView
                                android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
                                android:ellipsize="end"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/dp_8"
                                android:text="@string/min"
                                android:lines="1"/>
                        </LinearLayout>
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/dp_10"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">
                            <TextView
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:textSize="13sp"
                                android:ellipsize="end"
                                android:id="@+id/avg_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:lines="1"/>
                            <TextView
                                android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
                                android:ellipsize="end"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/dp_8"
                                android:text="@string/average"
                                android:lines="1"/>
                        </LinearLayout>
                        <LinearLayout
                            android:gravity="center"
                            android:orientation="vertical"
                            android:padding="@dimen/dp_10"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1">
                            <TextView
                                android:textAppearance="@style/TextAppearance.AppCompat.Body1"
                                android:textSize="13sp"
                                android:ellipsize="end"
                                android:id="@+id/max_value"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="0"
                                android:lines="1"/>
                            <TextView
                                android:textAppearance="@style/TextAppearance.MaterialComponents.Body2"
                                android:ellipsize="end"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:layout_marginTop="@dimen/dp_8"
                                android:text="@string/max"
                                android:lines="1"/>
                        </LinearLayout>
                    </androidx.appcompat.widget.LinearLayoutCompat>
                </com.google.android.material.card.MaterialCardView>
                <androidx.appcompat.widget.LinearLayoutCompat
                    android:gravity="center_vertical"
                    android:id="@+id/location_layout"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_10">
                    <androidx.appcompat.widget.AppCompatTextView
                        android:ellipsize="middle"
                        android:id="@+id/address_text"
                        android:padding="@dimen/dp_10"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:text="@string/string_unknown"
                        android:singleLine="false"
                        android:layout_weight="1"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/edit_location"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:icon="@drawable/ic_edit"
                        style="@style/Widget.Material3.Button.IconButton"/>
                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/get_location"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:icon="@drawable/ic_reset"
                        style="@style/Widget.Material3.Button.IconButton"/>
                </androidx.appcompat.widget.LinearLayoutCompat>
                <com.lefan.signal.ui.noise.NoiseTrendView
                    android:id="@+id/voice_trend_view"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_14"/>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </androidx.core.widget.NestedScrollView>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/start_btn"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_10"
            android:layout_above="@+id/ad_view"
            android:layout_marginEnd="@dimen/dp_14"
            android:layout_alignParentEnd="true"
            app:icon="@drawable/ic_start"
            app:iconSize="?attr/actionBarSize"
            app:iconTint="@null"
            style="@style/Widget.Material3.Button.IconButton"/>
        <com.google.android.material.button.MaterialButton
            android:id="@+id/save_btn"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginBottom="@dimen/dp_10"
            android:layout_above="@+id/start_btn"
            android:layout_marginEnd="@dimen/dp_14"
            android:layout_alignParentEnd="true"
            app:icon="@drawable/ic_save_noise"
            app:iconSize="?attr/actionBarSize"
            app:iconTint="@null"
            style="@style/Widget.Material3.Button.IconButton"/>
        <com.lefan.ads.banner.BannerView
            android:id="@+id/ad_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            app:admob_bannerId="@string/admob_banner2"
            app:groMore_bannerId="@string/groMore_banner"
            app:tencent_bannerId="@string/tencent_banner2"
            app:yandex_bannerId="@string/yandex_banner2"/>
    </RelativeLayout>
</androidx.appcompat.widget.LinearLayoutCompat>
