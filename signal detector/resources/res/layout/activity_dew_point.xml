<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:contentInsetStartWithNavigation="0dp"
            app:title="@string/humidity_detection"/>
    </com.google.android.material.appbar.AppBarLayout>
    <RelativeLayout
        android:id="@+id/bottom_layout"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.core.widget.NestedScrollView
            android:scrollbars="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_above="@+id/ad_view">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:padding="@dimen/dp_10"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <androidx.appcompat.widget.AppCompatTextView
                    android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                    android:id="@+id/input_type"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/string_parameter"
                    app:layout_constraintTop_toTopOf="parent"/>
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/temperature_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_10"
                    app:cardUseCompatPadding="true"
                    app:contentPadding="@dimen/dp_10"
                    app:layout_constraintEnd_toStartOf="@+id/humidity_card"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/input_type">
                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <androidx.appcompat.widget.AppCompatTextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/temperature"
                            android:singleLine="true"/>
                        <com.lefan.signal.ui.sensor.TemperatureView
                            android:id="@+id/temperature_view"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                        <com.google.android.material.textfield.TextInputLayout
                            android:enabled="false"
                            android:id="@+id/temperature_input_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:suffixText="℃"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/temperature_edit"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="0.00"
                                android:inputType="numberDecimal"
                                android:imeOptions="actionDone"/>
                        </com.google.android.material.textfield.TextInputLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:gravity="center_vertical"
                            android:layout_gravity="center_horizontal"
                            android:id="@+id/temperature_unit_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textOn="℉"
                            android:textOff="℃"
                            android:text="@string/temperature_unit"
                            app:showText="true"
                            app:switchPadding="@dimen/dp_6"/>
                    </androidx.appcompat.widget.LinearLayoutCompat>
                </com.google.android.material.card.MaterialCardView>
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/humidity_card"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    app:cardUseCompatPadding="true"
                    app:contentPadding="@dimen/dp_10"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toEndOf="@+id/temperature_card"
                    app:layout_constraintTop_toTopOf="@+id/temperature_card">
                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <androidx.appcompat.widget.AppCompatTextView
                            android:id="@+id/humidity_title"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/humidity"
                            android:singleLine="true"/>
                        <com.lefan.signal.ui.other.HumidityView2
                            android:id="@+id/humidity_view"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"/>
                        <com.google.android.material.textfield.TextInputLayout
                            android:enabled="false"
                            android:id="@+id/humidity_input_layout"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            app:suffixText="%"
                            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                            <com.google.android.material.textfield.TextInputEditText
                                android:id="@+id/humidity_edit"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:text="100.00"
                                android:inputType="numberDecimal"
                                android:imeOptions="actionDone"/>
                        </com.google.android.material.textfield.TextInputLayout>
                        <com.google.android.material.switchmaterial.SwitchMaterial
                            android:layout_gravity="center_horizontal"
                            android:id="@+id/humidity_unit_switch"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:textOn="g"
                            android:textOff="%"
                            android:text="@string/humidity_type"
                            app:showText="true"
                            app:switchPadding="@dimen/dp_6"/>
                    </androidx.appcompat.widget.LinearLayoutCompat>
                </com.google.android.material.card.MaterialCardView>
                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/pressure_title"
                    android:padding="@dimen/dp_10"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/string_pressure"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/temperature_card"/>
                <com.google.android.material.textfield.TextInputLayout
                    android:enabled="false"
                    android:id="@+id/pressure_input_layout"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="@dimen/dp_10"
                    app:layout_constraintEnd_toStartOf="@+id/pressure_unit_layout"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/pressure_title"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox">
                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/pressure_edit"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="1013.25"
                        android:inputType="numberDecimal"
                        android:imeOptions="actionDone"/>
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/pressure_unit_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/pressure_title"
                    style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
                    <androidx.appcompat.widget.AppCompatAutoCompleteTextView
                        android:id="@+id/pressure_unit"
                        android:focusableInTouchMode="false"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:text="hPa"
                        android:cursorVisible="false"
                        android:inputType="none"/>
                </com.google.android.material.textfield.TextInputLayout>
                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/auto_get_switch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_10"
                    android:text="@string/auto_get"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/pressure_input_layout"
                    app:switchPadding="@dimen/dp_10"
                    app:thumbTextPadding="@dimen/dp_10"/>
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/not_support_card"
                    android:visibility="gone"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardUseCompatPadding="true"
                    app:contentPadding="@dimen/dp_10"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/auto_get_switch">
                    <androidx.appcompat.widget.AppCompatTextView
                        android:layout_gravity="center_horizontal"
                        android:id="@+id/not_support_text"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"/>
                </com.google.android.material.card.MaterialCardView>
                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/dew_point_card"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/dp_10"
                    app:cardUseCompatPadding="true"
                    app:contentPadding="@dimen/dp_4"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/not_support_card">
                    <androidx.appcompat.widget.LinearLayoutCompat
                        android:orientation="vertical"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <androidx.appcompat.widget.AppCompatTextView
                            android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="@string/calculated_value"/>
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/cal_recycler"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/dp_10"
                            android:nestedScrollingEnabled="false"
                            app:layoutManager="androidx.recyclerview.widget.GridLayoutManager"
                            app:spanCount="3"/>
                    </androidx.appcompat.widget.LinearLayoutCompat>
                </com.google.android.material.card.MaterialCardView>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </androidx.core.widget.NestedScrollView>
        <com.lefan.ads.banner.BannerView
            android:id="@+id/ad_view"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_alignParentBottom="true"
            app:admob_bannerId="@string/admob_banner2"
            app:groMore_bannerId="@string/groMore_banner"
            app:tencent_bannerId="@string/tencent_banner2"
            app:yandex_bannerId="@string/yandex_banner2"/>
    </RelativeLayout>
</androidx.appcompat.widget.LinearLayoutCompat>
