<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:gravity="center_vertical"
    android:background="?attr/selectableItemBackground"
    android:padding="@dimen/dp_4"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:divider="@drawable/divider_ver"
    android:showDividers="middle">
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/satellite_country"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="0.7"/>
    <TextView
        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
        android:textSize="12sp"
        android:ellipsize="end"
        android:gravity="center_horizontal"
        android:id="@+id/satellite_svid"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:lines="1"
        android:layout_weight="0.7"/>
    <TextView
        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
        android:textSize="12sp"
        android:ellipsize="end"
        android:gravity="center_horizontal"
        android:id="@+id/satellite_azimuth"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:lines="1"
        android:layout_weight="1"/>
    <TextView
        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
        android:textSize="12sp"
        android:ellipsize="end"
        android:gravity="center_horizontal"
        android:id="@+id/satellite_elevation"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:lines="1"
        android:layout_weight="1"/>
    <TextView
        android:textAppearance="@style/TextAppearance.AppCompat.Body1"
        android:textSize="12sp"
        android:ellipsize="end"
        android:gravity="center_horizontal"
        android:id="@+id/satellite_carrierFrequencyHz"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:lines="1"
        android:layout_weight="1"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/satellite_usedInFix"
        android:padding="2dp"
        android:layout_width="0dp"
        android:layout_height="@dimen/dp_20"
        android:layout_weight="0.7"/>
    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/satellite_cn0DbHz"
        android:padding="@dimen/dp_4"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:max="63"
        android:layout_weight="1"
        app:trackCornerRadius="@dimen/dp_10"/>
</LinearLayout>
