<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:background="?attr/selectableItemBackground"
    android:paddingTop="@dimen/dp_10"
    android:paddingBottom="@dimen/dp_10"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <RelativeLayout
        android:id="@+id/wifi_name_bg"
        android:background="@drawable/wifi_name_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textAppearance="@style/TextAppearance.AppCompat.Body1"
            android:textSize="@dimen/sp_12"
            android:gravity="center"
            android:id="@+id/wifi_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/wifi_encryption"
            android:layout_width="13dp"
            android:layout_height="13dp"
            android:src="@drawable/ic_encryption"
            android:layout_centerVertical="true"
            android:layout_alignParentEnd="true"/>
    </RelativeLayout>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/dp_4"
        app:divider="@drawable/divider_ver"
        app:dividerPadding="@dimen/dp_4"
        app:showDividers="middle">
        <TextView
            android:textSize="11sp"
            android:ellipsize="end"
            android:gravity="center_horizontal"
            android:id="@+id/wifi_mac"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:lines="1"
            android:layout_weight="2"/>
        <TextView
            android:textSize="11sp"
            android:ellipsize="end"
            android:gravity="center_horizontal"
            android:id="@+id/wifi_frequency"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:lines="1"
            android:layout_weight="1"/>
        <TextView
            android:textSize="11sp"
            android:ellipsize="end"
            android:gravity="center_horizontal"
            android:id="@+id/wifi_channel"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:lines="1"
            android:layout_weight="1"/>
        <TextView
            android:textSize="11sp"
            android:ellipsize="end"
            android:gravity="center_horizontal"
            android:id="@+id/wifi_signal_val"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:lines="1"
            android:layout_weight="1"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</LinearLayout>
