<?xml version="1.0" encoding="utf-8"?>
<com.google.android.gms.ads.nativead.NativeAdView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:id="@+id/admob_native_view"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <androidx.constraintlayout.widget.ConstraintLayout
        android:padding="@dimen/dp_5"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.gms.ads.nativead.MediaView
            android:layout_gravity="center_horizontal"
            android:id="@+id/admob_ad_media"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            app:layout_constraintDimensionRatio="16:9"
            app:layout_constraintTop_toTopOf="parent"/>
        <TextView
            android:textAppearance="@style/TextAppearance.AppCompat.Small"
            android:textColor="#dcdcdc"
            android:ellipsize="end"
            android:id="@+id/admob_ad_body"
            android:background="@drawable/ad_body_shape"
            android:padding="@dimen/dp_4"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:lines="1"
            app:layout_constraintBottom_toBottomOf="@+id/admob_ad_media"/>
        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/admob_ad_app_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:adjustViewBounds="true"
            app:layout_constraintBottom_toBottomOf="@+id/admob_ad_linear1"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="@+id/admob_ad_headline"/>
        <TextView
            android:textAppearance="@style/TextAppearance.MaterialComponents.Body1"
            android:ellipsize="end"
            android:id="@+id/admob_ad_headline"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/dp_5"
            android:lines="1"
            android:textAlignment="viewStart"
            android:layout_marginStart="@dimen/ads_dp_10"
            app:layout_constraintEnd_toStartOf="@+id/admob_ad_call_to_action"
            app:layout_constraintStart_toEndOf="@+id/admob_ad_app_icon"
            app:layout_constraintTop_toBottomOf="@+id/admob_ad_media"/>
        <LinearLayout
            android:gravity="center_vertical"
            android:id="@+id/admob_ad_linear1"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            app:layout_constraintEnd_toStartOf="@+id/admob_ad_call_to_action"
            app:layout_constraintStart_toStartOf="@+id/admob_ad_headline"
            app:layout_constraintTop_toBottomOf="@+id/admob_ad_headline">
            <TextView
                android:textSize="13sp"
                android:ellipsize="end"
                android:id="@+id/admob_ad_advertiser"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:lines="1"/>
            <RatingBar
                android:id="@+id/admob_ad_stars"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:numStars="5"
                android:stepSize="0.5"
                android:isIndicator="true"
                style="?android:attr/ratingBarStyleSmall"/>
            <TextView
                android:textSize="12sp"
                android:id="@+id/admob_ad_price"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="@dimen/ads_dp_10"/>
            <TextView
                android:textSize="12sp"
                android:ellipsize="end"
                android:id="@+id/admob_ad_store"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:lines="1"
                android:layout_marginStart="@dimen/ads_dp_10"/>
        </LinearLayout>
        <com.google.android.material.button.MaterialButton
            android:textSize="12sp"
            android:textColor="#0033cc"
            android:id="@+id/admob_ad_call_to_action"
            android:layout_width="wrap_content"
            android:layout_height="0dp"
            android:maxHeight="@dimen/ads_dp_40"
            app:layout_constraintBottom_toBottomOf="@+id/admob_ad_linear1"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="@+id/admob_ad_headline"
            style="@style/Widget.MaterialComponents.Button.TextButton"/>
    </androidx.constraintlayout.widget.ConstraintLayout>
    <androidx.appcompat.widget.AppCompatTextView
        android:textSize="12sp"
        android:textColor="#fff"
        android:background="#2f80e9"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/ad_attribution"
        android:paddingStart="@dimen/dp_4"
        android:paddingEnd="@dimen/dp_4"/>
</com.google.android.gms.ads.nativead.NativeAdView>
