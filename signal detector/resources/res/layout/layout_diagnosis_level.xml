<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <TextView
        android:textAppearance="@style/TextAppearance.Material3.BodySmall"
        android:id="@+id/diagnosis_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="@dimen/dp_10"/>
    <View
        android:id="@+id/v_diagnosis_one"
        android:background="@drawable/bg_shape_diagnose_check_level"
        android:layout_width="@dimen/dp_6"
        android:layout_height="@dimen/dp_6"/>
    <View
        android:id="@+id/v_diagnosis_two"
        android:background="@drawable/bg_shape_diagnose_check_level"
        android:layout_width="@dimen/dp_6"
        android:layout_height="@dimen/dp_6"
        android:layout_marginStart="@dimen/dp_4"/>
    <View
        android:id="@+id/v_diagnosis_three"
        android:background="@drawable/bg_shape_diagnose_check_level"
        android:layout_width="@dimen/dp_6"
        android:layout_height="@dimen/dp_6"
        android:layout_marginStart="@dimen/dp_4"/>
    <View
        android:id="@+id/v_diagnosis_four"
        android:background="@drawable/bg_shape_diagnose_check_level"
        android:layout_width="@dimen/dp_6"
        android:layout_height="@dimen/dp_6"
        android:layout_marginStart="@dimen/dp_4"/>
    <View
        android:id="@+id/v_diagnosis_five"
        android:background="@drawable/bg_shape_diagnose_check_level"
        android:layout_width="@dimen/dp_6"
        android:layout_height="@dimen/dp_6"
        android:layout_marginStart="@dimen/dp_4"/>
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/help_img"
        android:layout_width="@dimen/dp_10"
        android:layout_height="@dimen/dp_10"
        android:src="@drawable/ic_help"
        android:layout_marginStart="@dimen/dp_8"/>
</LinearLayout>
