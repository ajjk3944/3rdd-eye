<?xml version="1.0" encoding="utf-8"?>
<androidx.appcompat.widget.LinearLayoutCompat xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:keepScreenOn="true">
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <androidx.appcompat.widget.Toolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:contentInsetStartWithNavigation="0dp"
            app:title="@string/speed"/>
    </com.google.android.material.appbar.AppBarLayout>
    <androidx.core.widget.NestedScrollView
        android:id="@+id/bottom_layout"
        android:scrollbars="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <TextView
                android:textColor="@color/text_color"
                android:ellipsize="end"
                android:id="@+id/speed_gps_info"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:lines="1"
                android:layout_marginStart="@dimen/dp_10"
                app:layout_constraintBottom_toBottomOf="@+id/speed_sate_view"
                app:layout_constraintEnd_toStartOf="@+id/speed_sate_view"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="@+id/speed_sate_view"/>
            <TextView
                android:ellipsize="end"
                android:id="@+id/sate_found"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_10"
                android:lines="1"
                app:layout_constraintEnd_toStartOf="@+id/sate_used"
                app:layout_constraintStart_toStartOf="@+id/speed_gps_info"
                app:layout_constraintTop_toBottomOf="@+id/speed_sate_view"/>
            <TextView
                android:id="@+id/sate_used"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintEnd_toEndOf="@+id/speed_sate_view"
                app:layout_constraintTop_toTopOf="@+id/sate_found"/>
            <com.lefan.signal.ui.satellite.SatelliteView
                android:id="@+id/speed_sate_view"
                android:layout_width="@dimen/dp_30"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_10"
                android:layout_marginEnd="@dimen/dp_10"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintTop_toTopOf="parent"/>
            <androidx.constraintlayout.widget.Guideline
                android:orientation="vertical"
                android:id="@+id/v_50"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:layout_constraintGuide_percent="0.5"/>
            <com.lefan.signal.ui.speed.CompassView2
                android:id="@+id/speed_direction"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/dp_10"
                app:layout_constraintBottom_toTopOf="@+id/compass_text"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="@+id/v_50"
                app:layout_constraintTop_toTopOf="@+id/speed_speed"
                app:layout_constraintVertical_chainStyle="packed"/>
            <TextView
                android:textColor="@color/text_color"
                android:id="@+id/compass_text"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_10"
                android:text="@string/direction_travel"
                app:layout_constraintBottom_toTopOf="@+id/ad_view_in"
                app:layout_constraintEnd_toEndOf="@+id/speed_direction"
                app:layout_constraintStart_toStartOf="@+id/speed_direction"
                app:layout_constraintTop_toBottomOf="@+id/speed_direction"/>
            <com.lefan.ads.banner.BannerView
                android:id="@+id/ad_view_in"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                app:admob_bannerId="@string/admob_banner4"
                app:groMore_bannerId="@string/groMore_banner"
                app:layout_constraintBottom_toBottomOf="@+id/speed_speed"
                app:layout_constraintEnd_toEndOf="@+id/speed_direction"
                app:layout_constraintStart_toStartOf="@+id/speed_direction"
                app:tencent_bannerId="@string/tencent_banner4"
                app:yandex_bannerId="@string/yandex_banner4"/>
            <com.lefan.signal.ui.speed.SpeedView
                android:id="@+id/speed_speed"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_10"
                android:layout_marginStart="@dimen/dp_30"
                android:layout_marginEnd="@dimen/dp_30"
                app:layout_constraintEnd_toEndOf="@+id/v_50"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/sate_found"/>
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/location_perm_card"
                android:visibility="gone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                app:cardUseCompatPadding="true"
                app:contentPadding="@dimen/dp_10"
                app:layout_constraintTop_toBottomOf="@+id/speed_speed">
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:background="@drawable/empty_shape"
                    android:padding="@dimen/dp_10"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="120dp">
                    <TextView
                        android:gravity="center"
                        android:id="@+id/request_perm_text"
                        android:padding="@dimen/dp_10"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/speed_need_location"/>
                    <TextView
                        android:id="@+id/request_perm_btn"
                        android:background="@drawable/permission_btn_bg"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/action_settings"/>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
            <TextView
                android:id="@+id/speed_unit_text"
                android:padding="@dimen/dp_10"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_10"
                android:text="@string/speed_unit"
                app:layout_constraintTop_toBottomOf="@+id/location_perm_card"/>
            <androidx.appcompat.widget.LinearLayoutCompat
                android:id="@+id/speed_unit_liner"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:divider="@drawable/divider_ver"
                android:showDividers="middle"
                android:dividerPadding="@dimen/dp_10"
                app:layout_constraintTop_toBottomOf="@+id/speed_unit_text">
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:id="@+id/unit_kph"
                    android:background="?attr/selectableItemBackground"
                    android:padding="@dimen/dp_10"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView
                        android:textColor="#2196f3"
                        android:id="@+id/kph_t1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KPH"/>
                    <TextView
                        android:textColor="#2196f3"
                        android:gravity="center"
                        android:id="@+id/kph_t2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_6"
                        android:text="@string/kilometer"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:id="@+id/unit_mph"
                    android:background="?attr/selectableItemBackground"
                    android:padding="@dimen/dp_10"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView
                        android:textColor="@color/view_sub_color"
                        android:id="@+id/mph_t1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="MPH"/>
                    <TextView
                        android:textColor="@color/view_sub_color"
                        android:gravity="center"
                        android:id="@+id/mph_t2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_6"
                        android:text="@string/mile"/>
                </LinearLayout>
                <LinearLayout
                    android:gravity="center"
                    android:orientation="vertical"
                    android:id="@+id/unit_kn"
                    android:background="?attr/selectableItemBackground"
                    android:padding="@dimen/dp_10"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1">
                    <TextView
                        android:textColor="@color/view_sub_color"
                        android:id="@+id/kn_t1"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="KN"/>
                    <TextView
                        android:textColor="@color/view_sub_color"
                        android:gravity="center"
                        android:id="@+id/kn_t2"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="@dimen/dp_6"
                        android:text="@string/knots"/>
                </LinearLayout>
            </androidx.appcompat.widget.LinearLayoutCompat>
            <com.lefan.signal.ui.speed.SpeedTrendView
                android:id="@+id/speed_trend"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/dp_10"
                app:layout_constraintTop_toBottomOf="@+id/speed_unit_liner"/>
        </androidx.constraintlayout.widget.ConstraintLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.appcompat.widget.LinearLayoutCompat>
