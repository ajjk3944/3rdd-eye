<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        app:elevation="0dp">
        <include
            android:id="@+id/toolbar_layout"
            layout="@layout/content_top_toolbar"/>
    </com.google.android.material.appbar.AppBarLayout>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_bar"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:layout_marginStart="0dp"
            android:layout_marginEnd="0dp"
            android:layout_marginVertical="0dp"
            app:hideAnimationBehavior="outward"
            app:indeterminateAnimationType="contiguous"
            app:indicatorColor="@array/custom_progress_colors"
            app:indicatorDirectionLinear="leftToRight"
            app:showAnimationBehavior="inward"
            app:trackThickness="4dp"/>
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="4dp"
            android:layout_marginBottom="8dp"
            android:layout_weight="1">
            <LinearLayout
                android:orientation="vertical"
                android:layout_width="match_parent"
                android:layout_height="wrap_content">
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/CardView.Home">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:padding="8dp"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent">
                        <TextView
                            android:id="@+id/lb_target_host"
                            android:text="@string/txt_target_host"
                            app:drawableStartCompat="@drawable/ic_baseline_phone_android_24"
                            app:layout_constraintEnd_toStartOf="@+id/tv_target_host"
                            app:layout_constraintHorizontal_weight="0.5"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            style="@style/PingTextLeft"/>
                        <TextView
                            android:id="@+id/tv_target_host"
                            app:layout_constraintBottom_toBottomOf="@+id/lb_target_host"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_weight="0.5"
                            app:layout_constraintStart_toEndOf="@+id/lb_target_host"
                            app:layout_constraintTop_toTopOf="@+id/lb_target_host"
                            style="@style/PingTextRight"/>
                        <View
                            android:id="@+id/view1"
                            android:background="@color/colorDivider"
                            android:layout_width="0dp"
                            android:layout_height="1px"
                            android:layout_marginTop="12dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/lb_target_host"/>
                        <TextView
                            android:id="@+id/lb_average"
                            android:text="@string/txt_average_ping"
                            app:drawableStartCompat="@drawable/ic_baseline_average_ping_24"
                            app:layout_constraintEnd_toStartOf="@+id/tv_average"
                            app:layout_constraintHorizontal_weight="0.5"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/view1"
                            style="@style/PingTextLeft"/>
                        <TextView
                            android:id="@+id/tv_average"
                            app:layout_constraintBottom_toBottomOf="@+id/lb_average"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_weight="0.5"
                            app:layout_constraintStart_toEndOf="@+id/lb_average"
                            app:layout_constraintTop_toTopOf="@+id/lb_average"
                            style="@style/PingTextRight"/>
                        <View
                            android:id="@+id/view2"
                            android:background="@color/colorDivider"
                            android:layout_width="0dp"
                            android:layout_height="1px"
                            android:layout_marginTop="12dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/lb_average"/>
                        <TextView
                            android:id="@+id/lb_minimum"
                            android:text="@string/txt_minimum_ping"
                            app:drawableStartCompat="@drawable/ic_baseline_minimum_ping_24"
                            app:layout_constraintEnd_toStartOf="@+id/tv_minimum"
                            app:layout_constraintHorizontal_weight="0.5"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/view2"
                            style="@style/PingTextLeft"/>
                        <TextView
                            android:id="@+id/tv_minimum"
                            app:layout_constraintBottom_toBottomOf="@+id/lb_minimum"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_weight="0.5"
                            app:layout_constraintStart_toEndOf="@+id/lb_minimum"
                            app:layout_constraintTop_toTopOf="@+id/lb_minimum"
                            style="@style/PingTextRight"/>
                        <View
                            android:id="@+id/view3"
                            android:background="@color/colorDivider"
                            android:layout_width="0dp"
                            android:layout_height="1px"
                            android:layout_marginTop="12dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/lb_minimum"/>
                        <TextView
                            android:id="@+id/lb_maximum"
                            android:text="@string/txt_maximum_ping"
                            app:drawableStartCompat="@drawable/ic_baseline_maximum_ping_24"
                            app:layout_constraintEnd_toStartOf="@+id/tv_maximum"
                            app:layout_constraintHorizontal_weight="0.5"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/view3"
                            style="@style/PingTextLeft"/>
                        <TextView
                            android:id="@+id/tv_maximum"
                            app:layout_constraintBottom_toBottomOf="@+id/lb_maximum"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_weight="0.5"
                            app:layout_constraintStart_toEndOf="@+id/lb_maximum"
                            app:layout_constraintTop_toTopOf="@+id/lb_maximum"
                            style="@style/PingTextRight"/>
                        <View
                            android:id="@+id/view4"
                            android:background="@color/colorDivider"
                            android:layout_width="0dp"
                            android:layout_height="1px"
                            android:layout_marginTop="12dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/lb_maximum"/>
                        <TextView
                            android:id="@+id/lb_packet_loss"
                            android:layout_marginBottom="8dp"
                            android:text="@string/txt_packet_loss"
                            app:drawableStartCompat="@drawable/ic_baseline_packet_loss"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toStartOf="@+id/tv_packet_loss"
                            app:layout_constraintHorizontal_weight="0.5"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/view4"
                            style="@style/PingTextLeft"/>
                        <TextView
                            android:id="@+id/tv_packet_loss"
                            app:layout_constraintBottom_toBottomOf="@+id/lb_packet_loss"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintHorizontal_weight="0.5"
                            app:layout_constraintStart_toEndOf="@+id/lb_packet_loss"
                            app:layout_constraintTop_toTopOf="@+id/lb_packet_loss"
                            style="@style/PingTextRight"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    style="@style/CardView.Home">
                    <com.github.mikephil.charting.charts.LineChart
                        android:id="@+id/ping_chart"
                        android:layout_width="match_parent"
                        android:layout_height="160dp"/>
                </com.google.android.material.card.MaterialCardView>
                <com.google.android.material.card.MaterialCardView
                    android:layout_width="match_parent"
                    android:layout_height="0dp"
                    android:layout_weight="1"
                    style="@style/CardView.Home">
                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content">
                        <TextView
                            android:id="@+id/tv_ping_header"
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:text="@string/txt_log_ping"
                            android:layout_marginStart="16dp"
                            app:layout_constraintBottom_toBottomOf="@+id/btn_share"
                            app:layout_constraintEnd_toStartOf="@+id/btn_share"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="@+id/btn_share"
                            style="@style/CardView.Home.HeaderText"/>
                        <Button
                            android:id="@+id/btn_share"
                            android:visibility="invisible"
                            android:layout_width="32dp"
                            android:layout_height="32dp"
                            android:layout_marginTop="8dp"
                            android:onClick="doShare"
                            android:layout_marginEnd="8dp"
                            app:icon="@drawable/ic_menu_share"
                            app:iconGravity="textStart"
                            app:iconPadding="0dp"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            style="@style/Widget.MaterialComponents.Button.TextButton"/>
                        <androidx.recyclerview.widget.RecyclerView
                            android:id="@+id/rv_ping"
                            android:scrollbars="vertical"
                            android:layout_width="0dp"
                            android:layout_height="320dp"
                            android:fadeScrollbars="false"
                            app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toBottomOf="@+id/btn_share"/>
                        <ImageView
                            android:id="@+id/iv_s_background"
                            android:layout_width="wrap_content"
                            android:layout_height="100dp"
                            android:src="@drawable/ic_op_background"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent"
                            app:layout_constraintVertical_bias="0.5"
                            app:tint="?attr/colorAccent"/>
                        <ImageView
                            android:id="@+id/iv_s_icon"
                            android:layout_width="match_parent"
                            android:layout_height="40dp"
                            android:src="@drawable/ic_network_ping"
                            android:layout_centerInParent="true"
                            app:layout_constraintBottom_toBottomOf="@+id/iv_s_background"
                            app:layout_constraintEnd_toEndOf="@+id/iv_s_background"
                            app:layout_constraintStart_toStartOf="@+id/iv_s_background"
                            app:layout_constraintTop_toTopOf="@+id/iv_s_background"
                            app:tint="?attr/colorAccent"/>
                        <androidx.constraintlayout.widget.Group
                            android:id="@+id/gr_start_layout"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            app:constraint_referenced_ids="iv_s_background,iv_s_icon"/>
                    </androidx.constraintlayout.widget.ConstraintLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </ScrollView>
        <RelativeLayout
            android:layout_gravity="bottom"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <FrameLayout
                android:id="@+id/adPreLoad"
                android:background="?attr/colorOnBackground"
                android:layout_width="match_parent"
                android:layout_height="70dp"/>
            <FrameLayout
                android:layout_gravity="bottom"
                android:id="@+id/adViewContainer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"/>
        </RelativeLayout>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
