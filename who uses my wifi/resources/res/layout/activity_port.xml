<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="2dp">
        <include
            android:id="@+id/toolbar_layout"
            layout="@layout/content_top_toolbar"/>
    </com.google.android.material.appbar.AppBarLayout>
    <androidx.appcompat.widget.LinearLayoutCompat
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/progress_bar"
            android:visibility="invisible"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:indeterminate="true"
            android:layout_marginStart="0dp"
            android:layout_marginEnd="0dp"
            android:layout_marginVertical="0dp"
            app:hideAnimationBehavior="outward"
            app:indeterminateAnimationType="contiguous"
            app:indicatorColor="@array/custom_progress_colors"
            app:indicatorDirectionLinear="leftToRight"
            app:showAnimationBehavior="inward"
            app:trackThickness="4dp"/>
        <com.google.android.material.card.MaterialCardView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginBottom="4dp"
            android:layout_weight="1"
            style="@style/CardView.Home">
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="match_parent">
                <TextView
                    android:id="@+id/tv_port_header"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:text="@string/action_port_scan"
                    android:layout_marginStart="16dp"
                    app:layout_constraintBottom_toBottomOf="@+id/btn_share"
                    app:layout_constraintEnd_toStartOf="@+id/btn_share"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="@+id/btn_share"
                    style="@style/CardView.Home.HeaderText"/>
                <Button
                    android:id="@+id/btn_share"
                    android:visibility="invisible"
                    android:layout_width="32dp"
                    android:layout_height="32dp"
                    android:layout_marginTop="8dp"
                    android:onClick="doShare"
                    android:layout_marginEnd="8dp"
                    app:icon="@drawable/ic_menu_share"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    style="@style/Widget.MaterialComponents.Button.TextButton"/>
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_port"
                    android:scrollbars="vertical"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:fadeScrollbars="false"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/btn_share"/>
                <ImageView
                    android:id="@+id/iv_s_background"
                    android:layout_width="wrap_content"
                    android:layout_height="180dp"
                    android:src="@drawable/ic_op_background"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintVertical_bias="0.25"
                    app:tint="?attr/colorAccent"/>
                <ImageView
                    android:id="@+id/iv_s_icon"
                    android:layout_width="match_parent"
                    android:layout_height="56dp"
                    android:src="@drawable/ic_port_scan"
                    android:layout_centerInParent="true"
                    app:layout_constraintBottom_toBottomOf="@+id/iv_s_background"
                    app:layout_constraintEnd_toEndOf="@+id/iv_s_background"
                    app:layout_constraintStart_toStartOf="@+id/iv_s_background"
                    app:layout_constraintTop_toTopOf="@+id/iv_s_background"
                    app:tint="?attr/colorAccent"/>
                <Button
                    android:id="@+id/btn_start"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="@string/action_port_scan"
                    android:layout_centerInParent="true"
                    app:icon="@drawable/ic_menu_ping"
                    app:layout_constraintEnd_toEndOf="@+id/iv_s_background"
                    app:layout_constraintStart_toStartOf="@+id/iv_s_background"
                    app:layout_constraintTop_toBottomOf="@+id/iv_s_background"
                    style="@style/Widget.MaterialComponents.Button"/>
                <androidx.constraintlayout.widget.Group
                    android:id="@+id/gr_start_layout"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:constraint_referenced_ids="btn_start,iv_s_background,iv_s_icon"/>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.google.android.material.card.MaterialCardView>
        <FrameLayout
            android:id="@+id/adPreLoad"
            android:background="?attr/colorOnBackground"
            android:layout_width="match_parent"
            android:layout_height="70dp"/>
        <FrameLayout
            android:layout_gravity="bottom"
            android:id="@+id/adViewContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </androidx.appcompat.widget.LinearLayoutCompat>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
