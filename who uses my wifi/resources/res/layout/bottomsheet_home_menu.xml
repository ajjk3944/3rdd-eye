<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingBottom="8dp"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    style="@style/Widget.MaterialComponents.BottomSheet">
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="16dp"
            android:src="@mipmap/ic_launcher"/>
        <TextView
            android:textSize="14sp"
            android:textStyle="bold"
            android:textColor="?attr/colorOnSecondaryContainer"
            android:ellipsize="end"
            android:gravity="center"
            android:id="@+id/tv_name"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/app_name"
            android:maxLines="3"
            android:textAlignment="center"/>
        <TextView
            android:id="@+id/btn_router_default_pss"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="18dp"
            android:text="@string/action_router_password"
            app:drawableLeftCompat="@drawable/ic_menu_router"
            style="@style/BottomSheet.Item"/>
        <TextView
            android:id="@+id/btn_ping"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/action_ping"
            app:drawableLeftCompat="@drawable/ic_menu_ping"
            style="@style/BottomSheet.Item"/>
        <TextView
            android:id="@+id/btn_port"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/action_port_scan"
            app:drawableLeftCompat="@drawable/ic_port_scan"
            style="@style/BottomSheet.Item"/>
        <TextView
            android:id="@+id/btn_router_admin"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/action_router_admin"
            app:drawableLeftCompat="@drawable/ic_menu_router_admin"
            style="@style/BottomSheet.Item"/>
        <TextView
            android:id="@+id/btn_settings"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/action_settings"
            app:drawableLeftCompat="@drawable/ic_menu_settings"
            style="@style/BottomSheet.Item"/>
        <View
            android:id="@+id/view4"
            android:layout_width="match_parent"
            style="@style/BottomSheet.Divider"/>
        <TextView
            android:id="@+id/btn_upgrade"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/action_upgrade"
            app:drawableLeftCompat="@drawable/ic_shopping_cart"
            style="@style/BottomSheet.Item"/>
        <View
            android:id="@+id/view5"
            android:layout_width="match_parent"
            style="@style/BottomSheet.Divider"/>
        <TextView
            android:id="@+id/tv_communicate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/nav_com_title"
            style="@style/BottomSheet.Title"/>
        <TextView
            android:id="@+id/btn_share"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/action_share"
            app:drawableLeftCompat="@drawable/ic_menu_share"
            style="@style/BottomSheet.Item"/>
        <TextView
            android:id="@+id/btn_other"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/action_other"
            app:drawableLeftCompat="@drawable/ic_play_store"
            style="@style/BottomSheet.Item"/>
    </LinearLayout>
</androidx.core.widget.NestedScrollView>
