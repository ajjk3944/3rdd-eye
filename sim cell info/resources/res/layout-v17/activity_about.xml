<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:app="http://schemas.android.com/apk/res-auto"
    android:paddingLeft="@dimen/activity_horizontal_margin"
    android:paddingTop="@dimen/activity_vertical_margin"
    android:paddingRight="@dimen/activity_horizontal_margin"
    android:paddingBottom="@dimen/activity_vertical_margin"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <LinearLayout
            android:orientation="vertical"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_centerHorizontal="true">
            <TextView
                android:textAppearance="?android:attr/textAppearanceLarge"
                android:id="@+id/appNameTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="5dp"
                android:text="app name"
                android:layout_alignParentTop="true"
                android:layout_centerHorizontal="true"
                android:textAlignment="center"/>
            <TextView
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:id="@+id/versionTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="version"
                android:layout_below="@+id/appNameTextView"
                android:layout_alignLeft="@+id/appNameTextView"
                android:textAlignment="center"
                android:layout_alignStart="@+id/appNameTextView"/>
            <Space
                android:layout_gravity="center_horizontal"
                android:layout_width="match_parent"
                android:layout_height="20dp"/>
            <ImageView
                android:layout_gravity="center_horizontal"
                android:id="@+id/imageView2"
                android:background="@mipmap/ic_launcher"
                android:layout_width="100dp"
                android:layout_height="100dp"/>
            <TextView
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:id="@+id/authorTextView"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="25dp"
                android:text="author text"
                android:layout_below="@+id/versionTextView"
                android:layout_alignRight="@+id/appNameTextView"
                android:textAlignment="center"
                android:layout_alignEnd="@+id/appNameTextView"/>
            <Space
                android:layout_gravity="center_horizontal"
                android:layout_width="match_parent"
                android:layout_height="220dp"/>
            <TextView
                android:textAppearance="?android:attr/textAppearanceMedium"
                android:gravity="bottom"
                android:id="@+id/aboutBottomTextView"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:text="c year"
                android:layout_alignParentLeft="true"
                android:layout_alignParentTop="true"
                android:textAlignment="center"
                android:layout_alignParentStart="true"/>
        </LinearLayout>
    </ScrollView>
</RelativeLayout>
